---
/**
 * RoadworksMap v2 — Interactive roadworks map with timeline, filters, and list view.
 *
 * Features:
 * - Dark CartoDB tiles, dark-themed Leaflet
 * - CED (county division) boundaries as default overlay (county council = highways authority)
 * - Borough ward boundaries as optional toggle
 * - Colour-coded markers by severity, filled vs outlined for active/planned
 * - Timeline slider: scrub through dates, density heatmap, play/pause animation
 * - Filters: status, severity, operator, ward, restrictions, road search
 * - Roadworks list panel below map with sorting
 * - one.network links in popups
 * - Responsive and touch-friendly
 */

import wardData from '../data/burnley-wards.json';

// Pre-compute ward boundaries
const wardBoundaries = Object.entries(wardData.wards).map(([slug, ward]: [string, any]) => ({
  slug,
  name: ward.name || slug.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()),
  coordinates: ward.boundary?.coordinates?.[0] || [],
  centroid: ward.centroid || [0, 0],
}));

// Import CED boundaries (6 Burnley-area county council divisions)
import cedBoundariesData from '../data/burnley-ceds.json';
const cedBoundaries = cedBoundariesData as any[];
---

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />

<div class="roadworks-map-section">
  <!-- Controls row 1: Status + Severity -->
  <div class="map-controls">
    <div class="filter-group">
      <span class="filter-label">Status</span>
      <button class="filter-btn active" data-filter="status" data-value="all">All</button>
      <button class="filter-btn" data-filter="status" data-value="Works started">
        <span class="dot dot-red"></span> Active
      </button>
      <button class="filter-btn" data-filter="status" data-value="Planned works">
        <span class="dot dot-amber"></span> Planned
      </button>
    </div>
    <div class="filter-group">
      <span class="filter-label">Severity</span>
      <button class="filter-btn active" data-filter="severity" data-value="all">All</button>
      <button class="filter-btn" data-filter="severity" data-value="high">
        <span class="dot dot-red"></span> High
      </button>
      <button class="filter-btn" data-filter="severity" data-value="medium">
        <span class="dot dot-amber"></span> Medium
      </button>
      <button class="filter-btn" data-filter="severity" data-value="low">
        <span class="dot dot-green"></span> Low
      </button>
    </div>
  </div>

  <!-- Controls row 2: Operator, Ward, Restrictions, Search -->
  <div class="map-controls">
    <div class="filter-group">
      <span class="filter-label">Operator</span>
      <select id="operator-filter" class="map-select">
        <option value="all">All operators</option>
      </select>
    </div>
    <div class="filter-group">
      <span class="filter-label">Ward</span>
      <select id="ward-filter" class="map-select">
        <option value="all">All wards</option>
      </select>
    </div>
    <div class="filter-group">
      <span class="filter-label">Restrictions</span>
      <select id="restriction-filter" class="map-select">
        <option value="all">All types</option>
      </select>
    </div>
    <div class="filter-group search-group">
      <span class="filter-label">Road</span>
      <input type="text" id="road-search" class="road-search" placeholder="Search road name..." />
    </div>
    <div class="filter-group toggle-group">
      <label class="toggle-label">
        <input type="checkbox" id="ced-toggle" checked />
        <span>County divisions</span>
      </label>
      <label class="toggle-label">
        <input type="checkbox" id="ward-toggle" />
        <span>Wards</span>
      </label>
    </div>
  </div>

  <!-- Timeline -->
  <div class="timeline-container">
    <div class="timeline-header">
      <div class="timeline-date-display">
        <button class="timeline-nav-btn" id="timeline-prev" title="Previous day">&lsaquo;</button>
        <span id="timeline-date-label">Today</span>
        <button class="timeline-nav-btn" id="timeline-next" title="Next day">&rsaquo;</button>
      </div>
      <div class="timeline-controls">
        <button class="timeline-btn" id="timeline-today" title="Jump to today">Today</button>
        <button class="timeline-btn" id="timeline-play" title="Play animation">
          <svg id="play-icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          <svg id="pause-icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="display:none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
        </button>
        <button class="timeline-btn" id="timeline-mode" title="Toggle timeline mode">All dates</button>
      </div>
    </div>
    <div class="timeline-track-wrapper">
      <div class="timeline-heatmap" id="timeline-heatmap"></div>
      <input type="range" class="timeline-slider" id="timeline-slider" min="0" max="100" value="0" />
      <div class="timeline-labels">
        <span id="timeline-start-label"></span>
        <span id="timeline-end-label"></span>
      </div>
    </div>
    <div class="timeline-stats" id="timeline-stats"></div>
  </div>

  <!-- Stats bar -->
  <div class="map-stats-bar">
    <span id="map-stats-showing">Loading...</span>
    <span id="map-stats-updated"></span>
  </div>

  <!-- Map -->
  <div id="roadworks-map" class="map-container"></div>

  <!-- Legend -->
  <div class="map-legend">
    <div class="legend-item"><span class="legend-dot" style="background:#ef4444"></span> Active — High severity</div>
    <div class="legend-item"><span class="legend-dot" style="background:#f59e0b"></span> Active — Medium</div>
    <div class="legend-item"><span class="legend-dot" style="background:#22c55e"></span> Active — Low</div>
    <div class="legend-item"><span class="legend-circle" style="border-color:#ef4444"></span> Planned — High</div>
    <div class="legend-item"><span class="legend-circle" style="border-color:#f59e0b"></span> Planned — Medium</div>
    <div class="legend-item"><span class="legend-circle" style="border-color:#22c55e"></span> Planned — Low</div>
    <div class="legend-item"><span class="legend-line" style="border-color:rgba(245,158,11,0.5)"></span> County divisions</div>
    <div class="legend-item"><span class="legend-line legend-line-dash" style="border-color:rgba(18,182,207,0.45)"></span> Borough wards</div>
  </div>

  <!-- Roadworks list -->
  <div class="rw-list-section">
    <div class="rw-list-header">
      <h3 class="rw-list-title">
        Roadworks List
        <span class="rw-list-count" id="rw-list-count"></span>
      </h3>
      <div class="rw-list-sort">
        <select id="rw-sort" class="map-select">
          <option value="severity">Sort: Severity</option>
          <option value="road">Sort: Road name</option>
          <option value="start">Sort: Start date</option>
          <option value="end">Sort: End date</option>
          <option value="operator">Sort: Operator</option>
        </select>
      </div>
    </div>
    <div class="rw-list" id="rw-list"></div>
  </div>
</div>

<!-- Leaflet JS -->
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>

<script is:inline define:vars={{ wardBoundaries, cedBoundaries }}>
(function() {
  'use strict';

  // --- Config ---
  var TILE_URL = 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png';
  var TILE_ATTR = '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> &copy; <a href="https://carto.com/">CARTO</a>';
  var BURNLEY_CENTER = [53.789, -2.248];
  var INITIAL_ZOOM = 13;

  var SEVERITY_COLORS = { high: '#ef4444', medium: '#f59e0b', low: '#22c55e' };
  var SEVERITY_ORDER = { high: 0, medium: 1, low: 2 };

  var CED_STYLE = {
    color: 'rgba(245, 158, 11, 0.5)',
    weight: 2.5,
    fillColor: 'rgba(245, 158, 11, 0.04)',
    fillOpacity: 1,
    dashArray: null,
    interactive: false,
  };

  var WARD_STYLE = {
    color: 'rgba(18, 182, 207, 0.45)',
    weight: 1.5,
    fillColor: 'rgba(18, 182, 207, 0.05)',
    fillOpacity: 1,
    dashArray: '5 5',
    interactive: false,
  };

  // --- State ---
  var allRoadworks = [];
  var markers = [];
  var cedLayer = null;
  var wardLayer = null;
  var map = null;
  var filters = { status: 'all', severity: 'all', operator: 'all', ward: 'all', restriction: 'all', road: '' };
  var timelineMode = 'all'; // 'all' = show all matching filters, 'date' = only show roadworks active on selected date
  var selectedDate = null; // Date object for timeline cursor
  var dateRangeStart = null;
  var dateRangeEnd = null;
  var playInterval = null;
  var sortBy = 'severity';

  // --- XSS-safe escape ---
  function esc(s) {
    if (!s) return '';
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  // --- Format date ---
  function fmtDate(iso) {
    if (!iso) return '\u2014';
    try {
      return new Date(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
    } catch(e) { return '\u2014'; }
  }

  function fmtDateShort(date) {
    if (!date) return '';
    return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
  }

  function fmtDateFull(date) {
    if (!date) return '';
    return date.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
  }

  function toDateOnly(iso) {
    if (!iso) return null;
    try { return new Date(iso.substring(0, 10) + 'T00:00:00Z'); }
    catch(e) { return null; }
  }

  function daysBetween(a, b) {
    return Math.round((b - a) / (1000 * 60 * 60 * 24));
  }

  // --- Humanise restriction ---
  function humanRestriction(r) {
    if (!r) return 'None';
    return r.replace(/([a-z])([A-Z])/g, '$1 $2').replace(/^./, function(c) { return c.toUpperCase(); });
  }

  // --- Init map ---
  function initMap() {
    var container = document.getElementById('roadworks-map');
    if (!container || typeof L === 'undefined') return;

    map = L.map(container, { zoomControl: true, scrollWheelZoom: true, attributionControl: true });
    window._rwMap = map;

    L.tileLayer(TILE_URL, { attribution: TILE_ATTR, maxZoom: 18, subdomains: 'abcd' }).addTo(map);
    map.setView(BURNLEY_CENTER, INITIAL_ZOOM);

    // Fix tile loading when map initializes off-screen
    setTimeout(function() { map.invalidateSize(); map.setView(BURNLEY_CENTER, INITIAL_ZOOM); }, 200);

    drawCEDs();
    fetchRoadworks();
  }

  // --- CED boundaries (default) ---
  function drawCEDs() {
    if (!cedBoundaries || !cedBoundaries.length) return;
    cedLayer = L.layerGroup().addTo(map);

    cedBoundaries.forEach(function(ced) {
      if (!ced.coordinates || !ced.coordinates.length) return;
      var latlngs = ced.coordinates.map(function(c) { return [c[1], c[0]]; });
      var poly = L.polygon(latlngs, CED_STYLE);
      poly.bindTooltip(esc(ced.name), {
        permanent: false, direction: 'center', className: 'ced-tooltip',
      });
      cedLayer.addLayer(poly);
    });
  }

  // --- Ward boundaries (toggle) ---
  function drawWards() {
    if (!wardBoundaries || !wardBoundaries.length) return;
    wardLayer = L.layerGroup();

    wardBoundaries.forEach(function(ward) {
      if (!ward.coordinates || !ward.coordinates.length) return;
      var latlngs = ward.coordinates.map(function(c) { return [c[1], c[0]]; });
      var poly = L.polygon(latlngs, WARD_STYLE);
      poly.bindTooltip(esc(ward.name), {
        permanent: false, direction: 'center', className: 'ward-tooltip',
      });
      wardLayer.addLayer(poly);
    });
  }

  // --- Fetch roadworks ---
  function fetchRoadworks() {
    fetch('/data/roadworks.json')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        allRoadworks = data.roadworks || [];
        populateFilters(data.stats);
        updateMeta(data);
        initTimeline();
        renderMarkers();
        renderList();
      })
      .catch(function(err) {
        console.error('Failed to load roadworks:', err);
        document.getElementById('map-stats-showing').textContent = 'Failed to load roadworks data';
      });
  }

  // --- Populate filter dropdowns ---
  function populateFilters(stats) {
    // Operators
    var opSel = document.getElementById('operator-filter');
    if (opSel && stats && stats.by_operator) {
      Object.keys(stats.by_operator).forEach(function(op) {
        var opt = document.createElement('option');
        opt.value = op;
        opt.textContent = op + ' (' + stats.by_operator[op] + ')';
        opSel.appendChild(opt);
      });
    }
    // Wards
    var wardSel = document.getElementById('ward-filter');
    if (wardSel && stats && stats.by_ward) {
      Object.keys(stats.by_ward).sort().forEach(function(w) {
        var opt = document.createElement('option');
        opt.value = w;
        opt.textContent = w + ' (' + stats.by_ward[w] + ')';
        wardSel.appendChild(opt);
      });
    }
    // Restrictions
    var resSel = document.getElementById('restriction-filter');
    if (resSel && stats && stats.by_restriction) {
      Object.keys(stats.by_restriction).forEach(function(r) {
        var opt = document.createElement('option');
        opt.value = r;
        opt.textContent = humanRestriction(r) + ' (' + stats.by_restriction[r] + ')';
        resSel.appendChild(opt);
      });
    }
  }

  // --- Update meta ---
  function updateMeta(data) {
    var el = document.getElementById('map-stats-updated');
    if (el && data.meta && data.meta.generated) {
      el.textContent = 'Updated ' + fmtDate(data.meta.generated);
    }
  }

  // --- Timeline ---
  function initTimeline() {
    if (!allRoadworks.length) return;

    // Find date range — use a sensible window, not the full extreme range
    var starts = allRoadworks.map(function(r) { return toDateOnly(r.start_date); }).filter(Boolean);
    var ends = allRoadworks.map(function(r) { return toDateOnly(r.end_date); }).filter(Boolean);
    if (!starts.length || !ends.length) return;

    var absStart = new Date(Math.min.apply(null, starts));
    var absEnd = new Date(Math.max.apply(null, ends));

    // Default range: 1 week before today to 3 months after, capped by actual data
    var today = new Date(); today.setHours(0, 0, 0, 0);
    var weekAgo = new Date(today.getTime() - 7 * 86400000);
    var threeMonths = new Date(today.getTime() + 90 * 86400000);

    // Find the 95th percentile end date to avoid outlier long-duration works skewing the range
    var sortedEnds = ends.slice().sort(function(a, b) { return a - b; });
    var p95End = sortedEnds[Math.floor(sortedEnds.length * 0.95)] || absEnd;

    dateRangeStart = absStart < weekAgo ? weekAgo : absStart;
    dateRangeEnd = p95End > threeMonths ? threeMonths : (p95End > absEnd ? absEnd : p95End);
    // Ensure we don't clip short — at minimum cover all planned works start dates
    if (dateRangeEnd < p95End) dateRangeEnd = p95End;

    // Default to today
    var today = new Date();
    today.setHours(0, 0, 0, 0);
    selectedDate = today < dateRangeStart ? dateRangeStart : (today > dateRangeEnd ? dateRangeEnd : today);

    var slider = document.getElementById('timeline-slider');
    var totalDays = daysBetween(dateRangeStart, dateRangeEnd);
    if (slider) {
      slider.max = totalDays;
      slider.value = daysBetween(dateRangeStart, selectedDate);
    }

    // Labels
    document.getElementById('timeline-start-label').textContent = fmtDateShort(dateRangeStart);
    document.getElementById('timeline-end-label').textContent = fmtDateShort(dateRangeEnd);

    updateTimelineDisplay();
    buildHeatmap(totalDays);
  }

  function buildHeatmap(totalDays) {
    var container = document.getElementById('timeline-heatmap');
    if (!container) return;
    container.innerHTML = '';

    // Compute density per day
    var maxCount = 0;
    var densities = [];
    for (var d = 0; d <= totalDays; d++) {
      var date = new Date(dateRangeStart.getTime() + d * 86400000);
      var count = countActiveOnDate(date);
      densities.push(count);
      if (count > maxCount) maxCount = count;
    }

    // Render bars (use canvas for performance)
    var canvas = document.createElement('canvas');
    canvas.width = container.clientWidth || 600;
    canvas.height = 24;
    canvas.style.width = '100%';
    canvas.style.height = '24px';
    canvas.style.borderRadius = '4px';
    container.appendChild(canvas);

    var ctx = canvas.getContext('2d');
    var barW = canvas.width / (totalDays + 1);

    for (var i = 0; i <= totalDays; i++) {
      var pct = maxCount > 0 ? densities[i] / maxCount : 0;
      var r = Math.round(18 + pct * (239 - 18));
      var g = Math.round(182 + pct * (68 - 182));
      var b = Math.round(207 + pct * (68 - 207));
      ctx.fillStyle = 'rgba(' + r + ',' + g + ',' + b + ',' + (0.15 + pct * 0.7) + ')';
      ctx.fillRect(i * barW, 0, Math.max(barW - 0.5, 1), 24);
    }

    // Today marker
    var today = new Date();
    today.setHours(0, 0, 0, 0);
    if (today >= dateRangeStart && today <= dateRangeEnd) {
      var todayPos = daysBetween(dateRangeStart, today) * barW;
      ctx.fillStyle = '#fff';
      ctx.fillRect(todayPos - 1, 0, 2, 24);
    }
  }

  function countActiveOnDate(date) {
    var t = date.getTime();
    return allRoadworks.filter(function(r) {
      var s = toDateOnly(r.start_date);
      var e = toDateOnly(r.end_date);
      return s && e && s.getTime() <= t && e.getTime() >= t;
    }).length;
  }

  function updateTimelineDisplay() {
    var label = document.getElementById('timeline-date-label');
    if (label) {
      if (timelineMode === 'all') {
        label.textContent = 'All dates';
      } else {
        label.textContent = fmtDateFull(selectedDate);
      }
    }

    var modeBtn = document.getElementById('timeline-mode');
    if (modeBtn) {
      modeBtn.textContent = timelineMode === 'all' ? 'All dates' : 'Date filter';
      modeBtn.classList.toggle('active', timelineMode === 'date');
    }

    var statsEl = document.getElementById('timeline-stats');
    if (statsEl && timelineMode === 'date' && selectedDate) {
      var count = countActiveOnDate(selectedDate);
      statsEl.textContent = count + ' roadworks active on ' + fmtDateFull(selectedDate);
      statsEl.style.display = 'block';
    } else if (statsEl) {
      statsEl.style.display = 'none';
    }
  }

  function setTimelineDate(dayIndex) {
    selectedDate = new Date(dateRangeStart.getTime() + dayIndex * 86400000);
    var slider = document.getElementById('timeline-slider');
    if (slider) slider.value = dayIndex;
    updateTimelineDisplay();
    renderMarkers();
    renderList();
  }

  // --- Filter logic ---
  function getFiltered() {
    var roadSearch = filters.road.toLowerCase();
    return allRoadworks.filter(function(r) {
      if (filters.status !== 'all' && r.status !== filters.status) return false;
      if (filters.severity !== 'all' && r.severity !== filters.severity) return false;
      if (filters.operator !== 'all' && r.operator !== filters.operator) return false;
      if (filters.ward !== 'all' && r.ward !== filters.ward) return false;
      if (filters.restriction !== 'all') {
        var rr = r.restrictions || 'none';
        if (rr !== filters.restriction) return false;
      }
      if (roadSearch && r.road.toLowerCase().indexOf(roadSearch) === -1) return false;

      // Timeline date filter
      if (timelineMode === 'date' && selectedDate) {
        var s = toDateOnly(r.start_date);
        var e = toDateOnly(r.end_date);
        if (!s || !e) return false;
        var t = selectedDate.getTime();
        if (s.getTime() > t || e.getTime() < t) return false;
      }

      return true;
    });
  }

  // --- Sort logic ---
  function sortRecords(records) {
    var sorted = records.slice();
    switch (sortBy) {
      case 'road':
        sorted.sort(function(a, b) { return (a.road || '').localeCompare(b.road || ''); });
        break;
      case 'start':
        sorted.sort(function(a, b) { return (a.start_date || '').localeCompare(b.start_date || ''); });
        break;
      case 'end':
        sorted.sort(function(a, b) { return (a.end_date || '').localeCompare(b.end_date || ''); });
        break;
      case 'operator':
        sorted.sort(function(a, b) { return (a.operator || '').localeCompare(b.operator || ''); });
        break;
      default:
        sorted.sort(function(a, b) { return (SEVERITY_ORDER[a.severity] || 9) - (SEVERITY_ORDER[b.severity] || 9); });
    }
    return sorted;
  }

  // --- Render markers ---
  function renderMarkers() {
    markers.forEach(function(m) { map.removeLayer(m); });
    markers = [];

    var filtered = getFiltered();

    filtered.forEach(function(rw) {
      if (!rw.lat || !rw.lng) return;

      var color = SEVERITY_COLORS[rw.severity] || '#8e8e93';
      var isActive = rw.status === 'Works started';
      var radius = isActive ? 9 : 7;

      var marker = L.circleMarker([rw.lat, rw.lng], {
        radius: radius,
        fillColor: color,
        fillOpacity: isActive ? 0.85 : 0.15,
        color: color,
        weight: isActive ? 2.5 : 2,
        opacity: 1,
      });

      // Build popup
      var sevBadge = '<span style="display:inline-block;padding:2px 6px;border-radius:4px;font-size:11px;font-weight:600;background:' + color + '20;color:' + color + '">' + esc(rw.severity) + '</span>';
      var statusBadge = '<span style="display:inline-block;padding:2px 6px;border-radius:4px;font-size:11px;font-weight:600;background:' + (isActive ? '#ef444420' : '#f59e0b20') + ';color:' + (isActive ? '#ef4444' : '#f59e0b') + '">' + esc(rw.status) + '</span>';

      var html = '<div style="font-family:-apple-system,BlinkMacSystemFont,sans-serif;min-width:220px;max-width:300px">'
        + '<div style="font-weight:700;font-size:14px;margin-bottom:4px;color:#fff">' + esc(rw.road) + '</div>'
        + '<div style="font-size:12px;color:#aaa;margin-bottom:6px">' + esc(rw.ward) + '</div>'
        + '<div style="display:flex;gap:6px;margin-bottom:8px">' + statusBadge + sevBadge + '</div>'
        + '<div style="font-size:12px;color:#ccc;line-height:1.6">'
        + '<div><strong>Dates:</strong> ' + fmtDate(rw.start_date) + ' \u2014 ' + fmtDate(rw.end_date) + '</div>'
        + '<div><strong>Operator:</strong> ' + esc(rw.operator) + '</div>';

      if (rw.restrictions) {
        html += '<div><strong>Restrictions:</strong> ' + esc(humanRestriction(rw.restrictions)) + '</div>';
      }
      if (rw.impact) {
        html += '<div><strong>Impact:</strong> ' + esc(rw.impact.replace(/([a-z])([A-Z])/g, '$1 $2')) + '</div>';
      }
      if (rw.category) {
        html += '<div><strong>Category:</strong> ' + esc(rw.category) + '</div>';
      }
      if (rw.description) {
        html += '<div style="margin-top:4px;color:#999;font-size:11px">' + esc(rw.description.substring(0, 200)) + '</div>';
      }
      if (rw.one_network_url) {
        html += '<div style="margin-top:6px"><a href="' + esc(rw.one_network_url) + '" target="_blank" rel="noopener" style="color:#12b6cf;font-size:12px;text-decoration:none">View on one.network \u2192</a></div>';
      }

      html += '</div></div>';

      marker.bindPopup(html, { className: 'rw-popup', maxWidth: 320 });
      marker.rwData = rw; // attach data for list interaction
      marker.addTo(map);
      markers.push(marker);
    });

    // Update stats
    var statsEl = document.getElementById('map-stats-showing');
    if (statsEl) {
      var active = filtered.filter(function(r) { return r.status === 'Works started'; }).length;
      var planned = filtered.filter(function(r) { return r.status === 'Planned works'; }).length;
      statsEl.textContent = filtered.length + ' roadworks (' + active + ' active, ' + planned + ' planned)';
    }
  }

  // --- Compute duration in days ---
  function durationDays(r) {
    var s = toDateOnly(r.start_date);
    var e = toDateOnly(r.end_date);
    if (!s || !e) return 0;
    return Math.max(1, daysBetween(s, e));
  }

  function durationLabel(days) {
    if (days <= 1) return '1 day';
    if (days < 7) return days + ' days';
    if (days < 30) return Math.round(days / 7) + ' week' + (Math.round(days / 7) !== 1 ? 's' : '');
    return Math.round(days / 30) + ' month' + (Math.round(days / 30) !== 1 ? 's' : '');
  }

  // --- Render list ---
  function renderList() {
    var listEl = document.getElementById('rw-list');
    var countEl = document.getElementById('rw-list-count');
    if (!listEl) return;

    var filtered = sortRecords(getFiltered());
    if (countEl) countEl.textContent = '(' + filtered.length + ')';

    if (!filtered.length) {
      listEl.innerHTML = '<div class="rw-list-empty">No roadworks match your filters</div>';
      return;
    }

    // Cap to 60 items
    var display = filtered.slice(0, 60);
    var html = '';
    display.forEach(function(rw) {
      var color = SEVERITY_COLORS[rw.severity] || '#8e8e93';
      var isActive = rw.status === 'Works started';
      var days = durationDays(rw);
      var durText = durationLabel(days);
      var restrictionText = rw.restrictions ? humanRestriction(rw.restrictions) : '';

      // Duration bar width (proportional, max 100% = 90 days)
      var barPct = Math.min(100, (days / 90) * 100);

      html += '<div class="rw-card" data-id="' + rw.id + '">'
        // Left severity bar
        + '<div class="rw-card-bar" style="background:' + color + ';opacity:' + (isActive ? '1' : '0.35') + '"></div>'
        + '<div class="rw-card-body">'
        // Row 1: road name + status/severity
        + '<div class="rw-card-top">'
        + '<div class="rw-card-road">' + esc(rw.road) + '</div>'
        + '<div class="rw-card-tags">'
        + '<span class="rw-tag" style="background:' + (isActive ? '#ef444418' : '#f59e0b18') + ';color:' + (isActive ? '#ef4444' : '#f59e0b') + '">' + (isActive ? 'Active' : 'Planned') + '</span>'
        + '<span class="rw-tag" style="background:' + color + '18;color:' + color + '">' + esc(rw.severity) + '</span>'
        + (restrictionText ? '<span class="rw-tag rw-tag-muted">' + esc(restrictionText) + '</span>' : '')
        + '</div>'
        + '</div>'
        // Row 2: meta
        + '<div class="rw-card-meta">'
        + '<span>' + esc(rw.ward) + '</span>'
        + '<span class="rw-card-dot">\u00b7</span>'
        + '<span>' + esc(rw.operator) + '</span>'
        + (rw.category ? '<span class="rw-card-dot">\u00b7</span><span>' + esc(rw.category) + '</span>' : '')
        + '</div>'
        // Row 3: dates + duration bar
        + '<div class="rw-card-dates">'
        + '<span class="rw-card-date-text">' + fmtDate(rw.start_date) + ' \u2014 ' + fmtDate(rw.end_date) + ' (' + durText + ')</span>'
        + '</div>'
        + '<div class="rw-card-duration-track">'
        + '<div class="rw-card-duration-fill" style="width:' + barPct + '%;background:' + color + ';opacity:' + (isActive ? '0.6' : '0.2') + '"></div>'
        + '</div>';

      // Row 4: description (if present, truncated)
      if (rw.description && rw.description.length > 30) {
        var desc = rw.description.split('|')[0]; // Take first part before pipe separator
        if (desc.length > 120) desc = desc.substring(0, 120) + '\u2026';
        html += '<div class="rw-card-desc">' + esc(desc) + '</div>';
      }

      // Row 5: one.network link
      if (rw.one_network_url) {
        html += '<a href="' + esc(rw.one_network_url) + '" target="_blank" rel="noopener" class="rw-card-link" onclick="event.stopPropagation()">View on one.network \u2192</a>';
      }

      html += '</div></div>';
    });

    if (filtered.length > 60) {
      html += '<div class="rw-list-more">Showing 60 of ' + filtered.length + ' \u2014 use filters to narrow results</div>';
    }

    listEl.innerHTML = html;

    // Click handlers — zoom to marker
    listEl.querySelectorAll('.rw-card').forEach(function(card) {
      card.addEventListener('click', function() {
        var id = parseInt(card.getAttribute('data-id'));
        var marker = markers.find(function(m) { return m.rwData && m.rwData.id === id; });
        if (marker) {
          map.setView(marker.getLatLng(), 16);
          marker.openPopup();
          // Scroll map into view
          document.getElementById('roadworks-map').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });
    });
  }

  // --- Event listeners ---

  // Filter buttons
  document.querySelectorAll('.filter-btn[data-filter]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var filterType = btn.getAttribute('data-filter');
      var value = btn.getAttribute('data-value');
      filters[filterType] = value;
      btn.closest('.filter-group').querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      renderMarkers();
      renderList();
    });
  });

  // Dropdowns
  ['operator-filter', 'ward-filter', 'restriction-filter'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) {
      el.addEventListener('change', function() {
        var key = id.replace('-filter', '');
        filters[key] = el.value;
        renderMarkers();
        renderList();
      });
    }
  });

  // Road search
  var searchEl = document.getElementById('road-search');
  if (searchEl) {
    var searchTimeout;
    searchEl.addEventListener('input', function() {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(function() {
        filters.road = searchEl.value;
        renderMarkers();
        renderList();
      }, 250);
    });
  }

  // CED toggle
  var cedToggle = document.getElementById('ced-toggle');
  if (cedToggle) {
    cedToggle.addEventListener('change', function() {
      if (cedToggle.checked && cedLayer) { cedLayer.addTo(map); }
      else if (cedLayer) { map.removeLayer(cedLayer); }
    });
  }

  // Ward toggle
  var wardToggle = document.getElementById('ward-toggle');
  if (wardToggle) {
    wardToggle.addEventListener('change', function() {
      if (!wardLayer) drawWards();
      if (wardToggle.checked && wardLayer) { wardLayer.addTo(map); }
      else if (wardLayer) { map.removeLayer(wardLayer); }
    });
  }

  // Timeline slider
  var slider = document.getElementById('timeline-slider');
  if (slider) {
    slider.addEventListener('input', function() {
      if (timelineMode === 'all') { timelineMode = 'date'; }
      setTimelineDate(parseInt(slider.value));
    });
  }

  // Timeline nav buttons
  document.getElementById('timeline-prev')?.addEventListener('click', function() {
    if (timelineMode === 'all') { timelineMode = 'date'; }
    var cur = daysBetween(dateRangeStart, selectedDate);
    if (cur > 0) setTimelineDate(cur - 1);
  });

  document.getElementById('timeline-next')?.addEventListener('click', function() {
    if (timelineMode === 'all') { timelineMode = 'date'; }
    var cur = daysBetween(dateRangeStart, selectedDate);
    var max = daysBetween(dateRangeStart, dateRangeEnd);
    if (cur < max) setTimelineDate(cur + 1);
  });

  // Today button
  document.getElementById('timeline-today')?.addEventListener('click', function() {
    timelineMode = 'date';
    var today = new Date(); today.setHours(0,0,0,0);
    var idx = daysBetween(dateRangeStart, today);
    idx = Math.max(0, Math.min(idx, daysBetween(dateRangeStart, dateRangeEnd)));
    setTimelineDate(idx);
  });

  // Timeline mode toggle
  document.getElementById('timeline-mode')?.addEventListener('click', function() {
    timelineMode = timelineMode === 'all' ? 'date' : 'all';
    updateTimelineDisplay();
    renderMarkers();
    renderList();
  });

  // Play/pause
  document.getElementById('timeline-play')?.addEventListener('click', function() {
    if (playInterval) {
      clearInterval(playInterval);
      playInterval = null;
      document.getElementById('play-icon').style.display = '';
      document.getElementById('pause-icon').style.display = 'none';
      return;
    }

    timelineMode = 'date';
    document.getElementById('play-icon').style.display = 'none';
    document.getElementById('pause-icon').style.display = '';

    var cur = daysBetween(dateRangeStart, selectedDate);
    var max = daysBetween(dateRangeStart, dateRangeEnd);

    playInterval = setInterval(function() {
      cur++;
      if (cur > max) {
        clearInterval(playInterval);
        playInterval = null;
        document.getElementById('play-icon').style.display = '';
        document.getElementById('pause-icon').style.display = 'none';
        return;
      }
      setTimelineDate(cur);
    }, 200);
  });

  // Sort
  var sortEl = document.getElementById('rw-sort');
  if (sortEl) {
    sortEl.addEventListener('change', function() {
      sortBy = sortEl.value;
      renderList();
    });
  }

  // --- Init ---
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMap);
  } else {
    initMap();
  }
})();
</script>

