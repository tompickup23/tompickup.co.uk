---
/**
 * RoadworksMap v3 — Netflix-quality interactive roadworks map.
 *
 * Features:
 * - Dark CartoDB tiles with ambient glow border
 * - Pulsing markers for active works, glass popups
 * - CED county division boundaries (default) + borough ward boundaries
 * - Timeline with density heatmap, play/pause, date navigation
 * - Postcode search via postcodes.io API
 * - Glassmorphism summary stat cards with animated counters
 * - Filters: status, severity, operator, ward, restrictions, road search
 * - Card-based list with duration bars and one.network links
 * - Responsive and touch-friendly
 */

import wardData from '../data/burnley-wards.json';

const wardBoundaries = Object.entries(wardData.wards).map(([slug, ward]: [string, any]) => ({
  slug,
  name: ward.name || slug.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()),
  coordinates: ward.boundary?.coordinates?.[0] || [],
  centroid: ward.centroid || [0, 0],
}));

import cedBoundariesData from '../data/burnley-ceds.json';
const cedBoundaries = cedBoundariesData as any[];
---

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" crossorigin="" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" crossorigin="" />

<div class="rw-section">
  <!-- Summary stats -->
  <div class="rw-stats-grid" id="rw-stats-grid">
    <div class="rw-stat-card rw-stat-active rw-shimmer">
      <div class="rw-stat-value" id="stat-active">—</div>
      <div class="rw-stat-label">Active Works</div>
      <div class="rw-stat-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </div>
    </div>
    <div class="rw-stat-card rw-stat-planned rw-shimmer">
      <div class="rw-stat-value" id="stat-planned">—</div>
      <div class="rw-stat-label">Planned Works</div>
      <div class="rw-stat-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      </div>
    </div>
    <div class="rw-stat-card rw-stat-high rw-shimmer">
      <div class="rw-stat-value" id="stat-high">—</div>
      <div class="rw-stat-label">High Severity</div>
      <div class="rw-stat-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      </div>
    </div>
    <div class="rw-stat-card rw-stat-closures rw-shimmer">
      <div class="rw-stat-value" id="stat-closures">—</div>
      <div class="rw-stat-label">Road Closures</div>
      <div class="rw-stat-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
      </div>
    </div>
    <div class="rw-stat-card rw-stat-districts rw-shimmer">
      <div class="rw-stat-value" id="stat-districts">—</div>
      <div class="rw-stat-label">Districts</div>
      <div class="rw-stat-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      </div>
    </div>
  </div>

  <!-- Postcode search + filters row 1 -->
  <div class="rw-controls">
    <div class="rw-search-box">
      <svg class="rw-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="postcode-search" class="rw-search-input" placeholder="Search postcode or road..." aria-label="Search by postcode or road name" />
      <button class="rw-search-clear" id="search-clear" type="button" aria-label="Clear search" style="display:none">&times;</button>
      <kbd class="rw-search-kbd">Enter</kbd>
    </div>
    <div class="rw-filter-chips">
      <button class="rw-chip active" data-filter="status" data-value="all" aria-pressed="true">All</button>
      <button class="rw-chip rw-chip-red" data-filter="status" data-value="Works started" aria-pressed="false">
        <span class="rw-pulse-dot"></span> Active
      </button>
      <button class="rw-chip rw-chip-amber" data-filter="status" data-value="Planned works" aria-pressed="false">Planned</button>
    </div>
    <div class="rw-filter-chips">
      <button class="rw-chip active" data-filter="severity" data-value="all" aria-pressed="true">All</button>
      <button class="rw-chip rw-chip-red" data-filter="severity" data-value="high" aria-pressed="false">High</button>
      <button class="rw-chip rw-chip-amber" data-filter="severity" data-value="medium" aria-pressed="false">Med</button>
      <button class="rw-chip rw-chip-green" data-filter="severity" data-value="low" aria-pressed="false">Low</button>
    </div>
    <button class="rw-reset-btn" id="reset-filters" title="Clear all filters and reset view" style="display:none">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      Reset filters
    </button>
  </div>

  <!-- Filters row 2 -->
  <div class="rw-controls rw-controls-secondary">
    <select id="district-filter" class="rw-select rw-select-district"><option value="all">All Lancashire</option></select>
    <select id="operator-filter" class="rw-select"><option value="all">All operators</option></select>
    <select id="ward-filter" class="rw-select"><option value="all">All wards</option></select>
    <select id="restriction-filter" class="rw-select"><option value="all">All restrictions</option></select>
    <div class="rw-boundary-toggles">
      <label class="rw-toggle"><input type="checkbox" id="ced-toggle" checked /><span>County divisions</span></label>
      <label class="rw-toggle"><input type="checkbox" id="ward-toggle" /><span>Wards</span></label>
      <label class="rw-toggle rw-toggle-intel" title="Show traffic signals, junctions, DfT count points, and schools"><input type="checkbox" id="traffic-intel-toggle" /><span>Traffic intelligence</span><span class="rw-toggle-hint">Signals, junctions, schools</span></label>
      <label class="rw-toggle rw-toggle-intel" title="Show modelled congestion corridors with severity levels"><input type="checkbox" id="corridor-toggle" /><span>Congestion corridors</span><span class="rw-toggle-hint">Modelled severity</span></label>
    </div>
  </div>

  <!-- Staleness warning -->
  <div class="rw-stale-warning" id="rw-stale-warning" style="display:none">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    <span id="rw-stale-text">Data may be stale</span>
  </div>

  <!-- Postcode not found toast -->
  <div class="rw-toast" id="rw-toast" style="display:none"></div>

  <!-- Timeline -->
  <div class="rw-timeline">
    <div class="rw-timeline-top">
      <div class="rw-timeline-nav">
        <button class="rw-tl-btn" id="timeline-prev" title="Previous day">&lsaquo;</button>
        <span class="rw-tl-date" id="timeline-date-label">All dates</span>
        <button class="rw-tl-btn" id="timeline-next" title="Next day">&rsaquo;</button>
      </div>
      <div class="rw-timeline-actions">
        <button class="rw-tl-action" id="timeline-today">Today</button>
        <button class="rw-tl-action" id="timeline-mode">All dates</button>
      </div>
    </div>
    <div class="rw-timeline-track">
      <div class="rw-heatmap" id="timeline-heatmap"></div>
      <input type="range" class="rw-slider" id="timeline-slider" min="0" max="100" value="0" />
    </div>
    <div class="rw-play-row">
      <span id="timeline-start-label" class="rw-tl-edge-label"></span>
      <button class="rw-play-btn" id="timeline-play" title="Play through timeline day by day">
        <svg id="play-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21"/></svg>
        <svg id="pause-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="display:none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
        <span class="rw-play-label" id="play-label">Play Timeline</span>
      </button>
      <div class="rw-speed-controls" id="speed-controls">
        <button class="rw-speed-btn" data-speed="1200" title="0.5x speed">0.5x</button>
        <button class="rw-speed-btn rw-speed-active" data-speed="600" title="1x speed">1x</button>
        <button class="rw-speed-btn" data-speed="300" title="2x speed">2x</button>
      </div>
      <span class="rw-play-summary" id="play-summary"></span>
      <span class="rw-tl-count" id="timeline-stats"></span>
      <span id="timeline-end-label" class="rw-tl-edge-label"></span>
    </div>
  </div>

  <!-- 24-hour disruption strip -->
  <div class="rw-hourly" id="rw-hourly-section">
    <div class="rw-hourly-header">
      <span class="rw-hourly-title">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Hourly disruption
      </span>
      <div class="rw-hourly-actions">
        <span class="rw-hourly-info" id="hourly-info"></span>
        <button class="rw-tl-action" id="hourly-clear" style="display:none">Clear hour</button>
      </div>
    </div>
    <div class="rw-hourly-chart" id="hourly-chart"></div>
    <div class="rw-hourly-labels">
      <span>00</span><span>03</span><span>06</span><span>09</span><span>12</span><span>15</span><span>18</span><span>21</span>
    </div>
  </div>

  <!-- Map -->
  <div class="rw-map-wrapper" id="rw-map-wrapper">
    <div class="rw-map-glow"></div>
    <div id="roadworks-map" class="rw-map"></div>
    <div class="rw-map-loading" id="rw-map-loading">
      <div class="rw-spinner"></div>
      <div class="rw-loading-text">Loading roadworks data…</div>
      <div class="rw-loading-bar"><div class="rw-loading-bar-fill" id="rw-loading-bar-fill"></div></div>
    </div>
    <!-- Map toolbar: fit + fullscreen -->
    <div class="rw-map-toolbar">
      <button class="rw-map-btn" id="rw-fit-markers" title="Fit to all markers" aria-label="Fit to markers">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
      </button>
      <button class="rw-map-btn" id="rw-fullscreen" title="Fullscreen" aria-label="Toggle fullscreen">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
      </button>
    </div>
    <!-- Marker count badge -->
    <div class="rw-map-count" id="rw-map-count">
      <span class="rw-map-count-num" id="rw-map-count-num">0</span>
      <span class="rw-map-count-label">works</span>
    </div>
    <!-- Floating timestamp overlay (top-right) -->
    <div class="rw-map-timestamp" id="rw-map-timestamp">
      <div class="rw-ts-row">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span id="rw-ts-date">Loading...</span>
      </div>
      <div class="rw-ts-count" id="rw-ts-count"></div>
    </div>
    <!-- Floating legend overlay (bottom-left) -->
    <div class="rw-map-legend" id="rw-map-legend">
      <div class="rw-ml-item">
        <span class="rw-ml-dot rw-ml-pulse" style="background:#dc2626"></span>
        <span class="rw-ml-label">Road Closures</span>
        <span class="rw-ml-count" id="legend-closures">0</span>
      </div>
      <div class="rw-ml-item">
        <span class="rw-ml-dot rw-ml-pulse" style="background:#f59e0b"></span>
        <span class="rw-ml-label">Lane Restrictions</span>
        <span class="rw-ml-count" id="legend-lanes">0</span>
      </div>
      <div class="rw-ml-item">
        <span class="rw-ml-dot" style="background:#6b7280;opacity:0.5"></span>
        <span class="rw-ml-label">Minor Works</span>
        <span class="rw-ml-count" id="legend-minor">0</span>
      </div>
    </div>
    <div class="rw-map-overlay" id="rw-map-meta">
      <span id="map-stats-showing">Loading...</span>
      <span id="map-stats-updated"></span>
    </div>
  </div>

  <!-- Legend -->
  <div class="rw-legend">
    <div class="rw-legend-item"><span class="rw-lg-dot rw-lg-pulse" style="background:#dc2626"></span>Road Closed</div>
    <div class="rw-legend-item"><span class="rw-lg-dot rw-lg-pulse" style="background:#f59e0b"></span>Lane Restriction</div>
    <div class="rw-legend-item"><span class="rw-lg-dot" style="background:#6b7280;opacity:0.5"></span>Minor Works</div>
    <div class="rw-legend-item"><span class="rw-lg-line" style="background:rgba(245,158,11,0.5)"></span>County div.</div>
    <div class="rw-legend-item"><span class="rw-lg-line rw-lg-dash" style="background:rgba(18,182,207,0.45)"></span>Ward</div>
    <div class="rw-legend-item rw-legend-jci" id="legend-jci" style="display:none"><span class="rw-lg-dot" style="background:#f97316"></span>JCI Junction</div>
  </div>
  <div class="rw-keyboard-hint" aria-live="polite">Use <kbd>Space</kbd> to play/pause, <kbd>&larr;</kbd><kbd>&rarr;</kbd> to navigate days</div>

  <!-- List -->
  <div class="rw-list-panel">
    <div class="rw-list-head">
      <h3 class="rw-list-title">Roadworks <span class="rw-list-count" id="rw-list-count"></span></h3>
      <select id="rw-sort" class="rw-select rw-select-sm">
        <option value="severity">Severity</option>
        <option value="road">Road A-Z</option>
        <option value="start">Start date</option>
        <option value="end">End date</option>
        <option value="duration">Duration</option>
        <option value="operator">Operator</option>
      </select>
    </div>
    <div class="rw-list" id="rw-list"></div>
    <div class="rw-pagination" id="rw-pagination" style="display:none">
      <span class="rw-page-info" id="rw-page-info"></span>
      <div class="rw-page-btns">
        <button class="rw-page-btn" id="rw-page-prev" disabled>&lsaquo; Previous</button>
        <span class="rw-page-num" id="rw-page-num"></span>
        <button class="rw-page-btn" id="rw-page-next">Next &rsaquo;</button>
      </div>
    </div>
  </div>

  <!-- Works over time chart -->
  <div class="rw-works-chart-section" id="rw-works-chart-section">
    <div class="rw-works-chart-header">
      <span class="rw-works-chart-title">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>
        Works forecast - next 90 days
      </span>
      <div class="rw-works-chart-legend">
        <span class="rw-wc-legend"><span class="rw-wc-swatch" style="background:#dc2626"></span>Closures</span>
        <span class="rw-wc-legend"><span class="rw-wc-swatch" style="background:#f59e0b"></span>Lane restrictions</span>
        <span class="rw-wc-legend"><span class="rw-wc-swatch" style="background:#6b7280"></span>Minor</span>
        <span class="rw-wc-legend"><span class="rw-wc-line" style="border-bottom:2px dashed #12b6cf"></span>Utility (non-LCC)</span>
        <span class="rw-wc-legend"><span class="rw-wc-line" style="border-bottom:2px solid #3b82f6"></span>LCC controlled</span>
      </div>
    </div>
    <div class="rw-works-canvas-wrap">
      <canvas id="works-chart-canvas" class="rw-works-canvas"></canvas>
      <div class="rw-works-chart-tooltip" id="works-chart-tooltip" style="display:none"></div>
    </div>
    <div class="rw-works-chart-labels" id="works-chart-labels"></div>
  </div>
</div>

<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
<script is:inline src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js" crossorigin=""></script>

<script is:inline define:vars={{ wardBoundaries, cedBoundaries }}>
(function() {
  'use strict';

  var TILE_URL = 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png';
  var TILE_ATTR = '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> &copy; <a href="https://carto.com/">CARTO</a>';
  // Burnley default for tompickup.co.uk, Lancashire-wide as secondary
  var BURNLEY_CENTER = [53.789, -2.248];
  var BURNLEY_ZOOM = 13;
  var LANCASHIRE_CENTER = [53.78, -2.70];
  var LANCASHIRE_ZOOM = 9;
  var DEFAULT_CENTER = BURNLEY_CENTER;
  var DEFAULT_ZOOM = BURNLEY_ZOOM;
  var DISTRICT_CENTERS = {
    burnley:        { center: [53.789, -2.248], zoom: 13 },
    hyndburn:       { center: [53.761, -2.390], zoom: 13 },
    pendle:         { center: [53.879, -2.190], zoom: 12 },
    rossendale:     { center: [53.685, -2.278], zoom: 12 },
    lancaster:      { center: [54.047, -2.801], zoom: 11 },
    ribble_valley:  { center: [53.903, -2.418], zoom: 11 },
    chorley:        { center: [53.653, -2.632], zoom: 12 },
    south_ribble:   { center: [53.727, -2.706], zoom: 13 },
    preston:        { center: [53.763, -2.703], zoom: 13 },
    west_lancashire:{ center: [53.608, -2.868], zoom: 11 },
    wyre:           { center: [53.900, -2.832], zoom: 11 },
    fylde:          { center: [53.798, -2.919], zoom: 12 },
  };
  var DISTRICT_LABELS = {
    burnley:'Burnley', hyndburn:'Hyndburn', pendle:'Pendle', rossendale:'Rossendale',
    lancaster:'Lancaster', ribble_valley:'Ribble Valley', chorley:'Chorley',
    south_ribble:'South Ribble', preston:'Preston', west_lancashire:'West Lancashire',
    wyre:'Wyre', fylde:'Fylde'
  };
  var SEV_COLORS = { high: '#ef4444', medium: '#f59e0b', low: '#22c55e' };
  var SEV_ORDER = { high: 1, medium: 2, low: 3 };

  // Restriction type classification — derived from raw roadworks fields
  var RESTRICTION_COLORS = { full_closure: '#dc2626', lane_restriction: '#f59e0b', minor: '#6b7280' };
  var RESTRICTION_LABELS = { full_closure: 'Road Closed', lane_restriction: 'Lane Restriction', minor: 'Minor Works' };
  var RESTRICTION_ICONS = { full_closure: '\u26D4', lane_restriction: '\u26A0', minor: '\u2022' };

  function classifyRestriction(rw) {
    var tc = (rw.traffic_constriction || '').toLowerCase();
    var mt = (rw.management_type || '').toLowerCase();
    var rest = (rw.restrictions || '').toLowerCase();
    if (tc === 'roadblocked' || mt === 'roadclosed') return 'full_closure';
    if (tc === 'lanesblocked' || mt === 'laneclosures' || rest === 'temporarytrafficlights') return 'lane_restriction';
    return 'minor';
  }
  function getCapacityPct(rc) {
    return rc === 'full_closure' ? 100 : rc === 'lane_restriction' ? 50 : 15;
  }
  function capacityBar(pct) {
    var filled = Math.round(pct / 10);
    var empty = 10 - filled;
    var color = pct >= 80 ? '#ef4444' : pct >= 40 ? '#f59e0b' : '#22c55e';
    return '<span style="font-family:monospace;font-size:11px;letter-spacing:1px">'
      + '<span style="color:'+color+'">'+'\u2588'.repeat(filled)+'</span>'
      + '<span style="color:rgba(255,255,255,0.1)">'+'\u2591'.repeat(empty)+'</span>'
      + '</span> <span style="color:'+color+';font-size:11px;font-weight:600">'+pct+'% loss</span>';
  }

  var CED_STYLE = { color: 'rgba(245,158,11,0.5)', weight: 2.5, fillColor: 'rgba(245,158,11,0.04)', fillOpacity: 1, dashArray: null, interactive: false };
  var WARD_STYLE = { color: 'rgba(18,182,207,0.45)', weight: 1.5, fillColor: 'rgba(18,182,207,0.05)', fillOpacity: 1, dashArray: '5 5', interactive: false };

  var allRoadworks = [], markers = [], cedLayer = null, wardLayer = null, map = null, clusterGroup = null;
  var filters = { status: 'all', severity: 'all', operator: 'all', ward: 'all', restriction: 'all', road: '', district: 'burnley' };
  var timelineMode = 'all', selectedDate = null, dateRangeStart = null, dateRangeEnd = null, playInterval = null, sortBy = 'severity', selectedHour = null, playSpeed = 600;
  var postcodeMarker = null;
  var currentPage = 0;
  var PAGE_SIZE = 30;
  var metaGenerated = null;

  function esc(s) { return s ? String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;') : ''; }

  function showToast(msg, duration) {
    var el = document.getElementById('rw-toast');
    if (!el) return;
    el.textContent = msg;
    el.style.display = '';
    el.classList.add('rw-toast-show');
    setTimeout(function() {
      el.classList.remove('rw-toast-show');
      setTimeout(function() { el.style.display = 'none'; }, 300);
    }, duration || 3000);
  }

  function updateResetBtn() {
    var btn = document.getElementById('reset-filters');
    if (!btn) return;
    var anyActive = filters.status !== 'all' || filters.severity !== 'all' || filters.operator !== 'all'
      || filters.ward !== 'all' || filters.restriction !== 'all' || filters.road !== ''
      || filters.district !== 'burnley' || timelineMode !== 'all';
    btn.style.display = anyActive ? '' : 'none';
  }

  function resetAllFilters() {
    stopPlay();
    filters = { status: 'all', severity: 'all', operator: 'all', ward: 'all', restriction: 'all', road: '', district: 'burnley' };
    timelineMode = 'all'; selectedHour = null; currentPage = 0;
    // Reset chip UI
    document.querySelectorAll('.rw-chip[data-filter]').forEach(function(b) {
      var isAll = b.getAttribute('data-value') === 'all';
      b.classList.toggle('active', isAll);
      b.setAttribute('aria-pressed', isAll ? 'true' : 'false');
    });
    // Reset selects
    ['operator-filter','ward-filter','restriction-filter'].forEach(function(id) {
      var el = document.getElementById(id); if (el) el.value = 'all';
    });
    var dSel = document.getElementById('district-filter'); if (dSel) dSel.value = 'burnley';
    // Reset search
    var si = document.getElementById('postcode-search'); if (si) si.value = '';
    var sc = document.getElementById('search-clear'); if (sc) sc.style.display = 'none';
    // Reset timeline
    updateTimelineDisplay();
    // Fly back to Burnley (default)
    if (map) map.flyTo(DEFAULT_CENTER, DEFAULT_ZOOM, { duration: 1 });
    updateResetBtn();
    updateStats(); renderMarkers(); renderList();
  }

  function fmtDate(iso) {
    if (!iso) return '\u2014';
    try { return new Date(iso).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}); } catch(e) { return '\u2014'; }
  }
  function fmtDateShort(d) { return d ? d.toLocaleDateString('en-GB',{day:'numeric',month:'short'}) : ''; }
  function fmtDateFull(d) { return d ? d.toLocaleDateString('en-GB',{weekday:'short',day:'numeric',month:'short',year:'numeric'}) : ''; }
  function toDateOnly(iso) { if (!iso) return null; try { return new Date(iso.substring(0,10)+'T00:00:00Z'); } catch(e) { return null; } }
  function daysBetween(a,b) { var ua=Date.UTC(a.getFullYear(),a.getMonth(),a.getDate()), ub=Date.UTC(b.getFullYear(),b.getMonth(),b.getDate()); return Math.round((ub-ua)/86400000); }
  function humanRestriction(r) { return r ? r.replace(/([a-z])([A-Z])/g,'$1 $2').replace(/^./,function(c){return c.toUpperCase();}) : 'None'; }
  function durationDays(r) { var s=toDateOnly(r.start_date),e=toDateOnly(r.end_date); return (s&&e)?Math.max(1,daysBetween(s,e)):0; }
  function durationLabel(d) { return d<=1?'1 day':d<7?d+' days':d<30?Math.round(d/7)+' wk'+(Math.round(d/7)!==1?'s':''):Math.round(d/30)+' mo'+(Math.round(d/30)!==1?'s':''); }

  // --- Time-of-day helpers ---
  function getHourFromISO(iso) { if (!iso) return null; var m = iso.match(/T(\d{2}):/); return m ? parseInt(m[1], 10) : null; }
  function getMinuteFromISO(iso) { if (!iso) return 0; var m = iso.match(/T\d{2}:(\d{2})/); return m ? parseInt(m[1], 10) : 0; }
  function isAllDayWork(rw) { var sh = getHourFromISO(rw.start_date); return sh === 0 || sh === null; }
  function getWorkingHours(rw) {
    if (isAllDayWork(rw)) return null;
    var sh = getHourFromISO(rw.start_date), sm = getMinuteFromISO(rw.start_date);
    var eh = getHourFromISO(rw.end_date), em = getMinuteFromISO(rw.end_date);
    return { start: String(sh).padStart(2,'0')+':'+String(sm).padStart(2,'0'), end: String(eh).padStart(2,'0')+':'+String(em).padStart(2,'0'), startH: sh, endH: eh };
  }
  function isActiveAtHour(rw, date, hour) {
    var s = toDateOnly(rw.start_date), e = toDateOnly(rw.end_date);
    if (!s || !e) return false;
    var t = date.getTime();
    if (s.getTime() > t || e.getTime() < t) return false;
    if (isAllDayWork(rw)) return true;
    var sh = getHourFromISO(rw.start_date) || 0;
    var eh = getHourFromISO(rw.end_date);
    if (eh === null || eh === 0) eh = 23;
    return hour >= sh && hour <= eh;
  }

  // Animate counter — settles at final value, skips animation during play
  function animateCount(el, target) {
    if (!el) return;
    // During play, just set immediately to avoid perpetual animation
    if (playInterval) { el.textContent = target; return; }
    var start = parseInt(el.textContent, 10) || 0;
    if (start === target) { el.textContent = target; return; }
    var duration = 400, startTime = null;
    function step(ts) {
      if (!startTime) startTime = ts;
      var p = Math.min((ts - startTime) / duration, 1);
      var ease = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(start + (target - start) * ease);
      if (p < 1) requestAnimationFrame(step);
      else el.textContent = target; // Ensure exact final value
    }
    requestAnimationFrame(step);
  }

  // --- Init ---
  function initMap() {
    var container = document.getElementById('roadworks-map');
    if (!container || typeof L === 'undefined') return;

    map = L.map(container, { zoomControl: true, scrollWheelZoom: true, attributionControl: true });
    L.tileLayer(TILE_URL, { attribution: TILE_ATTR, maxZoom: 18, subdomains: 'abcd' }).addTo(map);
    map.setView(DEFAULT_CENTER, DEFAULT_ZOOM);
    setTimeout(function() { map.invalidateSize(); map.setView(DEFAULT_CENTER, DEFAULT_ZOOM); }, 250);

    drawCEDs();
    fetchRoadworks();
  }

  function drawCEDs() {
    if (!cedBoundaries || !cedBoundaries.length) return;
    cedLayer = L.layerGroup().addTo(map);
    cedBoundaries.forEach(function(ced) {
      if (!ced.coordinates || !ced.coordinates.length) return;
      var ll = ced.coordinates.map(function(c){return[c[1],c[0]];});
      var p = L.polygon(ll, CED_STYLE);
      p.bindTooltip(esc(ced.name), { permanent:false, direction:'center', className:'ced-tooltip' });
      p.on('mouseover', function() {
        p.setStyle({ color: 'rgba(245,158,11,0.6)', weight: 2.5, fillColor: 'rgba(245,158,11,0.06)', fillOpacity: 1 });
      });
      p.on('mouseout', function() { p.setStyle(CED_STYLE); });
      cedLayer.addLayer(p);
    });
  }

  function drawWards() {
    if (!wardBoundaries || !wardBoundaries.length) return;
    wardLayer = L.layerGroup();
    wardBoundaries.forEach(function(w) {
      if (!w.coordinates || !w.coordinates.length) return;
      var ll = w.coordinates.map(function(c){return[c[1],c[0]];});
      var p = L.polygon(ll, WARD_STYLE);
      p.bindTooltip(esc(w.name), { permanent:false, direction:'center', className:'ward-tooltip' });
      p.on('mouseover', function() {
        p.setStyle({ color: 'rgba(18,182,207,0.55)', weight: 2.5, fillColor: 'rgba(18,182,207,0.08)', fillOpacity: 1 });
      });
      p.on('mouseout', function() { p.setStyle(WARD_STYLE); });
      wardLayer.addLayer(p);
    });
  }

  function removeLoadingStates() {
    // Remove shimmer from stat cards
    document.querySelectorAll('.rw-shimmer').forEach(function(el) { el.classList.remove('rw-shimmer'); });
    // Fade out map loading overlay
    var loadEl = document.getElementById('rw-map-loading');
    if (loadEl) { loadEl.classList.add('rw-loaded'); setTimeout(function(){ loadEl.style.display = 'none'; }, 500); }
  }

  function fetchRoadworks() {
    // Animate loading bar
    var barFill = document.getElementById('rw-loading-bar-fill');
    if (barFill) { barFill.style.width = '40%'; }
    fetch('/data/roadworks.json').then(function(r){ if(barFill) barFill.style.width = '70%'; return r.json();}).then(function(data) {
      if(barFill) barFill.style.width = '100%';
      allRoadworks = data.roadworks || [];
      populateFilters(data.stats);
      updateMeta(data);
      updateStats();
      initTimeline();
      renderMarkers();
      buildWorksChart();
      renderList();
      removeLoadingStates();
    }).catch(function(err) {
      console.error('Failed to load roadworks:', err);
      document.getElementById('map-stats-showing').textContent = 'Failed to load data';
      removeLoadingStates();
    });
  }

  function populateFilters(stats) {
    // District filter
    var dSel = document.getElementById('district-filter');
    if (dSel && stats && stats.by_district) {
      Object.keys(stats.by_district).sort(function(a,b){return(DISTRICT_LABELS[a]||a).localeCompare(DISTRICT_LABELS[b]||b);}).forEach(function(d) {
        var o = document.createElement('option');
        o.value = d;
        o.textContent = (DISTRICT_LABELS[d]||d) + ' (' + stats.by_district[d].total + ')';
        dSel.appendChild(o);
      });
      dSel.addEventListener('change', function() {
        filters.district = this.value; currentPage = 0;
        // Fly to district or back to Lancashire
        if (this.value !== 'all' && DISTRICT_CENTERS[this.value]) {
          var dc = DISTRICT_CENTERS[this.value];
          map.flyTo(dc.center, dc.zoom, { duration: 1 });
        } else {
          map.flyTo(LANCASHIRE_CENTER, LANCASHIRE_ZOOM, { duration: 1 });
        }
        // Dispatch event so page can react to region change
        window.dispatchEvent(new CustomEvent('regionchange', { detail: { district: this.value } }));
        stopPlay();
        updateStats(); renderMarkers(); buildWorksChart(); renderList();
      });
      // Default to Burnley
      dSel.value = 'burnley';
    }
    // Operator filter
    var opSel = document.getElementById('operator-filter');
    if (opSel && stats && stats.by_operator) {
      Object.keys(stats.by_operator).forEach(function(op) {
        var o = document.createElement('option'); o.value = op; o.textContent = op + ' (' + stats.by_operator[op] + ')'; opSel.appendChild(o);
      });
    }
    var wSel = document.getElementById('ward-filter');
    if (wSel && stats && stats.by_ward) {
      Object.keys(stats.by_ward).sort().forEach(function(w) {
        var o = document.createElement('option'); o.value = w; o.textContent = w + ' (' + stats.by_ward[w] + ')'; wSel.appendChild(o);
      });
    }
    var rSel = document.getElementById('restriction-filter');
    if (rSel && stats && stats.by_restriction) {
      Object.keys(stats.by_restriction).forEach(function(r) {
        var o = document.createElement('option'); o.value = r; o.textContent = humanRestriction(r) + ' (' + stats.by_restriction[r] + ')'; rSel.appendChild(o);
      });
    }
  }

  function updateMeta(data) {
    var el = document.getElementById('map-stats-updated');
    if (el && data.meta) el.textContent = 'Updated ' + fmtDate(data.meta.generated);
    // Populate floating timestamp overlay
    var tsDate = document.getElementById('rw-ts-date');
    var tsCount = document.getElementById('rw-ts-count');
    if (tsDate && data.meta && data.meta.generated) {
      try {
        var d = new Date(data.meta.generated);
        tsDate.textContent = d.toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})
          + ' ' + d.toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});
      } catch(e) { tsDate.textContent = fmtDate(data.meta.generated); }
    }
    if (tsCount) tsCount.textContent = (data.roadworks || []).length + ' works across Lancashire';
    // Check staleness
    if (data.meta && data.meta.generated) {
      metaGenerated = data.meta.generated;
      var genTime = new Date(data.meta.generated).getTime();
      var hoursAgo = Math.floor((Date.now() - genTime) / 3600000);
      if (hoursAgo >= 6) {
        var warn = document.getElementById('rw-stale-warning');
        var txt = document.getElementById('rw-stale-text');
        if (warn) warn.style.display = '';
        if (txt) txt.textContent = 'Data may be stale \u2014 last updated ' + hoursAgo + ' hour' + (hoursAgo !== 1 ? 's' : '') + ' ago';
      }
    }
  }

  function updateStats() {
    var filtered = getFiltered();
    var active = filtered.filter(function(r){return r.status==='Works started';}).length;
    var planned = filtered.filter(function(r){return r.status==='Planned works';}).length;
    var high = filtered.filter(function(r){return r.severity==='high';}).length;
    var closures = filtered.filter(function(r){return classifyRestriction(r)==='full_closure';}).length;
    var districts = {};
    filtered.forEach(function(r){ if(r.district) districts[r.district]=1; });
    animateCount(document.getElementById('stat-active'), active);
    animateCount(document.getElementById('stat-planned'), planned);
    animateCount(document.getElementById('stat-high'), high);
    animateCount(document.getElementById('stat-closures'), closures);
    animateCount(document.getElementById('stat-districts'), Object.keys(districts).length);
  }

  // --- Postcode search ---
  function searchPostcode(query) {
    query = query.trim();
    if (!query) return;

    // Check if it looks like a postcode
    var pcRegex = /^[A-Z]{1,2}\d[A-Z\d]?\s*\d[A-Z]{2}$/i;
    if (pcRegex.test(query)) {
      fetch('https://api.postcodes.io/postcodes/' + encodeURIComponent(query))
        .then(function(r){return r.json();})
        .then(function(data) {
          if (data.result) {
            var lat = data.result.latitude, lng = data.result.longitude;
            map.flyTo([lat, lng], 16, { duration: 0.8 });
            if (postcodeMarker) map.removeLayer(postcodeMarker);
            postcodeMarker = L.marker([lat, lng], {
              icon: L.divIcon({ className: 'postcode-pin', html: '<div class="pc-pin"></div>', iconSize: [20, 20], iconAnchor: [10, 10] })
            }).addTo(map).bindPopup('<div style="color:#fff;font-weight:600">' + esc(query.toUpperCase()) + '</div><div style="color:#aaa;font-size:12px">' + esc(data.result.admin_ward || '') + '</div>', { className: 'rw-popup' }).openPopup();
          } else {
            showToast('Postcode not found: ' + query.toUpperCase());
          }
        }).catch(function(){ showToast('Postcode lookup failed \u2014 please try again'); });
    } else {
      // Search road names
      filters.road = query;
      renderMarkers();
      renderList();
      updateStats();
      // Zoom to first result
      var first = getFiltered()[0];
      if (first && first.lat && first.lng) map.flyTo([first.lat, first.lng], 16, { duration: 0.8 });
    }
  }

  // --- Timeline ---
  function initTimeline() {
    if (!allRoadworks.length) return;
    var starts = allRoadworks.map(function(r){return toDateOnly(r.start_date);}).filter(Boolean);
    var ends = allRoadworks.map(function(r){return toDateOnly(r.end_date);}).filter(Boolean);
    if (!starts.length || !ends.length) return;

    var today = new Date(); today.setHours(0,0,0,0);
    var weekAgo = new Date(today.getTime() - 7*86400000);
    var sortedEnds = ends.slice().sort(function(a,b){return a-b;});
    var p95 = sortedEnds[Math.floor(sortedEnds.length * 0.95)] || sortedEnds[sortedEnds.length-1];
    var absStart = new Date(Math.min.apply(null, starts));

    dateRangeStart = absStart < weekAgo ? weekAgo : absStart;
    dateRangeEnd = p95;
    selectedDate = today < dateRangeStart ? dateRangeStart : (today > dateRangeEnd ? dateRangeEnd : today);

    var slider = document.getElementById('timeline-slider');
    var total = daysBetween(dateRangeStart, dateRangeEnd);
    if (slider) { slider.max = total; slider.value = daysBetween(dateRangeStart, selectedDate); }
    document.getElementById('timeline-start-label').textContent = fmtDateShort(dateRangeStart);
    document.getElementById('timeline-end-label').textContent = fmtDateShort(dateRangeEnd);
    updateTimelineDisplay();
    buildHeatmap(total);
  }

  function buildHeatmap(totalDays) {
    var container = document.getElementById('timeline-heatmap');
    if (!container) return;
    container.innerHTML = '';
    var maxCount = 0, densities = [];
    for (var d=0; d<=totalDays; d++) {
      var dt = new Date(dateRangeStart.getTime()+d*86400000);
      var c = countActiveOnDate(dt);
      densities.push(c);
      if (c > maxCount) maxCount = c;
    }
    var canvas = document.createElement('canvas');
    canvas.width = container.clientWidth || 600; canvas.height = 36;
    canvas.style.cssText = 'width:100%;height:36px;border-radius:8px;';
    container.appendChild(canvas);
    var ctx = canvas.getContext('2d');
    var bw = canvas.width / (totalDays + 1);
    var gap = Math.max(0.5, bw > 4 ? 1 : 0.5);
    for (var i=0; i<=totalDays; i++) {
      var pct = maxCount > 0 ? densities[i]/maxCount : 0;
      // Gradient: teal → red as density increases
      var r = Math.round(18 + pct*(239-18)), g = Math.round(182 + pct*(68-182)), b = Math.round(207 + pct*(68-207));
      ctx.fillStyle = 'rgba('+r+','+g+','+b+','+(0.15+pct*0.75)+')';
      ctx.fillRect(i*bw, 0, Math.max(bw-gap,1), 36);
    }
    // Today marker
    var td = new Date(); td.setHours(0,0,0,0);
    if (td >= dateRangeStart && td <= dateRangeEnd) {
      var pos = daysBetween(dateRangeStart, td) * bw;
      ctx.fillStyle = 'rgba(255,255,255,0.9)'; ctx.fillRect(pos-1, 0, 2, 36);
      // Small triangle indicator at top
      ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.moveTo(pos-4, 0); ctx.lineTo(pos+4, 0); ctx.lineTo(pos, 5); ctx.closePath(); ctx.fill();
    }
  }

  function buildHourlyStrip() {
    var section = document.getElementById('rw-hourly-section');
    if (!section) return;
    // Always show — use today's date if not in date mode
    var useDate = selectedDate;
    if (timelineMode !== 'date' || !useDate) {
      useDate = new Date(); useDate.setHours(0,0,0,0);
    }

    var chart = document.getElementById('hourly-chart');
    if (!chart) return;
    chart.innerHTML = '';

    var maxCount = 0, hourlyCounts = [];
    for (var h = 0; h < 24; h++) {
      var count = allRoadworks.filter(function(rw) { return isActiveAtHour(rw, useDate, h); }).length;
      hourlyCounts.push(count);
      if (count > maxCount) maxCount = count;
    }

    // Subtract baseline so bar heights show relative disruption
    var minCount = Math.min.apply(null, hourlyCounts);
    var range = maxCount - minCount;

    for (var i = 0; i < 24; i++) {
      var bar = document.createElement('div');
      var pct = range > 0 ? (hourlyCounts[i] - minCount) / range : 0;
      var barH = Math.max(4, Math.round(6 + pct * 38));
      var isRush = (i >= 7 && i < 9) || (i >= 15 && i < 18);
      var isSchoolRun = i === 8 || i === 15;

      bar.className = 'rw-hour-bar'
        + (isSchoolRun ? ' rw-hour-school' : isRush ? ' rw-hour-rush' : '')
        + (selectedHour === i ? ' rw-hour-selected' : '');
      bar.style.height = barH + 'px';
      bar.setAttribute('data-hour', i);
      bar.title = String(i).padStart(2,'0') + ':00 \u2014 ' + hourlyCounts[i] + ' works';
      chart.appendChild(bar);
    }

    // Now-marker if viewing today
    var now = new Date(), td = new Date(); td.setHours(0,0,0,0);
    if (useDate.getTime() === td.getTime()) {
      var nowPct = (now.getHours() + now.getMinutes() / 60) / 24 * 100;
      var marker = document.createElement('div');
      marker.className = 'rw-hour-now';
      marker.style.left = nowPct + '%';
      marker.title = 'Now (' + String(now.getHours()).padStart(2,'0') + ':' + String(now.getMinutes()).padStart(2,'0') + ')';
      chart.appendChild(marker);
    }

    // Info label
    var info = document.getElementById('hourly-info');
    var clearBtn = document.getElementById('hourly-clear');
    if (selectedHour !== null) {
      var rushTag = (selectedHour >= 7 && selectedHour < 9) ? ' \u00b7 AM rush' : (selectedHour >= 15 && selectedHour < 18) ? ' \u00b7 PM rush' : '';
      if (info) info.textContent = String(selectedHour).padStart(2,'0') + ':00 \u2014 ' + hourlyCounts[selectedHour] + ' works' + rushTag;
      if (clearBtn) clearBtn.style.display = '';
    } else {
      var peakH = hourlyCounts.indexOf(Math.max.apply(null, hourlyCounts));
      var timedCount = allRoadworks.filter(function(rw) {
        var s = toDateOnly(rw.start_date), e = toDateOnly(rw.end_date);
        if (!s || !e) return false; var t = useDate.getTime();
        if (s.getTime() > t || e.getTime() < t) return false;
        return !isAllDayWork(rw);
      }).length;
      if (info && maxCount > 0) info.textContent = 'Peak ' + String(peakH).padStart(2,'0') + ':00 (' + hourlyCounts[peakH] + ') \u00b7 ' + timedCount + ' with timed hours';
      else if (info) info.textContent = '';
      if (clearBtn) clearBtn.style.display = 'none';
    }

    // Click handlers for bars
    chart.querySelectorAll('.rw-hour-bar').forEach(function(b) {
      b.addEventListener('click', function() {
        var h = parseInt(b.getAttribute('data-hour'), 10);
        selectedHour = selectedHour === h ? null : h;
        buildHourlyStrip(); renderMarkers(); renderList(); updateStats();
      });
    });
  }

  // --- Works over time chart (90-day stacked area) ---
  function buildWorksChart() {
    var canvas = document.getElementById('works-chart-canvas');
    var labelsEl = document.getElementById('works-chart-labels');
    var tooltip = document.getElementById('works-chart-tooltip');
    if (!canvas || !labelsEl || !allRoadworks.length) return;

    var today = new Date(); today.setHours(0,0,0,0);
    var DAYS = 90;
    var PAD_LEFT = 36, PAD_RIGHT = 10, PAD_TOP = 8, PAD_BOTTOM = 4;

    // Build daily data
    var days = [];
    for (var d = 0; d < DAYS; d++) {
      var dt = new Date(today.getTime() + d * 86400000);
      var closures = 0, lanes = 0, minor = 0, utility = 0, lcc = 0;
      for (var j = 0; j < allRoadworks.length; j++) {
        var rw = allRoadworks[j];
        if (filters.district !== 'all' && rw.district !== filters.district) continue;
        var s = toDateOnly(rw.start_date), e = toDateOnly(rw.end_date);
        if (!s || !e) continue;
        var tt = dt.getTime();
        if (s.getTime() > tt || e.getTime() < tt) continue;
        var rc = classifyRestriction(rw);
        if (rc === 'full_closure') closures++;
        else if (rc === 'lane_restriction') lanes++;
        else minor++;
        var op = (rw.operator || '').toLowerCase();
        if (op.indexOf('lancashire county council') !== -1 || op.indexOf('lcc') !== -1) lcc++;
        else utility++;
      }
      days.push({ date: dt, closures: closures, lanes: lanes, minor: minor, utility: utility, lcc: lcc, total: closures + lanes + minor });
    }

    // Find max for Y scale
    var maxY = 0;
    for (var i = 0; i < days.length; i++) {
      if (days[i].total > maxY) maxY = days[i].total;
    }
    if (maxY === 0) maxY = 1;

    // Canvas setup
    var dpr = window.devicePixelRatio || 1;
    var rect = canvas.parentElement.getBoundingClientRect();
    var cw = rect.width || 600;
    var ch = canvas.classList.contains('rw-works-canvas') ? 160 : 160;
    if (window.innerWidth <= 768) ch = 120;
    canvas.width = cw * dpr;
    canvas.height = ch * dpr;
    canvas.style.width = cw + 'px';
    canvas.style.height = ch + 'px';
    var ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);

    var plotW = cw - PAD_LEFT - PAD_RIGHT;
    var plotH = ch - PAD_TOP - PAD_BOTTOM;
    var stepX = plotW / (DAYS - 1);

    function yPos(val) { return PAD_TOP + plotH - (val / maxY) * plotH; }
    function xPos(idx) { return PAD_LEFT + idx * stepX; }

    // Clear
    ctx.clearRect(0, 0, cw, ch);

    // Y-axis grid lines + labels
    var yTicks = 4;
    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    ctx.font = '10px -apple-system, BlinkMacSystemFont, sans-serif';
    for (var t = 0; t <= yTicks; t++) {
      var val = Math.round(maxY * t / yTicks);
      var y = yPos(val);
      ctx.strokeStyle = 'rgba(255,255,255,0.04)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(PAD_LEFT, y);
      ctx.lineTo(cw - PAD_RIGHT, y);
      ctx.stroke();
      ctx.fillStyle = 'rgba(235,235,245,0.25)';
      ctx.fillText(val, PAD_LEFT - 6, y);
    }

    // Draw stacked areas (bottom to top: minor, lanes, closures)
    // Build cumulative arrays
    var stackMinor = [], stackLanes = [], stackClosures = [];
    for (var i = 0; i < DAYS; i++) {
      stackMinor.push(days[i].minor);
      stackLanes.push(days[i].minor + days[i].lanes);
      stackClosures.push(days[i].minor + days[i].lanes + days[i].closures);
    }

    // Minor (grey) — bottom
    ctx.beginPath();
    ctx.moveTo(xPos(0), yPos(stackMinor[0]));
    for (var i = 1; i < DAYS; i++) ctx.lineTo(xPos(i), yPos(stackMinor[i]));
    for (var i = DAYS - 1; i >= 0; i--) ctx.lineTo(xPos(i), yPos(0));
    ctx.closePath();
    ctx.fillStyle = 'rgba(107,114,128,0.35)';
    ctx.fill();

    // Lanes (amber) — middle
    ctx.beginPath();
    ctx.moveTo(xPos(0), yPos(stackLanes[0]));
    for (var i = 1; i < DAYS; i++) ctx.lineTo(xPos(i), yPos(stackLanes[i]));
    for (var i = DAYS - 1; i >= 0; i--) ctx.lineTo(xPos(i), yPos(stackMinor[i]));
    ctx.closePath();
    ctx.fillStyle = 'rgba(245,158,11,0.4)';
    ctx.fill();

    // Closures (red) — top
    ctx.beginPath();
    ctx.moveTo(xPos(0), yPos(stackClosures[0]));
    for (var i = 1; i < DAYS; i++) ctx.lineTo(xPos(i), yPos(stackClosures[i]));
    for (var i = DAYS - 1; i >= 0; i--) ctx.lineTo(xPos(i), yPos(stackLanes[i]));
    ctx.closePath();
    ctx.fillStyle = 'rgba(220,38,38,0.4)';
    ctx.fill();

    // Overlay line: Utility (non-LCC) — dashed cyan
    ctx.beginPath();
    ctx.setLineDash([5, 4]);
    ctx.strokeStyle = 'rgba(18,182,207,0.7)';
    ctx.lineWidth = 1.5;
    ctx.moveTo(xPos(0), yPos(days[0].utility));
    for (var i = 1; i < DAYS; i++) ctx.lineTo(xPos(i), yPos(days[i].utility));
    ctx.stroke();
    ctx.setLineDash([]);

    // Overlay line: LCC controlled — solid blue
    ctx.beginPath();
    ctx.strokeStyle = 'rgba(59,130,246,0.7)';
    ctx.lineWidth = 1.5;
    ctx.moveTo(xPos(0), yPos(days[0].lcc));
    for (var i = 1; i < DAYS; i++) ctx.lineTo(xPos(i), yPos(days[i].lcc));
    ctx.stroke();

    // Today marker
    ctx.strokeStyle = 'rgba(255,255,255,0.6)';
    ctx.lineWidth = 1;
    ctx.setLineDash([3, 3]);
    ctx.beginPath();
    ctx.moveTo(xPos(0), PAD_TOP);
    ctx.lineTo(xPos(0), PAD_TOP + plotH);
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.font = '9px -apple-system, BlinkMacSystemFont, sans-serif';
    ctx.textAlign = 'left';
    ctx.fillText('Today', xPos(0) + 4, PAD_TOP + 10);

    // Date labels (every 7 days)
    labelsEl.innerHTML = '';
    for (var i = 0; i < DAYS; i += 7) {
      var lbl = document.createElement('span');
      lbl.className = 'rw-wc-date-label';
      lbl.textContent = fmtDateShort(days[i].date);
      lbl.style.left = ((PAD_LEFT + i * stepX) / cw * 100) + '%';
      labelsEl.appendChild(lbl);
    }

    // Save base image for hover overlay (avoids full redraw)
    var baseImage = ctx.getImageData(0, 0, canvas.width, canvas.height);

    // Hover tooltip
    var activeTooltipIdx = -1;
    canvas.onmousemove = function(ev) {
      var br = canvas.getBoundingClientRect();
      var mx = ev.clientX - br.left;
      var idx = Math.round((mx - PAD_LEFT) / stepX);
      if (idx < 0 || idx >= DAYS) {
        if (activeTooltipIdx !== -1) {
          tooltip.style.display = 'none';
          activeTooltipIdx = -1;
          ctx.putImageData(baseImage, 0, 0);
        }
        return;
      }
      if (idx === activeTooltipIdx) return;
      activeTooltipIdx = idx;
      var dd = days[idx];
      tooltip.innerHTML =
        '<div class="rw-wct-date">' + fmtDateShort(dd.date) + '</div>' +
        '<div class="rw-wct-row"><span class="rw-wct-dot" style="background:#dc2626"></span>Closures: <b>' + dd.closures + '</b></div>' +
        '<div class="rw-wct-row"><span class="rw-wct-dot" style="background:#f59e0b"></span>Lane restrictions: <b>' + dd.lanes + '</b></div>' +
        '<div class="rw-wct-row"><span class="rw-wct-dot" style="background:#6b7280"></span>Minor: <b>' + dd.minor + '</b></div>' +
        '<div class="rw-wct-divider"></div>' +
        '<div class="rw-wct-row"><span class="rw-wct-line" style="border-color:#12b6cf"></span>Utility: <b>' + dd.utility + '</b></div>' +
        '<div class="rw-wct-row"><span class="rw-wct-line rw-wct-solid" style="border-color:#3b82f6"></span>LCC: <b>' + dd.lcc + '</b></div>' +
        '<div class="rw-wct-total">Total: ' + dd.total + '</div>';
      tooltip.style.display = '';
      // Position tooltip
      var tx = mx + 12;
      var ty = ev.clientY - br.top - 10;
      if (tx + 160 > cw) tx = mx - 170;
      if (ty < 0) ty = 4;
      tooltip.style.left = tx + 'px';
      tooltip.style.top = ty + 'px';

      // Draw hover line over base image
      ctx.putImageData(baseImage, 0, 0);
      ctx.save();
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.strokeStyle = 'rgba(255,255,255,0.2)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      var hx = xPos(idx);
      ctx.moveTo(hx, PAD_TOP);
      ctx.lineTo(hx, PAD_TOP + plotH);
      ctx.stroke();
      ctx.restore();
    };
    canvas.onmouseleave = function() {
      tooltip.style.display = 'none';
      activeTooltipIdx = -1;
      ctx.putImageData(baseImage, 0, 0);
    };
  }

  function countActiveOnDate(date) {
    var t = date.getTime();
    return allRoadworks.filter(function(r) {
      var s=toDateOnly(r.start_date), e=toDateOnly(r.end_date);
      return s && e && s.getTime()<=t && e.getTime()>=t;
    }).length;
  }

  function updateTimelineDisplay() {
    var label = document.getElementById('timeline-date-label');
    if (label) label.textContent = timelineMode === 'all' ? 'All dates' : fmtDateFull(selectedDate);
    var modeBtn = document.getElementById('timeline-mode');
    if (modeBtn) { modeBtn.textContent = timelineMode === 'all' ? 'All dates' : 'Date filter'; modeBtn.classList.toggle('active', timelineMode === 'date'); }
    var statsEl = document.getElementById('timeline-stats');
    if (statsEl && timelineMode === 'date' && selectedDate) {
      var cnt = countActiveOnDate(selectedDate);
      var today = new Date(); today.setHours(0,0,0,0);
      var isToday = selectedDate && selectedDate.getTime() === today.getTime();
      statsEl.textContent = cnt + ' works' + (isToday ? ' (today)' : '');
      statsEl.style.opacity = '1';
    } else if (statsEl) {
      var today = new Date(); today.setHours(0,0,0,0);
      var cnt = countActiveOnDate(today);
      statsEl.textContent = cnt + ' works today';
      statsEl.style.opacity = '0.6';
    }
    buildHourlyStrip();
  }

  function setTimelineDate(idx) {
    selectedHour = null;
    selectedDate = new Date(dateRangeStart.getTime()+idx*86400000);
    var s = document.getElementById('timeline-slider'); if (s) s.value = idx;
    updateTimelineDisplay(); renderMarkers(); renderList(); updateStats();
  }

  // --- Filters ---
  function getFiltered() {
    var rs = filters.road.toLowerCase();
    return allRoadworks.filter(function(r) {
      if (filters.district!=='all' && r.district!==filters.district) return false;
      if (filters.status!=='all' && r.status!==filters.status) return false;
      if (filters.severity!=='all' && r.severity!==filters.severity) return false;
      if (filters.operator!=='all' && r.operator!==filters.operator) return false;
      if (filters.ward!=='all' && r.ward!==filters.ward) return false;
      if (filters.restriction!=='all' && (r.restrictions||'none')!==filters.restriction) return false;
      if (rs && r.road.toLowerCase().indexOf(rs)===-1) return false;
      if (timelineMode==='date' && selectedDate) {
        var s=toDateOnly(r.start_date), e=toDateOnly(r.end_date);
        if (!s||!e) return false;
        var t=selectedDate.getTime();
        if (s.getTime()>t || e.getTime()<t) return false;
        if (selectedHour !== null && !isActiveAtHour(r, selectedDate, selectedHour)) return false;
      }
      return true;
    });
  }

  function sortRecords(recs) {
    var s = recs.slice();
    switch (sortBy) {
      case 'road': s.sort(function(a,b){return(a.road||'').localeCompare(b.road||'');}); break;
      case 'start': s.sort(function(a,b){return(a.start_date||'').localeCompare(b.start_date||'');}); break;
      case 'end': s.sort(function(a,b){return(a.end_date||'').localeCompare(b.end_date||'');}); break;
      case 'duration': s.sort(function(a,b){return durationDays(b)-durationDays(a);}); break;
      case 'operator': s.sort(function(a,b){return(a.operator||'').localeCompare(b.operator||'');}); break;
      default: s.sort(function(a,b){return(SEV_ORDER[a.severity]||9)-(SEV_ORDER[b.severity]||9);});
    }
    return s;
  }

  // --- Render markers ---
  function renderMarkers() {
    // Remove previous markers/cluster
    if (clusterGroup) { map.removeLayer(clusterGroup); clusterGroup = null; }
    markers.forEach(function(m){map.removeLayer(m);}); markers = [];
    var filtered = getFiltered();
    filtered.forEach(function(rw) {
      if (!rw.lat || !rw.lng) return;
      var isActive = rw.status === 'Works started';
      var rc = classifyRestriction(rw);
      var rcColor = RESTRICTION_COLORS[rc];
      var rcLabel = RESTRICTION_LABELS[rc];
      var m;

      if (rc === 'full_closure') {
        // Full closures — large pulsing marker with X icon
        m = L.marker([rw.lat, rw.lng], {
          icon: L.divIcon({
            className: 'rw-marker-closure',
            html: '<div class="rw-marker-pulse" style="--mc:'+rcColor+'"></div>'
                + '<div class="rw-marker-core rw-marker-closure-core" style="background:'+rcColor+'">'
                + '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>'
                + '</div>',
            iconSize: [26, 26], iconAnchor: [13, 13],
          })
        });
      } else if (rc === 'lane_restriction') {
        // Lane restrictions — medium marker with warning triangle
        var laneColor = isActive ? '#f59e0b' : '#d97706';
        m = L.marker([rw.lat, rw.lng], {
          icon: L.divIcon({
            className: 'rw-marker-lane' + (isActive ? ' rw-marker-active' : ''),
            html: (isActive ? '<div class="rw-marker-pulse" style="--mc:'+laneColor+'"></div>' : '')
                + '<div class="rw-marker-core rw-marker-lane-core" style="background:'+laneColor+'">'
                + '<svg width="8" height="8" viewBox="0 0 24 24" fill="#fff"><path d="M12 2L1 21h22L12 2zm0 4l7.5 13h-15L12 6z"/></svg>'
                + '</div>',
            iconSize: [20, 20], iconAnchor: [10, 10],
          })
        });
      } else {
        // Minor works — small dot
        m = L.circleMarker([rw.lat, rw.lng], {
          radius: isActive ? 6 : 4.5,
          fillColor: isActive ? '#6b7280' : '#4b5563',
          fillOpacity: isActive ? 0.7 : 0.3,
          color: isActive ? '#9ca3af' : '#6b7280',
          weight: isActive ? 1.5 : 1,
          opacity: isActive ? 0.9 : 0.5,
        });
      }

      // Popup — now includes restriction type badge
      var sevColor = SEV_COLORS[rw.severity] || '#8e8e93';
      var stb = '<span style="display:inline-block;padding:2px 7px;border-radius:100px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.03em;background:'+(isActive?'#ef444418':'#f59e0b18')+';color:'+(isActive?'#ef4444':'#f59e0b')+'">'+(isActive?'Active':'Planned')+'</span>';
      var rtb = '<span style="display:inline-block;padding:2px 7px;border-radius:100px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.03em;background:'+rcColor+'18;color:'+rcColor+'">'+esc(rcLabel)+'</span>';
      var sb = '<span style="display:inline-block;padding:2px 7px;border-radius:100px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.03em;background:'+sevColor+'18;color:'+sevColor+'">'+esc(rw.severity)+'</span>';

      var days = durationDays(rw);
      var capPct = getCapacityPct(rc);
      var h = '<div style="font-family:Inter,-apple-system,sans-serif;min-width:250px;max-width:330px">'
        + '<div style="font-weight:700;font-size:15px;margin-bottom:3px;color:#fff;letter-spacing:-.01em">'+esc(rw.road)+'</div>'
        + '<div style="font-size:12px;color:rgba(235,235,245,0.4);margin-bottom:8px">'+esc(rw.ward)+(rw.district?' <span style="color:rgba(245,158,11,0.6)">\u2022 '+esc(DISTRICT_LABELS[rw.district]||rw.district)+'</span>':'')+'</div>'
        + '<div style="display:flex;gap:5px;flex-wrap:wrap;margin-bottom:8px">'+stb+rtb+sb+'</div>'
        // Capacity bar
        + '<div style="margin-bottom:10px;padding:6px 8px;background:rgba(255,255,255,0.04);border-radius:6px;border:1px solid rgba(255,255,255,0.06)">'
        + '<div style="font-size:10px;color:rgba(235,235,245,0.35);margin-bottom:3px;text-transform:uppercase;letter-spacing:.05em">Capacity Impact</div>'
        + capacityBar(capPct)
        + '</div>'
        + '<div style="font-size:12.5px;color:rgba(235,235,245,0.7);line-height:1.7">'
        + '<div><span style="color:rgba(235,235,245,0.35)">Dates</span> '+fmtDate(rw.start_date)+' \u2014 '+fmtDate(rw.end_date)+' <span style="color:rgba(235,235,245,0.3)">(' + durationLabel(days) + ')</span></div>';
      var wh = getWorkingHours(rw);
      if (wh) h += '<div><span style="color:rgba(235,235,245,0.35)">Hours</span> '+wh.start+' \u2014 '+wh.end+'</div>';
      else h += '<div><span style="color:rgba(235,235,245,0.35)">Hours</span> All day</div>';
      h += '<div><span style="color:rgba(235,235,245,0.35)">Operator</span> '+esc(rw.operator)+'</div>';
      if (rw.restrictions) h += '<div><span style="color:rgba(235,235,245,0.35)">Restrictions</span> '+esc(humanRestriction(rw.restrictions))+'</div>';
      if (rw.impact) h += '<div><span style="color:rgba(235,235,245,0.35)">Impact</span> '+esc(rw.impact.replace(/([a-z])([A-Z])/g,'$1 $2'))+'</div>';
      if (rw.description) { var desc = rw.description.split('|')[0]; h += '<div style="margin-top:6px;color:rgba(235,235,245,0.3);font-size:11.5px;line-height:1.4">'+esc(desc.substring(0,180))+'</div>'; }
      if (rw.one_network_url) h += '<div style="margin-top:8px"><a href="'+esc(rw.one_network_url)+'" target="_blank" rel="noopener" style="color:#12b6cf;font-size:12px;text-decoration:none;font-weight:500">View on one.network \u2192</a></div>';
      h += '</div></div>';

      m.bindPopup(h, { className: 'rw-popup', maxWidth: 340 });
      m.rwData = rw;
      markers.push(m);
    });

    // Use marker clustering when > 50 markers for performance
    if (filtered.length > 50 && typeof L.markerClusterGroup === 'function') {
      clusterGroup = L.markerClusterGroup({
        maxClusterRadius: 40,
        spiderfyOnMaxZoom: true,
        showCoverageOnHover: false,
        zoomToBoundsOnClick: true,
        disableClusteringAtZoom: 15,
        iconCreateFunction: function(cluster) {
          var children = cluster.getAllChildMarkers();
          var count = children.length;
          // Determine worst severity in cluster
          var hasClose = false, hasLane = false;
          children.forEach(function(c) {
            if (c.rwData) {
              var rc = classifyRestriction(c.rwData);
              if (rc === 'full_closure') hasClose = true;
              else if (rc === 'lane_restriction') hasLane = true;
            }
          });
          var bg = hasClose ? '#ef4444' : hasLane ? '#f59e0b' : '#6b7280';
          var size = count > 100 ? 44 : count > 30 ? 38 : 32;
          return L.divIcon({
            html: '<div class="rw-cluster" style="background:'+bg+';width:'+size+'px;height:'+size+'px;line-height:'+size+'px">'+count+'</div>',
            className: 'rw-cluster-icon',
            iconSize: [size, size],
          });
        }
      });
      markers.forEach(function(m){ clusterGroup.addLayer(m); });
      map.addLayer(clusterGroup);
    } else {
      // Few markers — add directly
      markers.forEach(function(m){ m.addTo(map); });
    }

    var statsEl = document.getElementById('map-stats-showing');
    var closures = filtered.filter(function(r){return classifyRestriction(r)==='full_closure';}).length;
    var lanes = filtered.filter(function(r){return classifyRestriction(r)==='lane_restriction';}).length;
    var minor = filtered.filter(function(r){return classifyRestriction(r)==='minor';}).length;
    if (statsEl) {
      statsEl.textContent = filtered.length + ' works \u00b7 ' + closures + ' closures \u00b7 ' + lanes + ' lane restrictions \u00b7 ' + minor + ' minor';
    }
    // Update marker count badge
    var countEl = document.getElementById('rw-map-count-num');
    if (countEl) countEl.textContent = filtered.length;
    // Update floating legend counts
    var lcEl = document.getElementById('legend-closures');
    var llEl = document.getElementById('legend-lanes');
    var lmEl = document.getElementById('legend-minor');
    if (lcEl) lcEl.textContent = closures;
    if (llEl) llEl.textContent = lanes;
    if (lmEl) lmEl.textContent = minor;
  }

  // --- List ---
  function renderList() {
    var el = document.getElementById('rw-list'), cEl = document.getElementById('rw-list-count');
    if (!el) return;
    var filtered = sortRecords(getFiltered());
    if (cEl) cEl.textContent = '(' + filtered.length + ')';
    updateResetBtn();
    if (!filtered.length) {
      el.innerHTML = '<div class="rw-list-empty">No roadworks match your filters</div>';
      var pg = document.getElementById('rw-pagination'); if (pg) pg.style.display = 'none';
      return;
    }
    // Pagination
    var totalPages = Math.ceil(filtered.length / PAGE_SIZE);
    if (currentPage >= totalPages) currentPage = totalPages - 1;
    if (currentPage < 0) currentPage = 0;
    var startIdx = currentPage * PAGE_SIZE;
    var endIdx = Math.min(startIdx + PAGE_SIZE, filtered.length);
    var display = filtered.slice(startIdx, endIdx), h = '';
    display.forEach(function(rw) {
      var c = SEV_COLORS[rw.severity]||'#8e8e93', isA = rw.status==='Works started';
      var days = durationDays(rw), dur = durationLabel(days), bp = Math.min(100, days/90*100);
      var rc = classifyRestriction(rw), rcColor = RESTRICTION_COLORS[rc], rcLabel = RESTRICTION_LABELS[rc];
      var capPct = getCapacityPct(rc);
      var capColor = capPct >= 80 ? '#ef4444' : capPct >= 40 ? '#f59e0b' : '#22c55e';
      h += '<div class="rw-card" data-id="'+rw.id+'" data-sev-color="'+rcColor+'">'
        + '<div class="rw-card-bar" style="background:'+rcColor+';opacity:'+(isA?'1':'0.4')+'"></div>'
        + '<div class="rw-card-body">'
        + '<div class="rw-card-top"><div class="rw-card-road">'+esc(rw.road)+'</div>'
        + '<div class="rw-card-tags">'
        + '<span class="rw-tag" style="background:'+(isA?'#ef444418':'#f59e0b18')+';color:'+(isA?'#ef4444':'#f59e0b')+'">'+(isA?'Active':'Planned')+'</span>'
        + '<span class="rw-tag" style="background:'+rcColor+'18;color:'+rcColor+'">'+esc(rcLabel)+'</span>'
        + '</div></div>'
        + '<div class="rw-card-meta">'+(rw.district?'<span class="rw-district-badge">'+esc(DISTRICT_LABELS[rw.district]||rw.district)+'</span>':'')+esc(rw.ward)+'<span class="rw-sep">\u00b7</span>'+esc(rw.operator)+'</div>'
        + '<div class="rw-card-dates">'+fmtDate(rw.start_date)+' \u2014 '+fmtDate(rw.end_date)+' ('+dur+')' + (function(){ var wh=getWorkingHours(rw); return wh ? ' <span class="rw-card-hours">\u00b7 '+wh.start+'\u2013'+wh.end+'</span>' : ''; })() + '</div>'
        + '<div class="rw-card-capacity"><div class="rw-cap-track"><div class="rw-cap-fill" style="width:'+capPct+'%;background:'+capColor+'"></div></div><span class="rw-cap-label" style="color:'+capColor+'">'+capPct+'% capacity loss</span></div>'
        + '<div class="rw-dur-track"><div class="rw-dur-fill" style="width:'+bp+'%;background:'+c+';opacity:'+(isA?'0.6':'0.2')+'"></div></div>';
      if (rw.description && rw.description.length > 30) {
        var d = rw.description.split('|')[0];
        h += '<div class="rw-card-desc">'+esc(d.length>120?d.substring(0,120)+'\u2026':d)+'</div>';
      }
      if (rw.one_network_url) h += '<a href="'+esc(rw.one_network_url)+'" target="_blank" rel="noopener" class="rw-card-link" onclick="event.stopPropagation()">one.network \u2192</a>';
      h += '</div></div>';
    });
    el.innerHTML = h;
    el.querySelectorAll('.rw-card').forEach(function(card) {
      card.addEventListener('click', function() {
        var id = parseInt(card.getAttribute('data-id'), 10);
        var mk = markers.find(function(m){return m.rwData && m.rwData.id===id;});
        if (mk) { map.setView(mk.getLatLng(), 16); mk.openPopup(); document.getElementById('roadworks-map').scrollIntoView({behavior:'smooth',block:'center'}); }
      });
    });
    // Pagination controls
    var pgEl = document.getElementById('rw-pagination');
    if (pgEl) {
      pgEl.style.display = totalPages > 1 ? '' : 'none';
      var info = document.getElementById('rw-page-info');
      var num = document.getElementById('rw-page-num');
      var prevBtn = document.getElementById('rw-page-prev');
      var nextBtn = document.getElementById('rw-page-next');
      if (info) info.textContent = 'Showing ' + (startIdx + 1) + '\u2013' + endIdx + ' of ' + filtered.length + ' results';
      if (num) num.textContent = 'Page ' + (currentPage + 1) + ' of ' + totalPages;
      if (prevBtn) prevBtn.disabled = currentPage <= 0;
      if (nextBtn) nextBtn.disabled = currentPage >= totalPages - 1;
    }
  }

  // --- Stop playback helper ---
  function stopPlay() {
    if (!playInterval) return;
    clearInterval(playInterval); playInterval = null;
    document.getElementById('play-icon').style.display = '';
    document.getElementById('pause-icon').style.display = 'none';
    var playBtn = document.getElementById('timeline-play');
    if (playBtn) playBtn.classList.remove('playing');
    var lbl = document.getElementById('play-label');
    if (lbl) lbl.textContent = 'Play Timeline';
    var sumEl = document.getElementById('play-summary');
    if (sumEl) sumEl.style.display = 'none';
  }

  // --- Events ---
  document.querySelectorAll('.rw-chip[data-filter]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      stopPlay(); currentPage = 0;
      var ft = btn.getAttribute('data-filter'), v = btn.getAttribute('data-value');
      filters[ft] = v;
      btn.closest('.rw-filter-chips').querySelectorAll('.rw-chip').forEach(function(b){
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');
      renderMarkers(); renderList(); updateStats();
    });
  });

  // Reset all filters
  var resetBtn = document.getElementById('reset-filters');
  if (resetBtn) resetBtn.addEventListener('click', resetAllFilters);

  // Search clear button
  var searchClearBtn = document.getElementById('search-clear');
  var searchInput = document.getElementById('postcode-search');
  if (searchInput) {
    searchInput.addEventListener('input', function() {
      var sc = document.getElementById('search-clear');
      if (sc) sc.style.display = searchInput.value ? '' : 'none';
    });
  }
  if (searchClearBtn) {
    searchClearBtn.addEventListener('click', function() {
      var si = document.getElementById('postcode-search');
      if (si) si.value = '';
      searchClearBtn.style.display = 'none';
      filters.road = '';
      if (postcodeMarker) { map.removeLayer(postcodeMarker); postcodeMarker = null; }
      currentPage = 0;
      renderMarkers(); renderList(); updateStats(); updateResetBtn();
    });
  }

  // Pagination
  document.getElementById('rw-page-prev')?.addEventListener('click', function() {
    if (currentPage > 0) { currentPage--; renderList(); var el = document.getElementById('rw-list'); if (el) el.scrollTop = 0; }
  });
  document.getElementById('rw-page-next')?.addEventListener('click', function() {
    currentPage++; renderList(); var el = document.getElementById('rw-list'); if (el) el.scrollTop = 0;
  });

  ['operator-filter','ward-filter','restriction-filter'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('change', function() {
      stopPlay(); currentPage = 0;
      filters[id.replace('-filter','')] = el.value;
      renderMarkers(); renderList(); updateStats();
    });
  });

  // Postcode/road search (keydown handler)
  var searchEl = document.getElementById('postcode-search');
  if (searchEl) {
    searchEl.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { stopPlay(); currentPage = 0; searchPostcode(searchEl.value); }
    });
  }

  // Toggles
  var cedT = document.getElementById('ced-toggle');
  if (cedT) cedT.addEventListener('change', function() { if (cedT.checked && cedLayer) cedLayer.addTo(map); else if (cedLayer) map.removeLayer(cedLayer); });
  var wardT = document.getElementById('ward-toggle');
  if (wardT) wardT.addEventListener('change', function() { if (!wardLayer) drawWards(); if (wardT.checked && wardLayer) wardLayer.addTo(map); else if (wardLayer) map.removeLayer(wardLayer); });

  // Traffic intelligence layers
  var intelLayer = null, corridorLayer = null;
  var intelT = document.getElementById('traffic-intel-toggle');
  var corrT = document.getElementById('corridor-toggle');

  function loadTrafficIntel() {
    fetch('/data/traffic.json').then(function(r){return r.json()}).then(function(td) {
      if (!td.infrastructure && !td.congestion_model) return;

      // Traffic intelligence layer: signals, junctions, DfT count points, schools
      if (!intelLayer) {
        intelLayer = L.layerGroup();
        var infra = td.infrastructure || {};
        var model = td.congestion_model || {};

        // Traffic signal clusters (small green dots)
        (infra.traffic_signals || []).forEach(function(s) {
          L.circleMarker([s.lat, s.lng], {
            radius: 3, fillColor: '#22c55e', color: '#166534', weight: 1,
            fillOpacity: 0.7, className: 'intel-signal'
          }).bindTooltip('Traffic signal' + (s.signal_count > 1 ? ' cluster (' + s.signal_count + ')' : ''), {className:'rw-popup'}).addTo(intelLayer);
        });

        // Signal crossings (small blue dots)
        (infra.signal_crossings || []).forEach(function(c) {
          var typeLabel = c.type || 'signal';
          L.circleMarker([c.lat, c.lng], {
            radius: 2.5, fillColor: c.bicycle ? '#a855f7' : '#3b82f6',
            color: c.bicycle ? '#6b21a8' : '#1e40af', weight: 1,
            fillOpacity: 0.6
          }).bindTooltip(typeLabel.charAt(0).toUpperCase() + typeLabel.slice(1) + ' crossing' + (c.bicycle ? ' (cycle)' : ''), {className:'rw-popup'}).addTo(intelLayer);
        });

        // Named junction JCI markers (larger, color-coded)
        (model.junctions || []).forEach(function(j) {
          var col = j.jci_level === 'critical' ? '#dc2626' : j.jci_level === 'high' ? '#f97316' : j.jci_level === 'moderate' ? '#eab308' : '#22c55e';
          var sz = j.jci >= 70 ? 10 : j.jci >= 50 ? 8 : j.jci >= 30 ? 7 : 6;
          L.circleMarker([j.lat, j.lng], {
            radius: sz, fillColor: col, color: '#000', weight: 2,
            fillOpacity: 0.85
          }).bindPopup(
            '<div style="color:#fff;font-weight:700;font-size:14px;margin-bottom:4px">' + esc(j.name) + '</div>' +
            '<div style="display:flex;gap:8px;margin-bottom:6px">' +
              '<span style="background:' + col + ';color:#fff;padding:2px 8px;border-radius:4px;font-weight:600">JCI ' + j.jci + '</span>' +
              '<span style="color:#aaa;text-transform:uppercase;font-size:11px">' + j.jci_level + '</span>' +
            '</div>' +
            (j.traffic_volume ? '<div style="color:#ccc;font-size:12px">' + j.traffic_volume.toLocaleString() + ' vehicles/day</div>' : '') +
            (j.nearby_schools ? '<div style="color:#ccc;font-size:12px">' + j.nearby_schools + ' school(s) within 500m</div>' : '') +
            (j.nearby_defects ? '<div style="color:#ccc;font-size:12px">' + j.nearby_defects + ' FixMyStreet report(s) nearby</div>' : '') +
            (j.notes ? '<div style="color:#888;font-size:11px;margin-top:4px">' + esc(j.notes) + '</div>' : ''),
            {className: 'rw-popup', maxWidth: 280}
          ).addTo(intelLayer);
        });

        // DfT count points (proportionally sized by volume)
        (td.count_points || []).forEach(function(cp) {
          if (!cp.aadf || !cp.lat || !cp.lng) return;
          var vol = cp.aadf.all_motor_vehicles || 0;
          if (vol < 1000) return;
          var sz = Math.max(3, Math.min(vol / 5000, 12));
          L.circleMarker([cp.lat, cp.lng], {
            radius: sz, fillColor: '#12b6cf', color: '#0e7490', weight: 1,
            fillOpacity: 0.4
          }).bindTooltip(
            cp.road + ': ' + vol.toLocaleString() + ' vehicles/day (' + (cp.aadf.year || '?') + ')',
            {className: 'rw-popup'}
          ).addTo(intelLayer);
        });

        // Schools (orange squares)
        (infra.schools || []).forEach(function(sc) {
          L.circleMarker([sc.lat, sc.lng], {
            radius: 5, fillColor: '#f59e0b', color: '#92400e', weight: 1.5,
            fillOpacity: 0.7
          }).bindTooltip(esc(sc.name) + ' (~' + sc.pupils + ' pupils)', {className:'rw-popup'}).addTo(intelLayer);
        });

        // Turf Moor
        if (infra.turf_moor) {
          L.circleMarker([infra.turf_moor.lat, infra.turf_moor.lng], {
            radius: 8, fillColor: '#7c3aed', color: '#4c1d95', weight: 2,
            fillOpacity: 0.8
          }).bindTooltip('Turf Moor (' + (infra.turf_moor.capacity||'').toLocaleString() + ' capacity)', {className:'rw-popup'}).addTo(intelLayer);
        }
      }

      // Congestion corridor layer
      if (!corridorLayer) {
        corridorLayer = L.layerGroup();
        (model.corridors || []).forEach(function(cor) {
          var col = cor.level === 'critical' ? '#dc2626' : cor.level === 'severe' ? '#f97316' : cor.level === 'high' ? '#eab308' : cor.level === 'moderate' ? '#22c55e' : '#64748b';
          var w = cor.severity >= 0.8 ? 6 : cor.severity >= 0.6 ? 5 : cor.severity >= 0.4 ? 4 : 3;
          var latlngs = cor.coords.map(function(c){return [c[0], c[1]]});
          L.polyline(latlngs, {
            color: col, weight: w, opacity: 0.7,
            dashArray: cor.level === 'critical' ? null : '8 4'
          }).bindPopup(
            '<div style="color:#fff;font-weight:700;font-size:13px">' + esc(cor.name) + '</div>' +
            '<div style="color:' + col + ';font-weight:600;margin:4px 0">' + cor.level.toUpperCase() + ' (severity ' + (cor.severity * 100).toFixed(0) + '%)</div>' +
            (cor.avg_daily_vehicles ? '<div style="color:#ccc;font-size:12px">' + cor.avg_daily_vehicles.toLocaleString() + ' avg daily vehicles</div>' : ''),
            {className: 'rw-popup', maxWidth: 250}
          ).addTo(corridorLayer);
        });
      }

      // Apply toggle state
      if (intelT && intelT.checked && intelLayer) intelLayer.addTo(map);
      if (corrT && corrT.checked && corridorLayer) corridorLayer.addTo(map);
    }).catch(function(e) { console.warn('Traffic intel load failed:', e); });
  }

  if (intelT) intelT.addEventListener('change', function() {
    if (!intelLayer) loadTrafficIntel();
    else if (intelT.checked) intelLayer.addTo(map);
    else map.removeLayer(intelLayer);
    // Toggle JCI legend entry
    var jciLeg = document.getElementById('legend-jci');
    if (jciLeg) jciLeg.style.display = intelT.checked ? '' : 'none';
  });
  if (corrT) corrT.addEventListener('change', function() {
    if (!corridorLayer) loadTrafficIntel();
    else if (corrT.checked) corridorLayer.addTo(map);
    else map.removeLayer(corridorLayer);
  });

  // Timeline
  var tSlider = document.getElementById('timeline-slider');
  if (tSlider) tSlider.addEventListener('input', function() { stopPlay(); if (timelineMode==='all') timelineMode='date'; setTimelineDate(parseInt(tSlider.value, 10)); });

  document.getElementById('timeline-prev')?.addEventListener('click', function() {
    stopPlay(); if (timelineMode==='all') timelineMode='date';
    var c = daysBetween(dateRangeStart, selectedDate); if (c>0) setTimelineDate(c-1);
  });
  document.getElementById('timeline-next')?.addEventListener('click', function() {
    stopPlay(); if (timelineMode==='all') timelineMode='date';
    var c = daysBetween(dateRangeStart, selectedDate), mx = daysBetween(dateRangeStart, dateRangeEnd); if (c<mx) setTimelineDate(c+1);
  });
  document.getElementById('timeline-today')?.addEventListener('click', function() {
    stopPlay(); timelineMode='date'; var td = new Date(); td.setHours(0,0,0,0);
    var idx = Math.max(0, Math.min(daysBetween(dateRangeStart, td), daysBetween(dateRangeStart, dateRangeEnd)));
    setTimelineDate(idx);
  });
  document.getElementById('timeline-mode')?.addEventListener('click', function() {
    stopPlay(); timelineMode = timelineMode==='all'?'date':'all'; if(timelineMode==='all')selectedHour=null; updateTimelineDisplay(); renderMarkers(); renderList(); updateStats();
  });
  document.getElementById('timeline-play')?.addEventListener('click', function() {
    var playBtn = document.getElementById('timeline-play');
    var lbl = document.getElementById('play-label');
    if (playInterval) { stopPlay(); return; }
    timelineMode='date'; document.getElementById('play-icon').style.display='none'; document.getElementById('pause-icon').style.display='';
    if(playBtn)playBtn.classList.add('playing');
    if(lbl)lbl.textContent='Pause';
    var c = daysBetween(dateRangeStart, selectedDate), mx = daysBetween(dateRangeStart, dateRangeEnd);
    playInterval = setInterval(function() {
      c++; if(c>mx){stopPlay();return;} setTimelineDate(c);
      // Update play summary
      var sumEl = document.getElementById('play-summary');
      if (sumEl) {
        var active = getFiltered().length;
        sumEl.textContent = 'Day '+(c+1)+'/'+(mx+1)+' \u2014 '+active+' active';
        sumEl.style.display = '';
      }
    }, playSpeed);
  });

  // Speed controls
  document.querySelectorAll('.rw-speed-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      playSpeed = parseInt(btn.dataset.speed, 10) || 600;
      document.querySelectorAll('.rw-speed-btn').forEach(function(b){ b.classList.remove('rw-speed-active'); });
      btn.classList.add('rw-speed-active');
      // If playing, restart with new speed
      if (playInterval) {
        clearInterval(playInterval);
        var c = daysBetween(dateRangeStart, selectedDate), mx = daysBetween(dateRangeStart, dateRangeEnd);
        playInterval = setInterval(function() {
          c++; if(c>mx){stopPlay();return;} setTimelineDate(c);
          var sumEl = document.getElementById('play-summary');
          if (sumEl) { sumEl.textContent = 'Day '+(c+1)+'/'+(mx+1)+' \u2014 '+getFiltered().length+' active'; }
        }, playSpeed);
      }
    });
  });

  // Keyboard shortcuts for timeline: ←/→ prev/next, Space play/pause
  document.addEventListener('keydown', function(e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') return;
    if (e.key === ' ' && timelineMode === 'date') {
      e.preventDefault();
      document.getElementById('timeline-play')?.click();
    } else if (e.key === 'ArrowLeft' && timelineMode === 'date' && selectedDate) {
      var c = daysBetween(dateRangeStart, selectedDate);
      if (c > 0) setTimelineDate(c - 1);
    } else if (e.key === 'ArrowRight' && timelineMode === 'date' && selectedDate) {
      var c = daysBetween(dateRangeStart, selectedDate);
      var mx = daysBetween(dateRangeStart, dateRangeEnd);
      if (c < mx) setTimelineDate(c + 1);
    }
  });

  var sortEl = document.getElementById('rw-sort');
  if (sortEl) sortEl.addEventListener('change', function() { sortBy = sortEl.value; currentPage = 0; renderList(); });

  document.getElementById('hourly-clear')?.addEventListener('click', function() {
    stopPlay(); selectedHour = null; buildHourlyStrip(); renderMarkers(); renderList(); updateStats();
  });

  // Listen for external region change events (from page-level toggle)
  window.addEventListener('setregion', function(e) {
    var district = e.detail && e.detail.district;
    if (!district) return;
    var dSel = document.getElementById('district-filter');
    if (dSel) { dSel.value = district; }
    filters.district = district;
    currentPage = 0;
    if (district !== 'all' && DISTRICT_CENTERS[district]) {
      map.flyTo(DISTRICT_CENTERS[district].center, DISTRICT_CENTERS[district].zoom, { duration: 1 });
    } else {
      map.flyTo(LANCASHIRE_CENTER, LANCASHIRE_ZOOM, { duration: 1 });
    }
    stopPlay();
    updateStats(); renderMarkers(); buildWorksChart(); renderList();
  });

  // --- Fullscreen toggle ---
  var fsBtn = document.getElementById('rw-fullscreen');
  if (fsBtn) fsBtn.addEventListener('click', function() {
    var wrapper = document.getElementById('rw-map-wrapper');
    if (!wrapper) return;
    if (!document.fullscreenElement) {
      (wrapper.requestFullscreen || wrapper.webkitRequestFullscreen || function(){}).call(wrapper);
      fsBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3v3a2 2 0 0 1-2 2H3m18 0h-3a2 2 0 0 1-2-2V3m0 18v-3a2 2 0 0 1 2-2h3M3 16h3a2 2 0 0 1 2 2v3"/></svg>';
      wrapper.classList.add('rw-fullscreen');
      setTimeout(function(){ if (map) map.invalidateSize(); }, 100);
    } else {
      (document.exitFullscreen || document.webkitExitFullscreen || function(){}).call(document);
      fsBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>';
      wrapper.classList.remove('rw-fullscreen');
      setTimeout(function(){ if (map) map.invalidateSize(); }, 100);
    }
  });
  document.addEventListener('fullscreenchange', function() {
    var wrapper = document.getElementById('rw-map-wrapper');
    if (!document.fullscreenElement && wrapper) {
      wrapper.classList.remove('rw-fullscreen');
      if (fsBtn) fsBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>';
      setTimeout(function(){ if (map) map.invalidateSize(); }, 100);
    }
  });

  // --- Fit to markers ---
  var fitBtn = document.getElementById('rw-fit-markers');
  if (fitBtn) fitBtn.addEventListener('click', function() {
    if (!map || !markers || !markers.length) return;
    var bounds = L.latLngBounds(markers.map(function(m){ return m.getLatLng(); }));
    map.fitBounds(bounds, { padding: [40, 40], maxZoom: 14 });
  });

  if (document.readyState==='loading') document.addEventListener('DOMContentLoaded', initMap); else initMap();
})();
</script>

<style>
  /* --- Layout --- */
  .rw-section { margin: 1.5rem 0; }

  /* --- Loading states --- */
  .rw-map-loading {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background: rgba(10, 10, 14, 0.85);
    border-radius: 18px;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .rw-map-loading.rw-loaded { opacity: 0; }
  .rw-spinner {
    width: 32px; height: 32px;
    border: 3px solid rgba(255,255,255,0.08);
    border-top-color: #f59e0b;
    border-radius: 50%;
    animation: rw-spin 0.8s linear infinite;
  }
  @keyframes rw-spin { to { transform: rotate(360deg); } }
  .rw-loading-text {
    font-size: 12px;
    color: rgba(235,235,245,0.35);
    letter-spacing: 0.03em;
  }

  /* Shimmer for stat cards before data loads */
  .rw-stat-card.rw-shimmer .rw-stat-value {
    background: linear-gradient(90deg, rgba(255,255,255,0.04) 25%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.04) 75%);
    background-size: 200% 100%;
    animation: rw-shimmer 1.5s ease-in-out infinite;
    color: transparent !important;
    text-shadow: none !important;
    border-radius: 6px;
    min-width: 40px;
    display: inline-block;
  }
  @keyframes rw-shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

  /* --- Stats grid --- */
  .rw-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .rw-stat-card {
    position: relative;
    padding: 1.125rem 1.25rem;
    background: linear-gradient(145deg, rgba(32, 32, 36, 0.75), rgba(14, 14, 18, 0.6));
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 1px 0 rgba(255,255,255,0.04) inset, 0 4px 24px rgba(0,0,0,0.3);
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .rw-stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    border-radius: 16px 16px 0 0;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    transform-origin: left center;
  }

  .rw-stat-card::after {
    content: '';
    position: absolute;
    top: -20%; right: -15%;
    width: 160px; height: 160px;
    border-radius: 50%;
    opacity: 0.15;
    transition: opacity 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }

  .rw-stat-active::before { background: linear-gradient(90deg, #ef4444 0%, #ef444480 45%, transparent 100%); filter: blur(0.5px) drop-shadow(0 0 6px rgba(239,68,68,0.5)); }
  .rw-stat-planned::before { background: linear-gradient(90deg, #f59e0b 0%, #f59e0b80 45%, transparent 100%); filter: blur(0.5px) drop-shadow(0 0 6px rgba(245,158,11,0.5)); }
  .rw-stat-high::before { background: linear-gradient(90deg, #ff453a 0%, #ff453a80 45%, transparent 100%); filter: blur(0.5px) drop-shadow(0 0 6px rgba(255,69,58,0.5)); }
  .rw-stat-closures::before { background: linear-gradient(90deg, #dc2626 0%, #dc262680 45%, transparent 100%); filter: blur(0.5px) drop-shadow(0 0 6px rgba(220,38,38,0.5)); }
  .rw-stat-districts::before { background: linear-gradient(90deg, #12b6cf 0%, #12b6cf80 45%, transparent 100%); filter: blur(0.5px) drop-shadow(0 0 6px rgba(18,182,207,0.5)); }

  .rw-stat-active::after { background: radial-gradient(circle, rgba(239,68,68,0.12) 0%, transparent 70%); }
  .rw-stat-planned::after { background: radial-gradient(circle, rgba(245,158,11,0.12) 0%, transparent 70%); }
  .rw-stat-high::after { background: radial-gradient(circle, rgba(255,69,58,0.12) 0%, transparent 70%); }
  .rw-stat-closures::after { background: radial-gradient(circle, rgba(220,38,38,0.12) 0%, transparent 70%); }
  .rw-stat-districts::after { background: radial-gradient(circle, rgba(18,182,207,0.12) 0%, transparent 70%); }

  .rw-stat-card:hover {
    transform: translateY(-4px) scale(1.01);
    box-shadow: 0 12px 40px rgba(0,0,0,0.5), 0 1px 0 rgba(255,255,255,0.04) inset;
  }
  .rw-stat-card:hover::after { opacity: 0.5; }
  .rw-stat-card:hover::before { transform: scaleX(1.02); }

  .rw-stat-active:hover { border-color: rgba(239,68,68,0.25); box-shadow: 0 12px 40px rgba(0,0,0,0.5), 0 0 20px rgba(239,68,68,0.08); }
  .rw-stat-planned:hover { border-color: rgba(245,158,11,0.25); box-shadow: 0 12px 40px rgba(0,0,0,0.5), 0 0 20px rgba(245,158,11,0.08); }
  .rw-stat-high:hover { border-color: rgba(255,69,58,0.25); box-shadow: 0 12px 40px rgba(0,0,0,0.5), 0 0 20px rgba(255,69,58,0.08); }
  .rw-stat-closures:hover { border-color: rgba(220,38,38,0.25); box-shadow: 0 12px 40px rgba(0,0,0,0.5), 0 0 20px rgba(220,38,38,0.08); }
  .rw-stat-districts:hover { border-color: rgba(18,182,207,0.3); box-shadow: 0 12px 40px rgba(0,0,0,0.5), 0 0 20px rgba(18,182,207,0.1); }

  .rw-stat-value {
    font-size: 2rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .rw-stat-label {
    font-size: 0.6875rem;
    color: rgba(235, 235, 245, 0.4);
    font-weight: 500;
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .rw-stat-icon {
    position: absolute;
    top: 1rem; right: 1rem;
    color: rgba(235, 235, 245, 0.09);
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .rw-stat-active:hover .rw-stat-icon { color: rgba(239,68,68,0.35); filter: drop-shadow(0 0 4px rgba(239,68,68,0.25)); }
  .rw-stat-planned:hover .rw-stat-icon { color: rgba(245,158,11,0.35); filter: drop-shadow(0 0 4px rgba(245,158,11,0.25)); }
  .rw-stat-high:hover .rw-stat-icon { color: rgba(255,69,58,0.35); filter: drop-shadow(0 0 4px rgba(255,69,58,0.25)); }
  .rw-stat-closures:hover .rw-stat-icon { color: rgba(220,38,38,0.35); filter: drop-shadow(0 0 4px rgba(220,38,38,0.25)); }
  .rw-stat-districts:hover .rw-stat-icon { color: rgba(18,182,207,0.4); filter: drop-shadow(0 0 4px rgba(18,182,207,0.3)); }

  .rw-stat-active .rw-stat-value { color: #ef4444; text-shadow: 0 0 24px rgba(239,68,68,0.2); }
  .rw-stat-planned .rw-stat-value { color: #f59e0b; text-shadow: 0 0 24px rgba(245,158,11,0.2); }
  .rw-stat-high .rw-stat-value { color: #ff453a; text-shadow: 0 0 24px rgba(255,69,58,0.2); }
  .rw-stat-closures .rw-stat-value { color: #dc2626; text-shadow: 0 0 24px rgba(220,38,38,0.2); }
  .rw-stat-districts .rw-stat-value { color: #12b6cf; text-shadow: 0 0 24px rgba(18,182,207,0.25); }

  /* --- Controls --- */
  .rw-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.875rem;
    background: linear-gradient(160deg, rgba(24, 24, 28, 0.72), rgba(16,16,20,0.55));
    backdrop-filter: blur(28px) saturate(1.5);
    -webkit-backdrop-filter: blur(28px) saturate(1.5);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    margin-bottom: 0.5rem;
    box-shadow: 0 1px 0 rgba(255,255,255,0.05) inset, 0 2px 12px rgba(0,0,0,0.2);
  }

  .rw-controls-secondary { padding: 0.4rem 0.875rem; border-top: 1px solid rgba(255,255,255,0.04); }

  /* Search */
  .rw-search-box {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.045);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 10px;
    padding: 0 10px;
    flex: 1;
    min-width: 160px;
    max-width: 280px;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .rw-search-box:focus-within {
    border-color: rgba(18, 182, 207, 0.5);
    box-shadow: 0 0 0 2.5px rgba(18, 182, 207, 0.18), 0 0 16px rgba(18, 182, 207, 0.08);
  }

  .rw-search-icon { color: rgba(235, 235, 245, 0.3); flex-shrink: 0; transition: color 0.2s ease; }
  .rw-search-box:focus-within .rw-search-icon { color: rgba(18, 182, 207, 0.7); }

  .rw-search-input {
    border: none;
    background: transparent;
    color: rgba(235, 235, 245, 0.85);
    font-size: 0.8125rem;
    padding: 6px 0;
    width: 100%;
    outline: none;
  }

  .rw-search-input::placeholder { color: rgba(235, 235, 245, 0.25); }

  .rw-search-kbd {
    font-size: 0.5625rem;
    color: rgba(235, 235, 245, 0.25);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    padding: 1px 4px;
    font-family: inherit;
    flex-shrink: 0;
    transition: opacity 0.2s ease;
  }
  .rw-search-box:focus-within .rw-search-kbd { opacity: 0; }

  /* Chips */
  .rw-filter-chips { display: flex; gap: 4px; }
  .rw-filter-chips + .rw-filter-chips { padding-left: 0.625rem; border-left: 1px solid rgba(255,255,255,0.07); }

  .rw-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 5px 11px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 100px;
    background: transparent;
    color: rgba(235, 235, 245, 0.5);
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.22s cubic-bezier(0.22, 1, 0.36, 1);
    white-space: nowrap;
  }

  .rw-chip:hover { background: rgba(255, 255, 255, 0.06); color: #fff; transform: translateY(-1px); }
  .rw-chip:active { transform: scale(0.97) translateY(0); transition-duration: 80ms; }

  .rw-chip.active {
    background: rgba(18, 182, 207, 0.12);
    border-color: rgba(18, 182, 207, 0.25);
    color: #12b6cf;
    box-shadow: 0 0 0 1px rgba(18,182,207,0.15), 0 0 12px rgba(18,182,207,0.12);
    text-shadow: 0 0 12px rgba(18,182,207,0.4);
  }

  .rw-chip-red.active { background: rgba(239,68,68,0.12); border-color: rgba(239,68,68,0.25); color: #ef4444; box-shadow: 0 0 0 1px rgba(239,68,68,0.2), 0 0 12px rgba(239,68,68,0.12); text-shadow: 0 0 12px rgba(239,68,68,0.5); }
  .rw-chip-amber.active { background: rgba(245,158,11,0.12); border-color: rgba(245,158,11,0.25); color: #f59e0b; box-shadow: 0 0 0 1px rgba(245,158,11,0.2), 0 0 12px rgba(245,158,11,0.12); text-shadow: 0 0 12px rgba(245,158,11,0.45); }
  .rw-chip-green.active { background: rgba(34,197,94,0.12); border-color: rgba(34,197,94,0.25); color: #22c55e; box-shadow: 0 0 0 1px rgba(34,197,94,0.2), 0 0 12px rgba(34,197,94,0.1); text-shadow: 0 0 12px rgba(34,197,94,0.4); }

  .rw-pulse-dot {
    width: 5px; height: 5px; border-radius: 50%; background: #ef4444;
    animation: pulse-dot 1.8s ease-in-out infinite;
  }
  @keyframes pulse-dot { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.35; transform: scale(0.7); } }

  .rw-select {
    padding: 5px 10px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 9px;
    background: rgba(255, 255, 255, 0.045);
    color: rgba(235, 235, 245, 0.7);
    font-size: 0.75rem;
    cursor: pointer;
    max-width: 180px;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .rw-select:hover { border-color: rgba(255,255,255,0.14); color: rgba(235,235,245,0.85); }
  .rw-select:focus { border-color: rgba(18, 182, 207, 0.3); outline: none; box-shadow: 0 0 0 2px rgba(18,182,207,0.2); }
  .rw-select-sm { max-width: 130px; }
  .rw-select-district { border-color: rgba(245,158,11,0.3); font-weight: 600; min-width: 170px; }
  .rw-select-district:hover { border-color: rgba(245,158,11,0.5); }
  .rw-select-district:focus { border-color: rgba(245,158,11,0.5); box-shadow: 0 0 0 2px rgba(245,158,11,0.15); }

  .rw-boundary-toggles { display: flex; gap: 0.75rem; margin-left: auto; }

  .rw-toggle {
    display: flex; align-items: center; gap: 5px;
    font-size: 0.7rem; color: rgba(235,235,245,0.45); cursor: pointer; white-space: nowrap;
    transition: color 0.2s ease;
  }
  .rw-toggle:hover { color: rgba(235,235,245,0.7); }

  .rw-toggle input { accent-color: #12b6cf; width: 13px; height: 13px; cursor: pointer; }

  .rw-toggle-intel { color: rgba(18,182,207,0.55); }
  .rw-toggle-intel:hover { color: rgba(18,182,207,0.8); }

  /* --- Timeline --- */
  .rw-timeline {
    padding: 0.625rem 0.875rem;
    background: rgba(22, 22, 26, 0.68);
    backdrop-filter: blur(20px) saturate(1.2);
    -webkit-backdrop-filter: blur(20px) saturate(1.2);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    margin-bottom: 0.5rem;
    box-shadow: 0 1px 0 rgba(255,255,255,0.04) inset, 0 4px 20px rgba(0,0,0,0.2);
  }

  .rw-timeline-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }

  .rw-timeline-nav { display: flex; align-items: center; gap: 0.5rem; }

  .rw-tl-date {
    font-size: 0.84rem; font-weight: 600; color: rgba(235,235,245,0.9);
    min-width: 180px; text-align: center; font-variant-numeric: tabular-nums;
  }

  .rw-tl-btn {
    width: 30px; height: 30px; border: 1px solid rgba(255,255,255,0.08); border-radius: 8px;
    background: transparent; color: rgba(235,235,245,0.5); font-size: 1.1rem; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.18s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .rw-tl-btn:hover { background: rgba(255,255,255,0.04); color: #fff; transform: scale(1.08); }
  .rw-tl-btn:active { transform: scale(0.94); }

  .rw-timeline-actions { display: flex; gap: 4px; }

  .rw-tl-action {
    display: inline-flex; align-items: center; gap: 3px;
    padding: 4px 10px; border: 1px solid rgba(255,255,255,0.06); border-radius: 8px;
    background: transparent; color: rgba(235,235,245,0.45); font-size: 0.71rem; font-weight: 500;
    cursor: pointer; transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .rw-tl-action:hover { background: rgba(255,255,255,0.04); color: #fff; transform: translateY(-1px); }
  .rw-tl-action:active { transform: scale(0.96); }
  .rw-tl-action.active { background: rgba(18,182,207,0.12); border-color: rgba(18,182,207,0.25); color: #12b6cf; }

  /* Play row — centered play button with edge labels */
  .rw-play-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 6px;
    gap: 8px;
  }

  .rw-tl-edge-label {
    font-size: 0.625rem;
    color: rgba(235,235,245,0.25);
    font-variant-numeric: tabular-nums;
    min-width: 60px;
  }

  .rw-tl-edge-label:last-child { text-align: right; }

  /* Prominent play button */
  .rw-play-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 20px;
    border: 1px solid rgba(18,182,207,0.3);
    border-radius: 20px;
    background: rgba(18,182,207,0.1);
    color: #12b6cf;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    letter-spacing: 0.02em;
  }
  .rw-play-btn:hover {
    background: rgba(18,182,207,0.2);
    border-color: rgba(18,182,207,0.5);
    box-shadow: 0 0 20px rgba(18,182,207,0.25);
    transform: translateY(-1px);
  }
  .rw-play-btn:active { transform: scale(0.96); }
  .rw-play-btn.playing {
    background: rgba(239,68,68,0.12);
    border-color: rgba(239,68,68,0.35);
    color: #ef4444;
    box-shadow: 0 0 16px rgba(239,68,68,0.2);
  }
  .rw-play-btn.playing:hover {
    background: rgba(239,68,68,0.2);
    box-shadow: 0 0 24px rgba(239,68,68,0.3);
  }

  .rw-play-label {
    font-size: 0.75rem;
    font-weight: 600;
  }

  /* Speed controls */
  .rw-speed-controls {
    display: flex;
    gap: 2px;
    background: rgba(255,255,255,0.04);
    border-radius: 8px;
    padding: 2px;
    border: 1px solid rgba(255,255,255,0.06);
  }
  .rw-speed-btn {
    padding: 3px 8px;
    font-size: 11px;
    font-weight: 600;
    font-family: Inter, -apple-system, sans-serif;
    color: rgba(235,235,245,0.4);
    background: transparent;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .rw-speed-btn:hover { color: rgba(235,235,245,0.7); background: rgba(255,255,255,0.06); }
  .rw-speed-btn.rw-speed-active {
    color: #f59e0b;
    background: rgba(245,158,11,0.12);
  }

  /* Play summary overlay */
  .rw-play-summary {
    font-size: 11px;
    color: rgba(245,158,11,0.7);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    display: none;
  }

  .rw-timeline-track { position: relative; }

  .rw-heatmap { width: 100%; height: 36px; border-radius: 8px; overflow: hidden; }

  .rw-slider {
    -webkit-appearance: none; appearance: none; width: 100%; height: 36px;
    background: transparent; cursor: pointer; margin: -38px 0 0 0; position: relative; z-index: 2;
  }

  .rw-slider::-webkit-slider-thumb {
    -webkit-appearance: none; width: 3px; height: 42px; background: #12b6cf;
    border-radius: 2px; cursor: grab;
    box-shadow: 0 0 0 2px rgba(18,182,207,0.3), 0 0 12px rgba(18,182,207,0.7);
  }

  .rw-slider::-moz-range-thumb {
    width: 3px; height: 42px; background: #12b6cf; border-radius: 2px; border: none;
    cursor: grab; box-shadow: 0 0 0 2px rgba(18,182,207,0.3), 0 0 12px rgba(18,182,207,0.7);
  }

  .rw-slider:focus::-webkit-slider-thumb {
    box-shadow: 0 0 0 3px rgba(18,182,207,0.25), 0 0 20px rgba(18,182,207,0.9);
  }

  .rw-timeline-labels {
    display: flex; justify-content: space-between; align-items: center; margin-top: 3px;
    font-size: 0.625rem; color: rgba(235,235,245,0.25); font-variant-numeric: tabular-nums;
  }

  .rw-tl-count {
    font-size: 0.74rem; color: #12b6cf; font-weight: 500; letter-spacing: 0.01em;
    transition: opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1); opacity: 0;
  }

  /* --- Map --- */
  .rw-map-wrapper {
    position: relative;
    border-radius: 18px;
    overflow: hidden;
  }

  /* Fullscreen mode */
  .rw-map-wrapper.rw-fullscreen {
    position: fixed !important;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 9999;
    border-radius: 0 !important;
  }
  .rw-map-wrapper.rw-fullscreen .rw-map { height: 100vh !important; border-radius: 0; }
  .rw-map-wrapper.rw-fullscreen .rw-map-glow { display: none; }
  .rw-map-wrapper.rw-fullscreen::after { display: none; }
  .rw-map-wrapper.rw-fullscreen .rw-map-legend { bottom: 50px; }
  .rw-map-wrapper.rw-fullscreen .rw-map-timestamp { top: 16px; right: 16px; }

  /* Map toolbar */
  .rw-map-toolbar {
    position: absolute;
    top: 12px;
    left: 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    z-index: 1000;
  }

  .rw-map-btn {
    width: 34px;
    height: 34px;
    background: rgba(16, 16, 18, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    color: #c7c7cc;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
  }
  .rw-map-btn:hover {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.25);
  }

  /* Marker count badge */
  .rw-map-count {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 5px;
    background: rgba(16, 16, 18, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
    padding: 5px 14px;
    z-index: 1000;
    pointer-events: none;
  }
  .rw-map-count-num {
    font-size: 0.9rem;
    font-weight: 700;
    color: #fff;
    font-variant-numeric: tabular-nums;
  }
  .rw-map-count-label {
    font-size: 0.7rem;
    color: #8e8e93;
    font-weight: 500;
  }

  .rw-map-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 18px;
    z-index: 500;
    pointer-events: none;
    background: radial-gradient(ellipse at 50% 50%, transparent 60%, rgba(0,0,0,0.35) 100%);
    mix-blend-mode: multiply;
  }

  .rw-map-glow {
    position: absolute;
    inset: -3px;
    border-radius: 21px;
    background: conic-gradient(from 0deg at 50% 50%, rgba(18,182,207,0.25) 0deg, rgba(18,182,207,0.08) 60deg, rgba(245,158,11,0.18) 120deg, rgba(239,68,68,0.15) 180deg, rgba(139,92,246,0.12) 240deg, rgba(18,182,207,0.08) 300deg, rgba(18,182,207,0.25) 360deg);
    z-index: 0;
    pointer-events: none;
    animation: map-glow-rotate 28s linear infinite;
  }

  @keyframes map-glow-rotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .rw-map {
    position: relative;
    width: 100%;
    height: min(600px, 60vh);
    min-height: 350px;
    border-radius: 18px;
    z-index: 1;
  }

  .rw-map-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    z-index: 1000;
    display: flex;
    justify-content: space-between;
    padding: 16px 14px 10px;
    background: linear-gradient(transparent, rgba(0,0,0,0.8) 70%, rgba(0,0,0,0.9));
    font-size: 0.6875rem;
    color: rgba(235,235,245,0.5);
    font-variant-numeric: tabular-nums;
    pointer-events: none;
    letter-spacing: 0.02em;
  }

  /* --- Floating timestamp overlay (top-right) --- */
  .rw-map-timestamp {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 1000;
    background: rgba(16, 16, 18, 0.88);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    padding: 8px 12px;
    pointer-events: auto;
  }
  .rw-ts-row {
    display: flex;
    align-items: center;
    gap: 5px;
    color: rgba(235, 235, 245, 0.6);
    font-size: 0.6875rem;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .rw-ts-count {
    font-size: 0.6rem;
    color: rgba(235, 235, 245, 0.3);
    margin-top: 2px;
    white-space: nowrap;
  }

  /* --- Floating legend overlay (bottom-left) --- */
  .rw-map-legend {
    position: absolute;
    bottom: 40px;
    left: 12px;
    z-index: 1000;
    background: rgba(16, 16, 18, 0.88);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    padding: 8px 12px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    pointer-events: auto;
  }
  .rw-ml-item {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 0.6875rem;
    color: rgba(235, 235, 245, 0.6);
    white-space: nowrap;
  }
  .rw-ml-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 0 6px currentColor;
  }
  .rw-ml-pulse {
    animation: legend-pulse 2.2s ease-in-out infinite;
  }
  .rw-ml-label {
    font-weight: 500;
    flex: 1;
  }
  .rw-ml-count {
    font-weight: 700;
    color: rgba(235, 235, 245, 0.85);
    font-variant-numeric: tabular-nums;
    min-width: 20px;
    text-align: right;
  }

  /* --- Markers — restriction-type aware --- */
  :global(.rw-marker-active),
  :global(.rw-marker-closure),
  :global(.rw-marker-lane) { background: transparent !important; border: none !important; }

  :global(.rw-marker-pulse) {
    position: absolute;
    width: 26px; height: 26px;
    border-radius: 50%;
    background: var(--mc, #ef4444);
    opacity: 0.3;
    animation: marker-pulse 2.2s ease-out infinite;
    top: 0; left: 0;
  }

  :global(.rw-marker-core) {
    position: absolute;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.5);
    display: flex; align-items: center; justify-content: center;
  }

  :global(.rw-marker-closure-core) {
    top: 2px; left: 2px;
    width: 22px; height: 22px;
    box-shadow: 0 0 0 1px rgba(255,255,255,0.2), 0 0 14px rgba(220,38,38,0.8), 0 0 30px rgba(220,38,38,0.4);
  }

  :global(.rw-marker-lane-core) {
    top: 3px; left: 3px;
    width: 14px; height: 14px;
    border-width: 1.5px;
    box-shadow: 0 0 0 1px rgba(255,255,255,0.15), 0 0 10px rgba(245,158,11,0.65), 0 0 20px rgba(245,158,11,0.25);
  }

  :global(.rw-marker-lane .rw-marker-pulse) {
    width: 20px; height: 20px;
  }

  @keyframes marker-pulse {
    0% { transform: scale(1); opacity: 0.35; }
    60% { transform: scale(2.4); opacity: 0; }
    100% { transform: scale(2.4); opacity: 0; }
  }

  /* --- Marker cluster styling --- */
  :global(.rw-cluster-icon) { background: transparent !important; border: none !important; }
  :global(.rw-cluster) {
    border-radius: 50%;
    color: #fff;
    font-family: Inter, -apple-system, sans-serif;
    font-weight: 700;
    font-size: 13px;
    text-align: center;
    box-shadow: 0 0 0 3px rgba(255,255,255,0.2), 0 0 15px rgba(0,0,0,0.5);
    border: 2px solid rgba(255,255,255,0.25);
    transition: transform 0.2s ease;
  }
  :global(.rw-cluster:hover) { transform: scale(1.15); }
  /* Override default markercluster styles */
  :global(.marker-cluster-small),
  :global(.marker-cluster-medium),
  :global(.marker-cluster-large) { background: transparent !important; }
  :global(.marker-cluster-small div),
  :global(.marker-cluster-medium div),
  :global(.marker-cluster-large div) { background: transparent !important; }

  :global(.postcode-pin) { background: transparent !important; border: none !important; }
  :global(.pc-pin) {
    width: 16px; height: 16px; border-radius: 50%; background: #12b6cf;
    box-shadow: 0 0 12px rgba(18,182,207,0.75), 0 0 28px rgba(18,182,207,0.3);
    border: 2px solid #fff;
    animation: pc-glow 2s ease-in-out infinite alternate;
  }
  @keyframes pc-glow { 0% { box-shadow: 0 0 12px rgba(18,182,207,0.75), 0 0 28px rgba(18,182,207,0.3); } 100% { box-shadow: 0 0 18px rgba(18,182,207,0.95), 0 0 40px rgba(18,182,207,0.45), 0 0 60px rgba(18,182,207,0.15); } }

  /* --- Legend --- */
  .rw-legend {
    display: flex; flex-wrap: wrap; gap: 0.625rem 1rem;
    margin-top: 0.75rem; padding: 0.625rem 1.125rem;
    background: linear-gradient(135deg, rgba(20, 20, 24, 0.82), rgba(14,14,18,0.65));
    backdrop-filter: blur(16px) saturate(1.3);
    -webkit-backdrop-filter: blur(16px) saturate(1.3);
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 2px 12px rgba(0,0,0,0.3), 0 1px 0 rgba(255,255,255,0.04) inset;
  }

  .rw-legend-item {
    display: flex; align-items: center; gap: 7px;
    font-size: 0.6875rem; font-weight: 500; color: rgba(235,235,245,0.55);
    letter-spacing: 0.01em;
  }

  .rw-lg-dot { width: 9px; height: 9px; border-radius: 50%; box-shadow: 0 0 8px currentColor, 0 0 4px currentColor; }
  .rw-lg-pulse { animation: legend-pulse 2.2s ease-in-out infinite; }
  @keyframes legend-pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(0.8); } }
  .rw-lg-ring { width: 9px; height: 9px; border-radius: 50%; border: 1.5px solid; background: transparent; opacity: 0.8; }
  .rw-lg-line { width: 22px; height: 3px; border-radius: 2px; }
  .rw-lg-dash { background: repeating-linear-gradient(90deg, rgba(18,182,207,0.5) 0 5px, transparent 5px 8px) !important; }

  /* --- List panel --- */
  .rw-list-panel {
    margin-top: 1.5rem;
    background: linear-gradient(160deg, rgba(28, 28, 30, 0.6), rgba(18,18,20,0.4));
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.25);
  }

  .rw-list-head {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.75rem 1.125rem; gap: 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.01);
  }

  .rw-list-title {
    font-size: 0.875rem; font-weight: 700; color: rgba(235,235,245,0.88); margin: 0;
    letter-spacing: -0.01em;
  }

  .rw-list-count { font-weight: 400; color: rgba(235,235,245,0.35); margin-left: 4px; }

  .rw-list {
    max-height: 500px; overflow-y: auto;
    scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.08) transparent;
  }
  .rw-list::-webkit-scrollbar { width: 4px; }
  .rw-list::-webkit-scrollbar-track { background: transparent; }
  .rw-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 4px; }
  .rw-list::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.18); }

  :global(.rw-card) {
    display: flex; position: relative; border-bottom: 1px solid rgba(255,255,255,0.035);
    cursor: pointer; transition: all 0.22s cubic-bezier(0.22, 1, 0.36, 1);
  }
  :global(.rw-card:hover) {
    background: rgba(255,255,255,0.04);
    transform: translateX(2px);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.04), 2px 0 20px rgba(0,0,0,0.2);
  }
  :global(.rw-card:last-child) { border-bottom: none; }
  :global(.rw-card-bar) { width: 4px; flex-shrink: 0; border-radius: 0 3px 3px 0; transition: opacity 0.2s ease; }
  :global(.rw-card-body) { flex: 1; min-width: 0; padding: 0.625rem 1rem; }
  :global(.rw-card-top) { display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem; }
  :global(.rw-card-road) {
    font-size: 0.8125rem; font-weight: 600; color: rgba(235,235,245,0.92);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; min-width: 0;
    letter-spacing: -0.005em; transition: color 0.2s ease;
  }
  :global(.rw-card:hover .rw-card-road) { color: #fff; }
  :global(.rw-card-tags) { display: flex; gap: 4px; flex-shrink: 0; flex-wrap: wrap; justify-content: flex-end; }
  :global(.rw-tag) {
    display: inline-block; padding: 2px 8px; border-radius: 100px;
    font-size: 0.5625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; white-space: nowrap; line-height: 1.7;
  }
  :global(.rw-tag-muted) { background: rgba(235,235,245,0.05) !important; color: rgba(235,235,245,0.35) !important; }
  :global(.rw-card-meta) { font-size: 0.6875rem; color: rgba(235,235,245,0.4); margin-top: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  :global(.rw-district-badge) { display: inline-block; padding: 1px 6px; border-radius: 3px; background: rgba(245,158,11,0.12); color: rgba(245,158,11,0.8); font-size: 10px; font-weight: 600; margin-right: 5px; letter-spacing: 0.02em; }
  :global(.rw-sep) { margin: 0 0.25rem; opacity: 0.35; }
  :global(.rw-card-dates) { font-size: 0.65rem; color: rgba(235,235,245,0.35); margin-top: 4px; font-variant-numeric: tabular-nums; }
  :global(.rw-dur-track) { height: 4px; background: rgba(255,255,255,0.055); border-radius: 2px; margin-top: 6px; overflow: hidden; }
  :global(.rw-dur-fill) { height: 100%; border-radius: 2px; transition: width 0.4s cubic-bezier(0.22, 1, 0.36, 1); }
  :global(.rw-card-desc) { font-size: 0.65rem; color: rgba(235,235,245,0.25); margin-top: 5px; line-height: 1.45; }
  :global(.rw-card-link) { display: inline-flex; align-items: center; gap: 3px; font-size: 0.65rem; color: rgba(18,182,207,0.65); text-decoration: none; margin-top: 4px; transition: all 0.18s ease; }
  :global(.rw-card-link:hover) { color: #12b6cf; text-shadow: 0 0 12px rgba(18,182,207,0.4); }
  :global(.rw-list-empty) { padding: 3rem 1rem; text-align: center; color: rgba(235,235,245,0.25); font-size: 0.8125rem; letter-spacing: 0.02em; }
  :global(.rw-list-more) { padding: 0.625rem 1rem; text-align: center; color: rgba(235,235,245,0.2); font-size: 0.7rem; border-top: 1px solid rgba(255,255,255,0.03); }

  /* --- Leaflet dark overrides --- */
  :global(.leaflet-container) { background: #08080a; font-family: Inter, -apple-system, sans-serif; }
  :global(.leaflet-popup-content-wrapper) {
    background: rgba(16, 16, 18, 0.97) !important;
    backdrop-filter: blur(32px) saturate(1.5) !important;
    -webkit-backdrop-filter: blur(32px) saturate(1.5) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    border-radius: 16px !important;
    box-shadow: 0 20px 60px rgba(0,0,0,0.7), 0 8px 20px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.05), inset 0 1px 0 rgba(255,255,255,0.05) !important;
    color: #fff !important;
    animation: popup-enter 0.25s cubic-bezier(0.22, 1, 0.36, 1) forwards !important;
  }
  @keyframes popup-enter { from { opacity: 0; transform: translateY(4px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
  :global(.leaflet-popup-content) { margin: 16px 18px !important; line-height: 1.55 !important; color: #fff !important; }
  :global(.leaflet-popup-tip) { background: rgba(16,16,18,0.97) !important; border: none !important; box-shadow: 2px 2px 6px rgba(0,0,0,0.4) !important; }
  :global(.leaflet-popup-close-button) { color: rgba(235,235,245,0.35) !important; font-size: 20px !important; padding: 10px 12px 0 0 !important; transition: color 0.15s ease, transform 0.15s ease !important; }
  :global(.leaflet-popup-close-button:hover) { color: rgba(235,235,245,0.9) !important; transform: scale(1.15) !important; }
  :global(.ced-tooltip) {
    background: rgba(14,14,16,0.94) !important; border: 1px solid rgba(245,158,11,0.3) !important;
    border-radius: 8px !important; color: rgba(245,158,11,0.9) !important;
    font-size: 11px !important; font-weight: 600 !important; padding: 4px 10px !important;
    box-shadow: 0 6px 20px rgba(0,0,0,0.5), 0 0 0 1px rgba(245,158,11,0.08) !important;
    letter-spacing: 0.02em !important;
  }
  :global(.ward-tooltip) {
    background: rgba(14,14,16,0.94) !important; border: 1px solid rgba(18,182,207,0.3) !important;
    border-radius: 8px !important; color: rgba(18,182,207,0.88) !important;
    font-size: 11px !important; font-weight: 600 !important; padding: 4px 10px !important;
    box-shadow: 0 6px 20px rgba(0,0,0,0.5), 0 0 0 1px rgba(18,182,207,0.08) !important;
    letter-spacing: 0.02em !important;
  }
  :global(.leaflet-control-zoom) { border: none !important; box-shadow: 0 4px 16px rgba(0,0,0,0.5) !important; border-radius: 10px !important; overflow: hidden; }
  :global(.leaflet-control-zoom a) { background: rgba(16,16,18,0.9) !important; color: rgba(235,235,245,0.6) !important; border-color: rgba(255,255,255,0.08) !important; width: 34px !important; height: 34px !important; line-height: 34px !important; font-size: 16px !important; transition: all 0.15s ease !important; }
  :global(.leaflet-control-zoom a:hover) { background: rgba(22,22,24,1) !important; color: #fff !important; transform: scale(1.05) !important; }
  :global(.leaflet-control-attribution) { background: rgba(16,16,18,0.7) !important; color: rgba(235,235,245,0.2) !important; font-size: 9px !important; border-radius: 6px 0 0 0 !important; padding: 2px 6px !important; }
  :global(.leaflet-control-attribution a) { color: rgba(18,182,207,0.5) !important; }

  /* --- Hourly strip --- */
  .rw-hourly {
    padding: 0.5rem 0.875rem;
    background: rgba(22, 22, 26, 0.55);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    margin-bottom: 0.5rem;
  }

  .rw-hourly-header {
    display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;
  }

  .rw-hourly-title {
    font-size: 0.68rem; font-weight: 600; color: rgba(235, 235, 245, 0.4);
    display: flex; align-items: center; gap: 5px;
    text-transform: uppercase; letter-spacing: 0.06em;
  }

  .rw-hourly-actions { display: flex; align-items: center; gap: 8px; }

  .rw-hourly-info {
    font-size: 0.68rem; color: rgba(18, 182, 207, 0.7); font-weight: 500;
    font-variant-numeric: tabular-nums; letter-spacing: 0.01em;
  }

  .rw-hourly-chart {
    display: flex; align-items: flex-end; gap: 1.5px;
    height: 48px; position: relative;
  }

  :global(.rw-hour-bar) {
    flex: 1; min-width: 0;
    background: rgba(18, 182, 207, 0.5);
    border-radius: 2px 2px 0 0;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  :global(.rw-hour-bar:hover) {
    background: rgba(18, 182, 207, 0.65) !important;
    filter: drop-shadow(0 0 6px rgba(18,182,207,0.3));
    transform: scaleY(1.15); transform-origin: bottom;
  }

  :global(.rw-hour-rush) { background: rgba(239, 68, 68, 0.45); }
  :global(.rw-hour-rush:hover) { background: rgba(239, 68, 68, 0.7) !important; filter: drop-shadow(0 0 6px rgba(239,68,68,0.3)); }
  :global(.rw-hour-school) { background: rgba(245, 158, 11, 0.55); }
  :global(.rw-hour-school:hover) { background: rgba(245, 158, 11, 0.75) !important; filter: drop-shadow(0 0 6px rgba(245,158,11,0.3)); }

  :global(.rw-hour-selected) {
    background: rgba(18, 182, 207, 0.75) !important;
    box-shadow: 0 0 10px rgba(18, 182, 207, 0.5), 0 0 3px rgba(18,182,207,0.8);
    filter: drop-shadow(0 -2px 4px rgba(18,182,207,0.3));
  }
  :global(.rw-hour-rush.rw-hour-selected) { background: rgba(239, 68, 68, 0.7) !important; box-shadow: 0 0 10px rgba(239,68,68,0.5); }
  :global(.rw-hour-school.rw-hour-selected) { background: rgba(245, 158, 11, 0.7) !important; box-shadow: 0 0 10px rgba(245,158,11,0.5); }

  :global(.rw-hour-now) {
    position: absolute; bottom: 0; width: 2px;
    height: calc(100% + 6px);
    background: rgba(255, 255, 255, 0.85);
    pointer-events: none; z-index: 2;
  }
  :global(.rw-hour-now::before) {
    content: ''; position: absolute; top: -1px; left: -3px;
    border-left: 4px solid transparent; border-right: 4px solid transparent;
    border-top: 5px solid #fff;
  }

  .rw-hourly-labels {
    display: flex; justify-content: space-between;
    margin-top: 3px; padding: 0 1px;
    font-size: 0.5625rem; color: rgba(235, 235, 245, 0.2);
    font-variant-numeric: tabular-nums;
  }

  :global(.rw-card-hours) { color: rgba(18, 182, 207, 0.5); font-weight: 500; }

  /* --- Capacity bar in cards --- */
  :global(.rw-card-capacity) {
    display: flex; align-items: center; gap: 8px; margin-top: 5px;
  }
  :global(.rw-cap-track) {
    flex: 1; height: 4px; background: rgba(255,255,255,0.06); border-radius: 2px; overflow: hidden;
  }
  :global(.rw-cap-fill) {
    height: 100%; border-radius: 2px; transition: width 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  :global(.rw-cap-label) {
    font-size: 0.6rem; font-weight: 600; white-space: nowrap; font-variant-numeric: tabular-nums;
  }

  /* --- Card hover left-border color --- */
  :global(.rw-card:hover .rw-card-bar) { opacity: 1 !important; box-shadow: 2px 0 8px rgba(0,0,0,0.3); }

  /* --- Search clear button --- */
  .rw-search-clear {
    display: flex; align-items: center; justify-content: center;
    width: 18px; height: 18px; border: none; background: rgba(255,255,255,0.08);
    border-radius: 50%; color: rgba(235,235,245,0.5); font-size: 14px; line-height: 1;
    cursor: pointer; flex-shrink: 0; transition: all 0.15s ease; padding: 0;
  }
  .rw-search-clear:hover { background: rgba(255,255,255,0.15); color: #fff; }

  /* --- Reset filters button --- */
  .rw-reset-btn {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 12px; border: 1px solid rgba(239,68,68,0.25); border-radius: 100px;
    background: rgba(239,68,68,0.08); color: rgba(239,68,68,0.8);
    font-size: 0.7rem; font-weight: 600; cursor: pointer; white-space: nowrap;
    transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
    animation: rw-fade-in 0.2s ease;
  }
  .rw-reset-btn:hover {
    background: rgba(239,68,68,0.15); border-color: rgba(239,68,68,0.4);
    color: #ef4444; transform: translateY(-1px);
  }
  .rw-reset-btn:active { transform: scale(0.96); }
  @keyframes rw-fade-in { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }

  /* --- Staleness warning --- */
  .rw-stale-warning {
    display: flex; align-items: center; gap: 8px;
    padding: 0.5rem 0.875rem;
    background: rgba(245,158,11,0.1);
    border: 1px solid rgba(245,158,11,0.25);
    border-radius: 10px; margin-bottom: 0.5rem;
    color: rgba(245,158,11,0.9); font-size: 0.75rem; font-weight: 500;
    animation: rw-fade-in 0.3s ease;
  }

  /* --- Toast notification --- */
  .rw-toast {
    position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%) translateY(10px);
    padding: 0.625rem 1.25rem;
    background: rgba(16,16,18,0.95); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px; color: rgba(235,235,245,0.85);
    font-size: 0.8rem; font-weight: 500; z-index: 10000;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    opacity: 0; transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }
  .rw-toast.rw-toast-show { opacity: 1; transform: translateX(-50%) translateY(0); }

  /* --- Loading bar --- */
  .rw-loading-bar {
    width: 120px; height: 3px; background: rgba(255,255,255,0.06);
    border-radius: 2px; overflow: hidden; margin-top: 8px;
  }
  .rw-loading-bar-fill {
    height: 100%; width: 0; background: linear-gradient(90deg, #12b6cf, #f59e0b);
    border-radius: 2px; transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* --- Toggle hints --- */
  .rw-toggle-hint {
    font-size: 0.55rem; color: rgba(235,235,245,0.2);
    font-weight: 400; display: none;
  }
  .rw-toggle:hover .rw-toggle-hint { display: inline; }

  /* --- Keyboard hint --- */
  .rw-keyboard-hint {
    font-size: 0.625rem; color: rgba(235,235,245,0.15);
    text-align: center; margin-top: 0.375rem;
    letter-spacing: 0.02em;
  }
  .rw-keyboard-hint kbd {
    display: inline-block; padding: 1px 5px;
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 3px; font-family: inherit; font-size: 0.6rem;
    color: rgba(235,235,245,0.3);
  }

  /* --- Pagination --- */
  .rw-pagination {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.625rem 1rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.015);
  }
  .rw-page-info {
    font-size: 0.7rem; color: rgba(235,235,245,0.35);
    font-variant-numeric: tabular-nums;
  }
  .rw-page-btns { display: flex; align-items: center; gap: 8px; }
  .rw-page-btn {
    padding: 5px 12px; border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px; background: transparent;
    color: rgba(235,235,245,0.6); font-size: 0.7rem; font-weight: 500;
    cursor: pointer; transition: all 0.18s ease;
  }
  .rw-page-btn:hover:not(:disabled) {
    background: rgba(255,255,255,0.06); color: #fff; transform: translateY(-1px);
  }
  .rw-page-btn:disabled {
    opacity: 0.25; cursor: not-allowed;
  }
  .rw-page-num {
    font-size: 0.7rem; color: rgba(235,235,245,0.5);
    font-weight: 600; font-variant-numeric: tabular-nums; min-width: 80px; text-align: center;
  }

  /* --- Improved shimmer --- */
  .rw-stat-card.rw-shimmer {
    overflow: hidden;
  }
  .rw-stat-card.rw-shimmer::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.03) 50%, transparent 100%);
    animation: rw-shimmer-sweep 2s ease-in-out infinite;
  }
  @keyframes rw-shimmer-sweep { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }

  /* --- Accessibility --- */
  @media (prefers-reduced-motion: reduce) {
    .rw-stat-card, .rw-chip, :global(.rw-card) { transition: none !important; }
    .rw-map-glow { animation: none !important; }
    :global(.rw-marker-pulse) { animation: none !important; }
    .rw-pulse-dot, .rw-lg-pulse, .rw-ml-pulse { animation: none !important; }
    :global(.pc-pin) { animation: none !important; }
    :global(.leaflet-popup-content-wrapper) { animation: none !important; }
  }

  /* --- Works over time chart --- */
  .rw-works-chart-section {
    padding: 0.5rem 0.875rem;
    background: rgba(22, 22, 26, 0.55);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    margin-bottom: 0.5rem;
  }

  .rw-works-chart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
    flex-wrap: wrap;
    gap: 6px;
  }

  .rw-works-chart-title {
    font-size: 0.68rem;
    font-weight: 600;
    color: rgba(235, 235, 245, 0.4);
    display: flex;
    align-items: center;
    gap: 5px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .rw-works-chart-legend {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .rw-wc-legend {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.6rem;
    color: rgba(235, 235, 245, 0.4);
    white-space: nowrap;
  }

  .rw-wc-swatch {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .rw-wc-line {
    display: inline-block;
    width: 14px;
    height: 0;
    flex-shrink: 0;
  }

  .rw-works-canvas-wrap {
    position: relative;
  }

  .rw-works-canvas {
    width: 100%;
    height: 160px;
    display: block;
    cursor: crosshair;
  }

  .rw-works-chart-labels {
