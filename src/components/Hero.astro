---
import StatCard from './StatCard.astro';
---

<section class="hero">
  <div class="hero-bg-glow"></div>
  <div class="hero-content">
    <div class="hero-text">
      <span class="hero-eyebrow">
        <span class="pulse-dot"></span>
        Lancashire County Councillor &middot; Reform UK
      </span>

      <h1>
        Tom <span class="gradient">Pickup</span>
      </h1>

      <p class="hero-role">
        Your councillor for <strong>Padiham &amp; Burnley West</strong>
      </p>

      <p class="hero-subtitle">
        We inherited a &pound;28 million overspend and cut it to near zero.
        Delivered the lowest council tax rise in 12 years. Secured &pound;72M for highways.
        Now we&rsquo;re rebuilding Lancashire properly.
      </p>

      <div class="hero-actions">
        <a href="/contact/" class="btn btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          Get in Touch
        </a>
        <a href="/about/" class="btn btn-secondary">
          What We&rsquo;ve Delivered
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      </div>
    </div>

    <div class="hero-photo-wrap">
      <div class="hero-photo-glow"></div>
      <div class="hero-photo">
        <img
          src="/images/headshot.jpg"
          alt="Tom Pickup, Lancashire County Councillor for Padiham and Burnley West"
          width="400"
          height="400"
          loading="eager"
        />
      </div>
      <div class="hero-photo-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        Elected May 2025
      </div>
    </div>
  </div>

  <div class="hero-stats-wrap">
    <div class="hero-stats">
      <StatCard
        icon='<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>'
        value="3.80%"
        label="Lowest CT Rise in 12 Years"
        color="#30d158"
      />
      <StatCard
        icon='<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>'
        value="&pound;28M&rarr;&pound;6M"
        label="Overspend Corrected"
        color="#12b6cf"
      />
      <StatCard
        icon='<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>'
        value="53/84"
        label="Reform Seats at LCC"
        color="#bf5af2"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 7rem 1.5rem 3rem;
  }

  .hero-bg-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-bg-glow::before,
  .hero-bg-glow::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.15;
    animation: gradientShift 12s ease-in-out infinite alternate;
  }

  .hero-bg-glow::before {
    width: 600px;
    height: 600px;
    top: -15%;
    right: -10%;
    background: radial-gradient(circle, #12b6cf 0%, transparent 70%);
  }

  .hero-bg-glow::after {
    width: 500px;
    height: 500px;
    bottom: -10%;
    left: -8%;
    background: radial-gradient(circle, #bf5af2 0%, transparent 70%);
    animation-delay: -6s;
    animation-direction: alternate-reverse;
  }

  @keyframes gradientShift {
    0% { transform: translate(0, 0) scale(1); opacity: 0.12; }
    50% { transform: translate(30px, -20px) scale(1.1); opacity: 0.2; }
    100% { transform: translate(-20px, 15px) scale(0.95); opacity: 0.1; }
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-2xl);
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    width: 100%;
  }

  /* ---- Text side ---- */
  .hero-text {
    min-width: 0;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    border-radius: 9999px;
    background: rgba(18, 182, 207, 0.12);
    border: 1px solid rgba(18, 182, 207, 0.2);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #12b6cf;
    margin-bottom: 1.5rem;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #30d158;
    position: relative;
    flex-shrink: 0;
  }

  .pulse-dot::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    background: rgba(48, 209, 88, 0.4);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.4; }
    50% { transform: scale(1.6); opacity: 0; }
  }

  h1 {
    font-size: clamp(2.75rem, 5.5vw, 4rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: #fff;
    margin: 0 0 0.75rem;
  }

  h1 .gradient {
    background: linear-gradient(90deg, #12b6cf, #64d2ff, #bf5af2, #12b6cf);
    background-size: 300% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: textShimmer 6s ease infinite;
  }

  @keyframes textShimmer {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .hero-role {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin: 0 0 1.25rem;
    max-width: none;
  }

  .hero-role strong {
    color: var(--text-primary);
  }

  .hero-subtitle {
    font-size: 1.0625rem;
    color: rgba(235, 235, 245, 0.55);
    max-width: 520px;
    margin: 0 0 2rem;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 12px;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    border: none;
    line-height: 1;
    background-image: none;
  }

  .btn:hover {
    background-image: none;
    background-size: 0;
  }

  .btn-primary {
    background: #12b6cf;
    color: #000;
    box-shadow: 0 4px 20px rgba(18, 182, 207, 0.3);
  }

  .btn-primary:hover {
    background: #14c8e3;
    box-shadow: 0 8px 32px rgba(18, 182, 207, 0.45);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: transparent;
    color: rgba(235, 235, 245, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.2);
    color: #fff;
    transform: translateY(-2px);
  }

  /* ---- Photo side ---- */
  .hero-photo-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-photo-glow {
    position: absolute;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(18, 182, 207, 0.2) 0%, transparent 70%);
    filter: blur(40px);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: photoGlow 4s ease-in-out infinite alternate;
  }

  @keyframes photoGlow {
    0% { opacity: 0.6; transform: translate(-50%, -50%) scale(1); }
    100% { opacity: 1; transform: translate(-50%, -50%) scale(1.08); }
  }

  .hero-photo {
    position: relative;
    width: 260px;
    height: 260px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid rgba(18, 182, 207, 0.3);
    box-shadow: 0 0 40px rgba(18, 182, 207, 0.15), 0 20px 60px rgba(0, 0, 0, 0.4);
    transition: border-color var(--transition-normal), box-shadow var(--transition-normal);
  }

  .hero-photo:hover {
    border-color: rgba(18, 182, 207, 0.5);
    box-shadow: 0 0 60px rgba(18, 182, 207, 0.25), 0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-photo-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: var(--space-md);
    padding: 6px 14px;
    border-radius: 9999px;
    background: rgba(48, 209, 88, 0.1);
    border: 1px solid rgba(48, 209, 88, 0.2);
    font-size: 0.75rem;
    font-weight: 600;
    color: #30d158;
    letter-spacing: 0.02em;
  }

  .hero-photo-badge svg {
    flex-shrink: 0;
  }

  /* ---- Stats strip ---- */
  .hero-stats-wrap {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 3rem auto 0;
    width: 100%;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .hero {
      padding: 6rem 1rem 2rem;
      min-height: auto;
    }

    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-xl);
    }

    .hero-text {
      order: 2;
    }

    .hero-photo-wrap {
      order: 1;
    }

    .hero-subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-photo {
      width: 200px;
      height: 200px;
    }

    .hero-photo-glow {
      width: 240px;
      height: 240px;
    }

    h1 {
      font-size: clamp(2.25rem, 6vw, 3rem);
    }
  }

  @media (max-width: 768px) {
    .hero-stats {
      grid-template-columns: repeat(2, 1fr);
    }

    .hero-actions {
      flex-direction: column;
      width: 100%;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .hero-photo {
      width: 160px;
      height: 160px;
    }

    .hero-photo-glow {
      width: 200px;
      height: 200px;
    }

    .hero-stats {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg-glow::before,
    .hero-bg-glow::after {
      animation: none;
    }

    h1 .gradient {
      animation: none;
    }

    .pulse-dot::after {
      animation: none;
    }

    .hero-photo-glow {
      animation: none;
    }
  }
</style>
