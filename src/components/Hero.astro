---
import StatCard from './StatCard.astro';
---

<section class="hero">
  <div class="hero-content">
    <span class="hero-eyebrow">
      <span class="pulse-dot"></span>
      Lancashire County Councillor &middot; Reform UK
    </span>

    <h1>
      Fighting for<br />
      <span class="gradient">Padiham &amp; Burnley West</span>
    </h1>

    <p class="hero-subtitle">
      I inherited a &pound;28 million overspend and cut it to near zero.
      Delivered the lowest council tax rise in a decade. Saved all five care homes.
    </p>

    <div class="hero-actions">
      <a href="/contact/" class="btn btn-primary">Get in Touch</a>
      <a
        href="/news/"
        class="btn btn-secondary"
      >
        See What We&rsquo;ve Done
      </a>
    </div>

    <div class="hero-stats">
      <StatCard
        icon='<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>'
        value="3.80%"
        label="Lowest CT Rise in a Decade"
        color="#30d158"
      />
      <StatCard
        icon='<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>'
        value="&pound;62M"
        label="Savings Delivered"
        color="#12b6cf"
      />
      <StatCard
        icon='<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>'
        value="&pound;28M&rarr;&pound;6M"
        label="Overspend Corrected"
        color="#bf5af2"
      />
    </div>

    <!-- Council Tax Timeline Mini-Chart -->
    <div class="hero-chart">
      <span class="hero-chart-label">Council Tax Rises at LCC, 9 Years</span>
      <svg class="ct-chart" viewBox="0 0 314 56" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Bar chart showing council tax rises from 2018 to 2027">
        <rect x="4" y="4" width="28" height="32" rx="4" fill="#0087DC" opacity="0.85"><title>2018/19: 5.99% (Conservative)</title></rect>
        <rect x="38" y="14" width="28" height="22" rx="4" fill="#0087DC" opacity="0.85"><title>2019/20: 3.99% (Conservative)</title></rect>
        <rect x="72" y="14" width="28" height="22" rx="4" fill="#0087DC" opacity="0.85"><title>2020/21: 3.99% (Conservative)</title></rect>
        <rect x="106" y="14" width="28" height="22" rx="4" fill="#0087DC" opacity="0.85"><title>2021/22: 3.99% (Conservative)</title></rect>
        <rect x="140" y="14" width="28" height="22" rx="4" fill="#0087DC" opacity="0.85"><title>2022/23: 3.99% (Conservative)</title></rect>
        <rect x="174" y="14" width="28" height="22" rx="4" fill="#0087DC" opacity="0.85"><title>2023/24: 3.99% (Conservative)</title></rect>
        <rect x="208" y="10" width="28" height="26" rx="4" fill="#0087DC" opacity="0.85"><title>2024/25: 4.99% (Conservative)</title></rect>
        <rect x="242" y="10" width="28" height="26" rx="4" fill="#ff9f0a" opacity="0.85"><title>2025/26: 4.99% (NOC)</title></rect>
        <rect x="276" y="16" width="28" height="20" rx="4" fill="#12b6cf"><title>2026/27: 3.80% (Reform)</title></rect>
        <text x="18" y="52" text-anchor="middle" fill="#636366" font-size="7" font-weight="500">18</text>
        <text x="52" y="52" text-anchor="middle" fill="#636366" font-size="7" font-weight="500">19</text>
        <text x="86" y="52" text-anchor="middle" fill="#636366" font-size="7" font-weight="500">20</text>
        <text x="120" y="52" text-anchor="middle" fill="#636366" font-size="7" font-weight="500">21</text>
        <text x="154" y="52" text-anchor="middle" fill="#636366" font-size="7" font-weight="500">22</text>
        <text x="188" y="52" text-anchor="middle" fill="#636366" font-size="7" font-weight="500">23</text>
        <text x="222" y="52" text-anchor="middle" fill="#636366" font-size="7" font-weight="500">24</text>
        <text x="256" y="52" text-anchor="middle" fill="#ff9f0a" font-size="7" font-weight="500">25</text>
        <text x="290" y="52" text-anchor="middle" fill="#12b6cf" font-size="7" font-weight="700">26</text>
      </svg>
      <div class="hero-chart-legend">
        <span class="legend-dot" style="background: #0087DC;"></span>
        <span>Conservative</span>
        <span class="legend-dot" style="background: #ff9f0a;"></span>
        <span>NOC (4.99%)</span>
        <span class="legend-dot" style="background: #12b6cf;"></span>
        <span>Reform (3.80%)</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    padding: 8rem 1.5rem 5rem;
  }

  .hero::before,
  .hero::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(100px);
    opacity: 0.15;
    animation: gradientShift 12s ease-in-out infinite alternate;
  }

  .hero::before {
    width: 600px;
    height: 600px;
    top: -15%;
    right: -10%;
    background: radial-gradient(circle, #12b6cf 0%, transparent 70%);
  }

  .hero::after {
    width: 500px;
    height: 500px;
    bottom: -10%;
    left: -8%;
    background: radial-gradient(circle, #12b6cf 0%, transparent 70%);
    animation-delay: -6s;
    animation-direction: alternate-reverse;
  }

  @keyframes gradientShift {
    0% {
      transform: translate(0, 0) scale(1);
      opacity: 0.12;
    }
    50% {
      transform: translate(30px, -20px) scale(1.1);
      opacity: 0.2;
    }
    100% {
      transform: translate(-20px, 15px) scale(0.95);
      opacity: 0.1;
    }
  }

  .hero-content {
    max-width: 800px;
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    border-radius: 9999px;
    background: rgba(18, 182, 207, 0.12);
    border: 1px solid rgba(18, 182, 207, 0.2);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #12b6cf;
    margin-bottom: 1.5rem;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #30d158;
    position: relative;
    flex-shrink: 0;
  }

  .pulse-dot::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    background: rgba(48, 209, 88, 0.4);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
      opacity: 0.4;
    }
    50% {
      transform: scale(1.6);
      opacity: 0;
    }
  }

  h1 {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0 0 1.25rem;
  }

  h1 .gradient {
    background: linear-gradient(90deg, #12b6cf, #64d2ff, #bf5af2, #12b6cf);
    background-size: 300% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: textShimmer 6s ease infinite;
  }

  @keyframes textShimmer {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: rgba(235, 235, 245, 0.6);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 12px;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    border: none;
    line-height: 1;
  }

  .btn-primary {
    background: #12b6cf;
    color: #000;
    box-shadow: 0 4px 20px rgba(18, 182, 207, 0.3);
  }

  .btn-primary:hover {
    background: #14c8e3;
    box-shadow: 0 8px 32px rgba(18, 182, 207, 0.45);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: transparent;
    color: rgba(235, 235, 245, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.2);
    color: #fff;
    transform: translateY(-2px);
  }

  .btn-secondary svg {
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  .btn-secondary:hover svg {
    opacity: 1;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 640px;
    margin: 0 auto;
  }

  /* Council Tax Mini Chart */
  .hero-chart {
    max-width: 440px;
    margin: 2rem auto 0;
    text-align: center;
  }

  .hero-chart-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(235, 235, 245, 0.35);
    margin-bottom: 0.75rem;
  }

  .ct-chart {
    width: 100%;
    height: auto;
    max-height: 56px;
  }

  .ct-chart rect {
    transition: opacity 0.2s ease;
  }

  .ct-chart:hover rect {
    opacity: 0.5;
  }

  .ct-chart rect:hover {
    opacity: 1 !important;
  }

  .hero-chart-legend {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 0.5rem;
    font-size: 0.625rem;
    color: rgba(235, 235, 245, 0.35);
  }

  .legend-dot {
    width: 6px;
    height: 6px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .hero-chart-legend span:nth-child(3) {
    margin-left: 8px;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 6rem 1rem 3rem;
      min-height: auto;
    }

    h1 {
      font-size: 2.25rem;
    }

    .hero-subtitle {
      font-size: 1rem;
      margin-bottom: 2rem;
    }

    .hero-actions {
      flex-direction: column;
      margin-bottom: 2rem;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }

    .hero-stats {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .hero-chart {
      max-width: 100%;
      margin-top: 1.5rem;
    }

    .hero::before {
      width: 300px;
      height: 300px;
    }

    .hero::after {
      width: 250px;
      height: 250px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero::before,
    .hero::after {
      animation: none;
    }

    h1 .gradient {
      animation: none;
    }

    .pulse-dot::after {
      animation: none;
    }
  }
</style>
