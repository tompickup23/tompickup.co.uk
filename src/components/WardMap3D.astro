---
import wardData from '../data/burnley-wards.json';

interface Props {
  activeWard?: string;
  size?: 'full' | 'mini';
}

const { activeWard = '', size = 'full' } = Astro.props;

// Coordinate bounds for Burnley
const BOUNDS = {
  minLng: -2.3500,
  maxLng: -2.1050,
  minLat: 53.7180,
  maxLat: 53.8300,
};

const WIDTH = 800;
const HEIGHT = 700;
const PAD = 20;

function projectLng(lng: number): number {
  return PAD + ((lng - BOUNDS.minLng) / (BOUNDS.maxLng - BOUNDS.minLng)) * (WIDTH - 2 * PAD);
}

function projectLat(lat: number): number {
  return PAD + ((BOUNDS.maxLat - lat) / (BOUNDS.maxLat - BOUNDS.minLat)) * (HEIGHT - 2 * PAD);
}

function coordsToPath(coords: number[][]): string {
  return coords
    .map((c, i) => `${i === 0 ? 'M' : 'L'}${projectLng(c[0]).toFixed(1)},${projectLat(c[1]).toFixed(1)}`)
    .join(' ') + 'Z';
}

// Build ward SVG data
const wards = Object.entries(wardData.wards).map(([slug, ward]: [string, any]) => {
  const coords = ward.boundary?.coordinates?.[0] || [];
  const path = coordsToPath(coords);
  const cx = projectLng(ward.centroid[0]);
  const cy = projectLat(ward.centroid[1]);
  const isActive = slug === activeWard;
  const depDecile = ward.deprivation?.avg_imd_decile || 5;
  const electorate = ward.elections?.electorate || 0;

  return {
    slug,
    name: ward.name,
    path,
    cx,
    cy,
    isActive,
    party: ward.primary_party,
    partyColor: ward.party_color,
    depDecile,
    depLevel: ward.deprivation?.deprivation_level || 'Unknown',
    electorate,
  };
});
---

<div class={`ward-map-container ${size === 'mini' ? 'ward-map-mini' : ''}`} data-ward-map>
  <svg
    viewBox={`0 0 ${WIDTH} ${HEIGHT}`}
    class="ward-map-svg"
    aria-label="Interactive map of Burnley borough wards"
    role="img"
  >
    <defs>
      <filter id="ward-glow">
        <feGaussianBlur stdDeviation="4" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
      <filter id="ward-shadow">
        <feDropShadow dx="2" dy="4" stdDeviation="3" flood-color="rgba(0,0,0,0.5)" flood-opacity="0.6" />
      </filter>
      <linearGradient id="ward-edge" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="rgba(255,255,255,0.12)" />
        <stop offset="100%" stop-color="rgba(255,255,255,0.02)" />
      </linearGradient>
    </defs>

    {/* Shadow layer */}
    {wards.map((w) => (
      <path
        d={w.path}
        class="ward-shadow-path"
        transform="translate(3, 5)"
      />
    ))}

    {/* Ward faces */}
    {wards.map((w) => (
      <a href={w.isActive ? undefined : `/wards/${w.slug}/`} class="ward-link" data-ward={w.slug}>
        <g class={`ward-group ${w.isActive ? 'ward-active' : ''}`} data-slug={w.slug} data-party-color={w.partyColor}>
          <path
            d={w.path}
            class="ward-face"
            style={`--party-color: ${w.partyColor}`}
          />
          <path
            d={w.path}
            class="ward-edge"
            fill="url(#ward-edge)"
          />
          {w.isActive && (
            <path
              d={w.path}
              class="ward-active-glow"
              filter="url(#ward-glow)"
            />
          )}
          <title>{w.name}</title>
        </g>
      </a>
    ))}

    {/* Ward labels (full size only) */}
    {size === 'full' && wards.map((w) => (
      <text
        x={w.cx}
        y={w.cy}
        class={`ward-label ${w.isActive ? 'ward-label-active' : ''}`}
        text-anchor="middle"
        dominant-baseline="central"
        pointer-events="none"
      >
        {w.name.replace(/ with /g, '\nw/ ').split('\n').map((line: string, i: number) => (
          <tspan x={w.cx} dy={i === 0 ? '0' : '1.1em'}>{line}</tspan>
        ))}
      </text>
    ))}
  </svg>

  {/* Tooltip */}
  <div class="ward-tooltip" id="ward-tooltip" aria-hidden="true">
    <span class="tooltip-name"></span>
    <span class="tooltip-party"></span>
    <span class="tooltip-stat"></span>
  </div>

  {/* Data overlay toggles (full size only) */}
  {size === 'full' && (
    <div class="map-overlays">
      <button class="overlay-btn overlay-active" data-overlay="party">Party Control</button>
      <button class="overlay-btn" data-overlay="deprivation">Deprivation</button>
      <button class="overlay-btn" data-overlay="neutral">Neutral</button>
    </div>
  )}
</div>

<script>
  function initWardMap() {
    const maps = document.querySelectorAll('[data-ward-map]');

    maps.forEach((mapContainer) => {
      const tooltip = mapContainer.querySelector('#ward-tooltip') as HTMLElement;
      const groups = mapContainer.querySelectorAll('.ward-group');
      const overlayBtns = mapContainer.querySelectorAll('.overlay-btn');

      // Ward data embedded for tooltips
      const wardInfo: Record<string, { name: string; party: string; depLevel: string; electorate: number }> = {};
      const dataScript = document.getElementById('ward-map-data');
      if (dataScript) {
        try { Object.assign(wardInfo, JSON.parse(dataScript.textContent || '{}')); } catch {}
      }

      // Hover interactions
      groups.forEach((g) => {
        const el = g as HTMLElement;
        const slug = el.dataset.slug || '';

        el.addEventListener('mouseenter', (e) => {
          if (!tooltip) return;
          const info = wardInfo[slug];
          const nameEl = tooltip.querySelector('.tooltip-name');
          const partyEl = tooltip.querySelector('.tooltip-party');
          const statEl = tooltip.querySelector('.tooltip-stat');
          if (nameEl && info) nameEl.textContent = info.name;
          if (partyEl && info) partyEl.textContent = info.party;
          if (statEl && info) statEl.textContent = `${info.electorate.toLocaleString()} voters · ${info.depLevel}`;

          tooltip.classList.add('visible');
          tooltip.setAttribute('aria-hidden', 'false');
        });

        el.addEventListener('mousemove', (e) => {
          if (!tooltip) return;
          const rect = mapContainer.getBoundingClientRect();
          const x = (e as MouseEvent).clientX - rect.left;
          const y = (e as MouseEvent).clientY - rect.top;
          tooltip.style.left = `${x + 12}px`;
          tooltip.style.top = `${y - 10}px`;
        });

        el.addEventListener('mouseleave', () => {
          if (!tooltip) return;
          tooltip.classList.remove('visible');
          tooltip.setAttribute('aria-hidden', 'true');
        });
      });

      // Data overlay toggles
      overlayBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          overlayBtns.forEach((b) => b.classList.remove('overlay-active'));
          btn.classList.add('overlay-active');
          const mode = (btn as HTMLElement).dataset.overlay;
          const svg = mapContainer.querySelector('.ward-map-svg');
          if (svg) {
            svg.setAttribute('data-overlay', mode || 'party');
          }
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initWardMap);
  initWardMap();
</script>

{/* Embed ward info for tooltips */}
<script type="application/json" id="ward-map-data" set:html={JSON.stringify(
  Object.fromEntries(
    Object.entries(wardData.wards).map(([slug, ward]: [string, any]) => [
      slug,
      {
        name: ward.name,
        party: ward.primary_party,
        depLevel: ward.deprivation?.deprivation_level || 'Unknown',
        electorate: ward.elections?.electorate || 0,
      }
    ])
  )
)} />

<style>
  /* ---- Container ---- */
  .ward-map-container {
    position: relative;
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    perspective: 1000px;
    padding: 1.5rem 0 0;
  }

  .ward-map-mini {
    max-width: 400px;
    padding: 0.5rem 0 0;
  }

  /* ---- 3D Transform ---- */
  .ward-map-svg {
    width: 100%;
    height: auto;
    transform: rotateX(40deg) rotateZ(-2deg);
    transform-style: preserve-3d;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    filter: drop-shadow(0 24px 48px rgba(0, 0, 0, 0.5))
            drop-shadow(0 8px 16px rgba(0, 0, 0, 0.3));
    will-change: transform;
  }

  .ward-map-mini .ward-map-svg {
    transform: rotateX(35deg) rotateZ(-1deg);
    filter: drop-shadow(0 16px 32px rgba(0, 0, 0, 0.4));
  }

  /* ---- Ambient glow beneath map ---- */
  .ward-map-container::before {
    content: '';
    position: absolute;
    bottom: -10%;
    left: 10%;
    right: 10%;
    height: 50%;
    background: radial-gradient(ellipse at 50% 100%, rgba(18, 182, 207, 0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: -1;
  }

  /* ---- Shadow layer ---- */
  .ward-shadow-path {
    fill: rgba(0, 0, 0, 0.4);
    stroke: none;
    filter: blur(1px);
  }

  /* ---- Ward faces ---- */
  .ward-face {
    fill: rgba(28, 28, 30, 0.85);
    stroke: rgba(255, 255, 255, 0.12);
    stroke-width: 1.2;
    transition: fill 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                stroke 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                stroke-width 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                filter 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }

  .ward-edge {
    stroke: none;
    pointer-events: none;
    opacity: 0.5;
  }

  /* ---- Hover state ---- */
  .ward-group:hover .ward-face {
    fill: rgba(18, 182, 207, 0.18);
    stroke: rgba(18, 182, 207, 0.8);
    stroke-width: 2;
    filter: drop-shadow(0 0 10px rgba(18, 182, 207, 0.35))
            drop-shadow(0 0 24px rgba(18, 182, 207, 0.15));
  }

  .ward-group:hover {
    transform: translateY(-5px);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .ward-group:hover .ward-edge {
    opacity: 0.85;
  }

  /* ---- Active state ---- */
  .ward-active .ward-face {
    fill: rgba(18, 182, 207, 0.22);
    stroke: rgba(18, 182, 207, 0.9);
    stroke-width: 2.5;
    filter: drop-shadow(0 0 12px rgba(18, 182, 207, 0.4));
  }

  .ward-active .ward-edge {
    opacity: 0.9;
  }

  .ward-active-glow {
    fill: rgba(18, 182, 207, 0.12);
    stroke: none;
    animation: wardPulse 3s ease-in-out infinite;
  }

  @keyframes wardPulse {
    0%, 100% { opacity: 0.2; filter: blur(0px); }
    50% { opacity: 0.55; filter: blur(2px); }
  }

  /* ---- Party overlay mode ---- */
  .ward-map-svg[data-overlay="party"] .ward-face {
    fill: color-mix(in srgb, var(--party-color) 28%, rgba(28, 28, 30, 0.85));
    stroke: color-mix(in srgb, var(--party-color) 60%, transparent);
    stroke-width: 1.5;
  }

  .ward-map-svg[data-overlay="party"] .ward-group:hover .ward-face {
    fill: color-mix(in srgb, var(--party-color) 50%, rgba(28, 28, 30, 0.7));
    stroke: var(--party-color);
    stroke-opacity: 1;
    filter: drop-shadow(0 0 12px color-mix(in srgb, var(--party-color) 40%, transparent));
  }

  /* ---- Deprivation overlay mode ---- */
  .ward-map-svg[data-overlay="deprivation"] .ward-face {
    stroke: rgba(255, 255, 255, 0.08);
    stroke-width: 1;
  }

  .ward-map-svg[data-overlay="deprivation"] .ward-group:hover .ward-face {
    stroke: rgba(255, 255, 255, 0.3);
    stroke-width: 1.5;
  }

  /* ---- Neutral overlay mode ---- */
  .ward-map-svg[data-overlay="neutral"] .ward-face {
    fill: rgba(38, 38, 42, 0.85);
    stroke: rgba(255, 255, 255, 0.08);
  }

  .ward-map-svg[data-overlay="neutral"] .ward-group:hover .ward-face {
    fill: rgba(18, 182, 207, 0.12);
    stroke: rgba(18, 182, 207, 0.6);
    filter: drop-shadow(0 0 8px rgba(18, 182, 207, 0.2));
  }

  /* ---- Labels ---- */
  .ward-label {
    font-size: 8.5px;
    font-weight: 700;
    fill: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    paint-order: stroke;
    stroke: rgba(0, 0, 0, 0.7);
    stroke-width: 3px;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: fill 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ward-group:hover + text.ward-label,
  .ward-label-active {
    fill: rgba(255, 255, 255, 0.95);
  }

  /* ---- Links ---- */
  .ward-link {
    text-decoration: none;
    background-image: none;
  }

  .ward-link:hover {
    background-image: none;
    background-size: 0;
  }

  /* ---- Tooltip ---- */
  .ward-tooltip {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 12px 16px;
    background: rgba(9, 9, 11, 0.94);
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5),
                0 2px 8px rgba(0, 0, 0, 0.3),
                0 1px 0 rgba(255, 255, 255, 0.03) inset;
    pointer-events: none;
    opacity: 0;
    transform: translateY(6px) scale(0.97);
    transition: opacity 0.2s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 10;
    white-space: nowrap;
  }

  .ward-tooltip.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .tooltip-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.01em;
  }

  .tooltip-party {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent, #12b6cf);
  }

  .tooltip-stat {
    font-size: 0.6875rem;
    color: rgba(235, 235, 245, 0.45);
    font-variant-numeric: tabular-nums;
  }

  /* ---- Overlay toggles ---- */
  .map-overlays {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .overlay-btn {
    padding: 0.4rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 100px;
    color: rgba(235, 235, 245, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(8px);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    letter-spacing: 0.01em;
  }

  .overlay-btn:hover {
    color: rgba(235, 235, 245, 0.85);
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.06);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .overlay-btn:active {
    transform: scale(0.97);
  }

  .overlay-btn.overlay-active {
    color: #12b6cf;
    border-color: rgba(18, 182, 207, 0.3);
    background: rgba(18, 182, 207, 0.08);
    box-shadow: 0 0 12px rgba(18, 182, 207, 0.15),
                0 2px 8px rgba(0, 0, 0, 0.2);
    text-shadow: 0 0 12px rgba(18, 182, 207, 0.3);
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .ward-map-svg {
      transform: rotateX(32deg) rotateZ(-1deg);
    }

    .ward-label {
      font-size: 7px;
    }

    .ward-tooltip {
      display: none;
    }

    .map-overlays {
      flex-wrap: wrap;
      gap: 0.375rem;
    }

    .overlay-btn {
      padding: 0.35rem 0.75rem;
      font-size: 0.6875rem;
    }
  }

  @media (max-width: 480px) {
    .ward-map-container {
      padding: 0.5rem 0 0;
    }

    .ward-map-svg {
      transform: rotateX(26deg);
    }

    .ward-label {
      font-size: 6px;
      stroke-width: 2.5px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ward-map-svg {
      transition: none;
    }

    .ward-group:hover {
      transform: none;
    }

    .ward-active-glow {
      animation: none;
      opacity: 0.35;
    }

    .ward-tooltip {
      transition: opacity 0.15s ease;
      transform: translateY(0) scale(1);
    }

    .ward-tooltip.visible {
      transform: translateY(0) scale(1);
    }
  }
</style>
