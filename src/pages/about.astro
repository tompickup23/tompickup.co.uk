---
import Layout from '../layouts/Layout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
---

<Layout
  title="About — Tom Pickup"
  description="About Tom Pickup, Lancashire County Councillor for Padiham and Burnley West. Reform UK. Transparency advocate and creator of AI DOGE."
>
  <!-- Section 1: Page Header -->
  <section class="page-header-section">
    <div class="container">
      <h1 class="gradient-text">About Me</h1>
      <p class="page-subtitle">Lancashire County Councillor for Padiham and Burnley West</p>
    </div>
  </section>

  <!-- Section 2: Bio -->
  <section class="bio-section">
    <div class="container">
      <ScrollReveal>
        <div class="bio-grid">
          <div class="bio-photo-placeholder">
            <div class="photo-inner">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                <polyline points="21 15 16 10 5 21"></polyline>
              </svg>
              <span>Photo coming soon</span>
            </div>
          </div>

          <div class="bio-text">
            <h2>Tom Pickup</h2>
            <div class="bio-meta">
              <span class="badge badge-teal">Reform UK</span>
              <span class="badge badge-teal">Padiham &amp; Burnley West</span>
            </div>
            <p>
              I grew up in this area and I care deeply about its future. Like many residents, I watched
              council tax bills climb year after year while potholes multiplied, bins got missed, and the
              answers from County Hall never quite added up. I decided to stop complaining and start doing
              something about it.
            </p>
            <p>
              Before entering politics, I worked in technology, which gave me the skills to build
              tools that can make sense of vast amounts of public data. That background led me to create
              <a href="https://aidoge.co.uk" target="_blank" rel="noopener noreferrer">AI DOGE</a> — a
              platform that tracks over 2.3 million transactions and more than &pound;12 billion in spending
              across all 15 Lancashire councils. I believe technology can and should be used to hold power
              to account.
            </p>
            <p>
              I was elected in 2025 on a Reform UK ticket, standing on a simple promise: transparency,
              accountability, and putting residents first. I don't do politics-as-usual. I ask the
              awkward questions, I dig into the numbers, and I publish what I find — because the people
              paying the bills have a right to know where their money goes.
            </p>
            <p>
              When I'm not at County Hall or in committee meetings, you'll find me out in the community
              talking to the people I represent. My door is always open, and I'm always happy to hear from
              residents of Padiham and Burnley West.
            </p>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 3: Timeline -->
  <section class="timeline-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">Key Milestones</h2>
        </div>

        <div class="timeline">
          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-card card">
              <span class="timeline-date">2025</span>
              <h3>Elected to Lancashire County Council</h3>
              <p>
                Won the Padiham and Burnley West division for Reform UK, joining the largest
                Reform group on any county council in England with 53 seats.
              </p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-card card">
              <span class="timeline-date">2025</span>
              <h3>Launched Councillor Website</h3>
              <p>
                Built this website to provide a direct, transparent line of communication
                between me and the residents I represent. No spin, no jargon.
              </p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-card card">
              <span class="timeline-date">2024</span>
              <h3>Created AI DOGE</h3>
              <p>
                Built the AI DOGE open data platform from scratch — tracking spending for all
                15 Lancashire councils with forensic AI analysis. Over 2.3 million transactions
                and &pound;12 billion in public spending made searchable and transparent.
              </p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-card card">
              <span class="timeline-date">2024</span>
              <h3>Began Investigating Council Spending</h3>
              <p>
                Started analysing publicly available council spending data, uncovering patterns
                of duplicate payments, supplier concentration risks, and contract irregularities
                across Lancashire.
              </p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-card card">
              <span class="timeline-date">Ongoing</span>
              <h3>Community Engagement</h3>
              <p>
                Committed to holding regular surgeries and being available to residents.
                Your concerns drive my work at County Hall — from road repairs to planning
                issues to scrutinising budgets.
              </p>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 4: Political Priorities -->
  <section class="political-priorities-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">My Priorities</h2>
        </div>

        <div class="priorities-grid stagger-children">
          <div class="priority-static card">
            <div class="priority-static-icon" style="color: var(--accent);">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            </div>
            <h3>Radical Transparency</h3>
            <p>
              Open data, public scrutiny, and no backroom deals. Every council decision should be
              visible to the people who pay for it. I publish my findings, share the data, and
              invite challenge.
            </p>
          </div>

          <div class="priority-static card">
            <div class="priority-static-icon" style="color: var(--accent-green);">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              </svg>
            </div>
            <h3>Accountable Governance</h3>
            <p>
              Councillors and officers should answer to residents, not the other way round.
              I challenge complacency, question spending decisions, and hold the executive
              to account in every meeting.
            </p>
          </div>

          <div class="priority-static card">
            <div class="priority-static-icon" style="color: var(--accent-orange);">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
              </svg>
            </div>
            <h3>Data-Driven Decisions</h3>
            <p>
              Gut feeling and party loyalty shouldn't drive council policy. I use real data
              to understand problems, measure performance, and propose solutions. The numbers
              don't lie.
            </p>
          </div>

          <div class="priority-static card">
            <div class="priority-static-icon" style="color: var(--accent-purple);">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
            </div>
            <h3>Residents First</h3>
            <p>
              Every decision I make starts with one question: is this good for the people of
              Padiham and Burnley West? I'm not here for a career in politics. I'm here to
              serve my community.
            </p>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 5: Transparency Work -->
  <section class="transparency-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">Transparency &amp; AI DOGE</h2>
        </div>

        <div class="transparency-content">
          <p>
            The AI DOGE platform is my biggest contribution to transparency in Lancashire.
            Built from scratch, it uses artificial intelligence to analyse council spending
            data across all 15 Lancashire councils — from district councils like Burnley and
            Pendle to Lancashire County Council itself and the unitary authorities of Blackpool
            and Blackburn with Darwen.
          </p>
          <p>
            The platform performs forensic checks including duplicate payment detection, split
            payment evasion analysis, supplier concentration risk assessment, Benford's Law
            statistical screening, and cross-council price comparison. All data is publicly
            accessible and all findings are verifiable.
          </p>
          <p>
            I believe this kind of transparency should be the norm, not the exception. If you
            want to explore the data yourself or learn more about how it works, visit the links below.
          </p>

          <div class="transparency-links">
            <a
              href="https://aidoge.co.uk/lancashire/lancashirecc/"
              class="btn-primary"
              target="_blank"
              rel="noopener noreferrer"
            >
              Explore AI DOGE
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
            </a>
            <a href="/transparency/" class="btn-secondary">Transparency Page</a>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 6: Accessibility Statement -->
  <section class="accessibility-section" id="accessibility">
    <div class="container-narrow">
      <ScrollReveal>
        <div class="accessibility-card card">
          <h2>Accessibility Statement</h2>
          <p>
            This website aims to be accessible to as many people as possible, in line with
            <strong>WCAG 2.1 Level AA</strong> guidelines. The site is built with semantic HTML,
            supports keyboard navigation, provides sufficient colour contrast, and respects user
            preferences for reduced motion.
          </p>
          <p>
            If you encounter any accessibility issues or have suggestions for improvement,
            please <a href="/contact/">get in touch</a>. I take accessibility seriously and
            will work to resolve any barriers as quickly as possible.
          </p>
        </div>
      </ScrollReveal>
    </div>
  </section>
</Layout>

<style>
  /* ---- Page Header ---- */
  .page-header-section {
    text-align: center;
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  .page-header-section h1 {
    margin-bottom: var(--space-sm);
  }

  .page-subtitle {
    color: var(--text-secondary);
    font-size: 1.125rem;
  }

  /* ---- Bio Section ---- */
  .bio-section {
    padding: 0 0 var(--space-2xl);
  }

  .bio-grid {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .bio-photo-placeholder {
    width: 300px;
    height: 400px;
    border-radius: var(--radius-lg);
    background: var(--bg-tertiary);
    border: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .photo-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    color: var(--text-tertiary);
  }

  .photo-inner svg {
    opacity: 0.4;
  }

  .photo-inner span {
    font-size: 0.875rem;
    font-weight: 500;
  }

  .bio-text h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    margin-bottom: var(--space-sm);
  }

  .bio-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .bio-text p {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.75;
    margin-bottom: var(--space-md);
  }

  .bio-text p:last-child {
    margin-bottom: 0;
  }

  /* ---- Timeline ---- */
  .timeline-section {
    padding: 0 0 var(--space-2xl);
  }

  .timeline {
    position: relative;
    padding-left: 32px;
    max-width: 700px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    top: 0;
    left: 11px;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--accent) 0%,
      var(--accent-border) 30%,
      var(--border-color) 100%
    );
    border-radius: 1px;
  }

  .timeline-item {
    position: relative;
    padding-bottom: var(--space-lg);
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: -32px;
    top: var(--space-lg);
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--bg-primary);
    border: 2px solid var(--accent);
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .timeline-dot::after {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
  }

  .timeline-card {
    margin-left: var(--space-md);
  }

  .timeline-date {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-xs);
    font-variant-numeric: tabular-nums;
  }

  .timeline-card h3 {
    font-size: 1.0625rem;
    font-weight: 600;
    margin-bottom: var(--space-sm);
    color: var(--text-primary);
  }

  .timeline-card p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  /* Stagger timeline animation */
  .timeline-item:nth-child(1) { opacity: 0; animation: fadeInUp 0.5s var(--ease-smooth) 0.1s forwards; }
  .timeline-item:nth-child(2) { opacity: 0; animation: fadeInUp 0.5s var(--ease-smooth) 0.2s forwards; }
  .timeline-item:nth-child(3) { opacity: 0; animation: fadeInUp 0.5s var(--ease-smooth) 0.3s forwards; }
  .timeline-item:nth-child(4) { opacity: 0; animation: fadeInUp 0.5s var(--ease-smooth) 0.4s forwards; }
  .timeline-item:nth-child(5) { opacity: 0; animation: fadeInUp 0.5s var(--ease-smooth) 0.5s forwards; }

  /* ---- Political Priorities ---- */
  .political-priorities-section {
    padding: 0 0 var(--space-2xl);
  }

  .priorities-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .priority-static {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .priority-static-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.04);
    margin-bottom: var(--space-xs);
    transition: transform var(--transition-fast);
  }

  .priority-static:hover .priority-static-icon {
    transform: scale(1.08) rotate(-3deg);
  }

  .priority-static h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .priority-static p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  /* ---- Transparency Section ---- */
  .transparency-section {
    padding: 0 0 var(--space-2xl);
  }

  .transparency-content {
    max-width: 720px;
  }

  .transparency-content p {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.75;
    margin-bottom: var(--space-md);
  }

  .transparency-links {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-top: var(--space-lg);
  }

  /* ---- Accessibility Section ---- */
  .accessibility-section {
    padding: 0 0 var(--space-2xl);
  }

  .accessibility-card {
    border-left: 3px solid var(--accent);
  }

  .accessibility-card h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: var(--space-md);
  }

  .accessibility-card p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .accessibility-card p:last-child {
    margin-bottom: 0;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .page-header-section {
      padding: var(--space-xl) 0 var(--space-lg);
    }

    .bio-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .bio-photo-placeholder {
      width: 100%;
      max-width: 300px;
      height: 280px;
      margin: 0 auto;
    }

    .priorities-grid {
      grid-template-columns: 1fr;
    }

    .timeline {
      padding-left: 28px;
    }

    .timeline::before {
      left: 9px;
    }

    .timeline-dot {
      left: -28px;
      width: 20px;
      height: 20px;
    }

    .timeline-dot::after {
      width: 6px;
      height: 6px;
    }

    .timeline-card {
      margin-left: var(--space-sm);
    }

    .transparency-links {
      flex-direction: column;
    }
  }

  @media (max-width: 480px) {
    .bio-photo-placeholder {
      height: 240px;
    }

    .transparency-links a {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .timeline-item {
      opacity: 1 !important;
      animation: none !important;
    }

    .priority-static:hover .priority-static-icon {
      transform: none;
    }
  }
</style>
