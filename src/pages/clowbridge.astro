---
import Layout from '../layouts/Layout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
---

<Layout
  title="Clowbridge with Dunnockshaw Parish Council | Tom Pickup"
  description="Clowbridge with Dunnockshaw Parish Council. A rural parish in the heart of East Lancashire, represented by Tom Pickup."
>
  <!-- Hero -->
  <section class="parish-hero">
    <div class="container">
      <ScrollReveal>
        <div class="parish-hero-inner">
          <span class="badge badge-teal">Parish Council</span>
          <h1>Clowbridge with Dunnockshaw</h1>
          <p class="parish-hero-sub">
            A rural parish in the hills above Burnley, with its own elected council
            serving a small but proud community.
          </p>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Overview -->
  <section class="parish-overview">
    <div class="container">
      <ScrollReveal>
        <div class="overview-grid">
          <div class="overview-card">
            <h3>About the Parish</h3>
            <p>
              Clowbridge with Dunnockshaw sits in the West Pennine hills between Burnley and
              Rossendale. It&rsquo;s one of the most rural parts of the Burnley borough, centred around
              Clowbridge Reservoir and the hamlets of Dunnockshaw and Clowbridge.
            </p>
            <p>
              Despite its small population, the parish has its own elected council &mdash; the most
              local tier of government, dealing with matters closest to home.
            </p>
          </div>

          <div class="overview-card">
            <h3>Your Parish Councillor</h3>
            <div class="councillor-highlight">
              <div class="councillor-photo">
                <img src="/images/headshot.jpg" alt="Tom Pickup" width="80" height="80" loading="lazy" />
              </div>
              <div class="councillor-info">
                <span class="councillor-name">Tom Pickup</span>
                <span class="councillor-role">Parish Councillor</span>
                <span class="councillor-party">Reform UK</span>
              </div>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- What the Parish Council Does -->
  <section class="parish-services">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">What the Parish Council Does</h2>
          <p class="section-subtitle">The most local tier of government &mdash; closest to the community</p>
        </div>

        <div class="services-grid stagger-children">
          <div class="service-card">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            <h3>Local Environment</h3>
            <p>Footpaths, benches, noticeboards, litter bins, and keeping the parish looking its best.</p>
          </div>
          <div class="service-card">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            <h3>Community Voice</h3>
            <p>Representing parish residents on planning applications, highways issues, and local concerns to the borough and county councils.</p>
          </div>
          <div class="service-card">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            <h3>Local Events</h3>
            <p>Supporting community events and bringing neighbours together in a rural setting.</p>
          </div>
          <div class="service-card">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            <h3>Precept</h3>
            <p>Setting a small annual precept (added to council tax) to fund parish services and maintenance.</p>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="parish-contact">
    <div class="container">
      <ScrollReveal>
        <div class="contact-cta-card">
          <div class="contact-cta-lines"></div>
          <div class="contact-cta-inner">
            <h2>Have a Parish Issue?</h2>
            <p>Whether it&rsquo;s a footpath, a planning concern, or anything in the Clowbridge and Dunnockshaw area &mdash; get in touch.</p>
            <a href="/contact/" class="cta-btn-white">Contact Me</a>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>
</Layout>

<style>
  /* ---- Hero ---- */
  .parish-hero {
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  .parish-hero-inner {
    max-width: 600px;
  }

  .parish-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.08;
    margin: var(--space-md) 0 var(--space-md);
    background: linear-gradient(135deg, #ffffff 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .parish-hero-sub {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* ---- Overview ---- */
  .parish-overview {
    padding: 0 0 var(--space-2xl);
  }

  .overview-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .overview-card {
    padding: var(--space-lg);
    background: rgba(28, 28, 30, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
  }

  .overview-card h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-md);
  }

  .overview-card p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: var(--space-md);
  }

  .overview-card p:last-child {
    margin-bottom: 0;
  }

  /* ---- Councillor Highlight ---- */
  .councillor-highlight {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-md);
  }

  .councillor-photo img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--accent-border);
  }

  .councillor-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .councillor-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .councillor-role {
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }

  .councillor-party {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
  }

  /* ---- Services ---- */
  .parish-services {
    padding: 0 0 var(--space-2xl);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  .service-card {
    padding: var(--space-lg);
    background: rgba(28, 28, 30, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
    transition: border-color var(--transition-normal), transform var(--transition-fast);
  }

  .service-card:hover {
    border-color: rgba(255, 255, 255, 0.12);
    transform: translateY(-2px);
  }

  .service-card svg {
    color: var(--accent);
    margin-bottom: var(--space-sm);
  }

  .service-card h3 {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
  }

  .service-card p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* ---- Contact CTA ---- */
  .parish-contact {
    padding: 0 0 var(--space-2xl);
  }

  .contact-cta-card {
    position: relative;
    background:
      radial-gradient(ellipse 80% 60% at 20% 80%, rgba(18, 182, 207, 0.4) 0%, transparent 50%),
      linear-gradient(135deg, #0a2a3a 0%, #12b6cf 100%);
    border-radius: var(--radius-xl);
    overflow: hidden;
    padding: var(--space-2xl) var(--space-xl);
    text-align: center;
  }

  .contact-cta-lines {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        135deg,
        transparent,
        transparent 40px,
        rgba(255, 255, 255, 0.03) 40px,
        rgba(255, 255, 255, 0.03) 41px
      );
    pointer-events: none;
  }

  .contact-cta-inner {
    position: relative;
    z-index: 1;
    max-width: 460px;
    margin: 0 auto;
  }

  .contact-cta-inner h2 {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 800;
    color: #ffffff;
    margin-bottom: var(--space-md);
  }

  .contact-cta-inner p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1rem;
    line-height: 1.65;
    margin-bottom: var(--space-lg);
  }

  .cta-btn-white {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.75rem;
    background: #ffffff;
    color: #0a2a3a;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    background-image: none;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.2);
    transition: transform var(--transition-fast), box-shadow var(--transition-normal);
  }

  .cta-btn-white:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    background-image: none;
    background-size: 0;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .overview-grid {
      grid-template-columns: 1fr;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .parish-hero {
      padding: var(--space-xl) 0 var(--space-lg);
    }
  }
</style>
