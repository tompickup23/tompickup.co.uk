---
import Layout from '../layouts/Layout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
---

<Layout
  title="Padiham & Burnley West | Tom Pickup"
  description="What Lancashire County Council is investing in Padiham and Burnley West. Schools, childcare, care homes, heritage, highways — tracked since May 2025."
>
  <!-- Section 1: Page Header -->
  <section class="page-header-section">
    <div class="container">
      <h1 class="gradient-text">Padiham &amp; Burnley West</h1>
      <p class="page-subtitle">Your division. Your money. What&rsquo;s being delivered since May 2025.</p>
    </div>
  </section>

  <!-- Section 2: Ward Overview -->
  <section class="ward-overview">
    <div class="container">
      <ScrollReveal>
        <div class="overview-grid stagger-children">
          <div class="impact-card" data-accent="teal">
            <div class="impact-accent"></div>
            <span class="impact-value tabular-nums">&pound;527K+</span>
            <span class="impact-label">Direct Local Investment</span>
          </div>
          <div class="impact-card" data-accent="green">
            <div class="impact-accent"></div>
            <span class="impact-value tabular-nums">507</span>
            <span class="impact-label">Tracked Transactions</span>
          </div>
          <div class="impact-card" data-accent="blue">
            <div class="impact-accent"></div>
            <span class="impact-value tabular-nums">16</span>
            <span class="impact-label">LCC-Owned Properties</span>
          </div>
          <div class="impact-card" data-accent="purple">
            <div class="impact-accent"></div>
            <span class="impact-value tabular-nums">5</span>
            <span class="impact-label">Schools Funded</span>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 3: Council-Wide Achievements -->
  <section class="achievements-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">What Reform Has Delivered for Lancashire</h2>
          <p class="section-subtitle">Every resident of Padiham and Burnley West benefits from these county-wide changes.</p>
        </div>

        <div class="achievements-grid stagger-children">
          <div class="achievement-card card">
            <span class="achievement-number" style="color: #30d158;">3.80%</span>
            <h3>Lowest CT Rise in 12 Years</h3>
            <p>The Conservatives raised council tax to the maximum in 7 of 8 years. Reform&rsquo;s first budget delivered 3.80%, saving each Band D household &pound;17.55 compared to the previous approach.</p>
          </div>
          <div class="achievement-card card">
            <span class="achievement-number" style="color: #ff453a;">&pound;28M&rarr;&pound;6M</span>
            <h3>Inherited Overspend Corrected</h3>
            <p>We inherited a &pound;28 million overspend forecast. Through targeted action, not cuts to front-line services, we&rsquo;ve reduced it to &pound;6.1 million and falling.</p>
          </div>
          <div class="achievement-card card">
            <span class="achievement-number" style="color: var(--accent);">5</span>
            <h3>Care Homes: Future Secured</h3>
            <p>Inherited a consultation on their future. Listened to 1,600+ residents. Secured the future of all five county care homes, including Woodside in Padiham, with new investment pledged.</p>
          </div>
          <div class="achievement-card card">
            <span class="achievement-number" style="color: #ff9f0a;">&pound;60.3M</span>
            <h3>Waste Contract: First Open Tender</h3>
            <p>Put East Lancashire waste disposal out to competitive tender for the first time in a generation. The Burnley lot alone saves taxpayers millions, with waste processed locally at Hapton Valley.</p>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 4: Local Investment Detail -->
  <section class="investment-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">Investment in Padiham &amp; Burnley West</h2>
          <p class="section-subtitle">LCC spending directly attributed to facilities and services in the division, May&ndash;December 2025.</p>
        </div>

        <!-- Schools -->
        <div class="investment-category">
          <div class="category-header">
            <div class="category-icon" style="color: #30d158;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
            </div>
            <div>
              <h3>Schools &amp; Education</h3>
              <span class="category-total">&pound;345,323 across 370 transactions</span>
            </div>
          </div>

          <div class="investment-cards">
            <div class="invest-card card">
              <div class="invest-header">
                <h4>Padiham St Leonard&rsquo;s CE Primary</h4>
                <span class="invest-amount">&pound;179,040</span>
              </div>
              <p>158 transactions including &pound;26,935 specialist educational psychology (SEND support), &pound;14,244 building maintenance, &pound;8,850 delegated maintenance, &pound;5,282 ICT connectivity, plus supply teaching and learning resources.</p>
            </div>

            <div class="invest-card card">
              <div class="invest-header">
                <h4>Padiham Green CE Primary</h4>
                <span class="invest-amount">&pound;78,780</span>
              </div>
              <p>70 transactions including &pound;30,983 planned building works, &pound;5,094 new laptops and tablets, plus supply teaching staff, security systems, and electrical compliance.</p>
            </div>

            <div class="invest-card card">
              <div class="invest-header">
                <h4>Padiham Primary School</h4>
                <span class="invest-amount">&pound;51,331</span>
              </div>
              <p>76 transactions including &pound;11,850 ICT capital (laptops and tablets), &pound;2,905 sports coaching, plus planned maintenance works and service contracts.</p>
            </div>

            <div class="invest-card card">
              <div class="invest-header">
                <h4>Hapton CE/Methodist Primary</h4>
                <span class="invest-amount">&pound;36,172</span>
              </div>
              <p>63 transactions covering school operations, supply teaching staff, learning resources, and building maintenance.</p>
            </div>
          </div>
        </div>

        <!-- Early Years -->
        <div class="investment-category">
          <div class="category-header">
            <div class="category-icon" style="color: #ff9f0a;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </div>
            <div>
              <h3>Early Years &amp; Childcare</h3>
              <span class="category-total">&pound;161,890 across 81 transactions</span>
            </div>
          </div>

          <div class="investment-cards">
            <div class="invest-card card">
              <div class="invest-header">
                <h4>Little Acorns Padiham</h4>
                <span class="invest-amount">&pound;124,264</span>
              </div>
              <p>Government-funded childcare places for under-2s, 2-year-olds, and 3&ndash;4-year-olds. Monthly payments supporting local families. Includes &pound;3,789 in Early Years EHCP funding for children with special educational needs.</p>
            </div>

            <div class="invest-card card">
              <div class="invest-header">
                <h4>Whitegate Children&rsquo;s Centre &amp; Nursery</h4>
                <span class="invest-amount">&pound;37,626</span>
              </div>
              <p>65 transactions including food provisions, planned electrical upgrades (&pound;6,990), waste collection, and building maintenance at the Victoria Road site.</p>
            </div>
          </div>
        </div>

        <!-- Care & Social Services -->
        <div class="investment-category">
          <div class="category-header">
            <div class="category-icon" style="color: #ff453a;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            </div>
            <div>
              <h3>Care &amp; Social Services</h3>
              <span class="category-total">&pound;53,086 across 92 transactions</span>
            </div>
          </div>

          <div class="investment-cards">
            <div class="invest-card card">
              <div class="invest-header">
                <h4>Woodside Residential Care Home</h4>
                <span class="invest-amount">&pound;41,569</span>
              </div>
              <p>LCC-owned freehold on Burnley Road (1,895 sqm). 59 transactions for day-to-day operations (&pound;27,250), service contracts (&pound;7,492), and planned maintenance (&pound;6,827). One of the five county care homes whose future we secured.</p>
            </div>

            <div class="invest-card card">
              <div class="invest-header">
                <h4>Short Break East Lancashire</h4>
                <span class="invest-amount">&pound;9,518</span>
              </div>
              <p>Respite care facility on Greenock Street for children with disabilities. 32 transactions covering operations and support services.</p>
            </div>

            <div class="invest-card card">
              <div class="invest-header">
                <h4>Stoney View Children&rsquo;s Home</h4>
                <span class="invest-amount">&pound;1,998</span>
              </div>
              <p>LCC-owned freehold on Malvern Avenue supporting looked-after children.</p>
            </div>
          </div>
        </div>

        <!-- Heritage -->
        <div class="investment-category">
          <div class="category-header">
            <div class="category-icon" style="color: #bf5af2;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"></path><path d="M5 21V7l8-4v18"></path><path d="M19 21V11l-6-4"></path></svg>
            </div>
            <div>
              <h3>Heritage &amp; Culture</h3>
              <span class="category-total">&pound;34,091 across 60 transactions</span>
            </div>
          </div>

          <div class="investment-cards">
            <div class="invest-card card">
              <div class="invest-header">
                <h4>Gawthorpe Hall</h4>
                <span class="invest-amount">&pound;34,091</span>
              </div>
              <p>Grade I listed Elizabethan house on Burnley Road. 60 transactions for day-to-day maintenance (&pound;15,565), ongoing service contracts (&pound;5,353), planned conservation works (&pound;4,921), and museum stock (&pound;4,416).</p>
            </div>
          </div>
        </div>

        <!-- Library & Infrastructure -->
        <div class="investment-category">
          <div class="category-header">
            <div class="category-icon" style="color: var(--accent);">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
            </div>
            <div>
              <h3>Libraries &amp; Infrastructure</h3>
              <span class="category-total">&pound;3,362 across 25 transactions</span>
            </div>
          </div>

          <div class="investment-cards">
            <div class="invest-card card">
              <div class="invest-header">
                <h4>Padiham Library</h4>
                <span class="invest-amount">&pound;1,324</span>
              </div>
              <p>Service contracts and maintenance at the Town Hall site on Burnley Road, in the most deprived decile (IMD 1).</p>
            </div>

            <div class="invest-card card">
              <div class="invest-header">
                <h4>Hapton Fleet Workshop</h4>
                <span class="invest-amount">&pound;2,038</span>
              </div>
              <p>LCC highways and fleet maintenance depot on Brindley Close. Leasehold, 2,429 sqm. Maintenance of the vehicles that serve our roads.</p>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 4b: Capital Programme 2026/27 -->
  <section class="capital-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">Highways Capital Programme 2026/27</h2>
          <p class="section-subtitle">
            LCC highways schemes funded or in reserve for Padiham &amp; Burnley West. From the &pound;72 million county-wide highways capital budget approved March 2026.
          </p>
        </div>

        <div class="capital-headline">
          <div class="capital-stat">
            <span class="capital-value tabular-nums">&pound;509K</span>
            <span class="capital-label">Allocated for PBW highways</span>
          </div>
          <div class="capital-stat">
            <span class="capital-value tabular-nums">4</span>
            <span class="capital-label">Schemes funded or in reserve</span>
          </div>
          <div class="capital-stat">
            <span class="capital-value tabular-nums">&pound;72M</span>
            <span class="capital-label">County-wide highways capital</span>
          </div>
        </div>

        <div class="capital-cards stagger-children">
          <div class="capital-card card">
            <div class="capital-card-header">
              <span class="capital-badge capital-funded">Funded</span>
              <span class="capital-amount tabular-nums">&pound;138,000</span>
            </div>
            <h4>Park Road, Padiham &mdash; Resurfacing</h4>
            <p>Full carriageway resurfacing of Park Road. One of 7 funded Burnley borough schemes in the 2026/27 programme.</p>
          </div>

          <div class="capital-card card">
            <div class="capital-card-header">
              <span class="capital-badge capital-funded">Funded</span>
              <span class="capital-amount tabular-nums">&pound;109,000</span>
            </div>
            <h4>A671 Padiham Road &mdash; Surface Dressing</h4>
            <p>Preventative surface dressing to extend road life on the A671, a key route linking Padiham to Burnley town centre.</p>
          </div>

          <div class="capital-card card">
            <div class="capital-card-header">
              <span class="capital-badge capital-reserve">Reserve</span>
              <span class="capital-amount tabular-nums">&pound;237,000</span>
            </div>
            <h4>A646 Rossendale Road &mdash; Resurfacing</h4>
            <p>Reserve-listed resurfacing of the A646, a major cross-boundary route between Burnley and Rossendale. Will proceed if funded schemes come in under budget.</p>
          </div>

          <div class="capital-card card">
            <div class="capital-card-header">
              <span class="capital-badge capital-reserve">Reserve</span>
              <span class="capital-amount tabular-nums">&pound;24,800</span>
            </div>
            <h4>A671 Padiham Road &mdash; Junction Resurfacing</h4>
            <p>Reserve-listed junction resurfacing on the A671, complementing the funded surface dressing scheme on the same route.</p>
          </div>
        </div>

        <div class="capital-context card">
          <p>
            <strong>Context:</strong> Burnley borough received &pound;748,000 across 7 funded highway schemes in the 2026/27 programme &mdash;
            the largest allocation among East Lancashire districts. A further &pound;262K sits on the reserve list.
            These are in addition to the &pound;254K in day-to-day highways maintenance spending tracked below.
          </p>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 5: Wider Burnley Impact -->
  <section class="wider-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">Wider Burnley Borough Investment</h2>
          <p class="section-subtitle">LCC revenue spending and capital programmes benefiting residents across Burnley borough, including Padiham &amp; Burnley West.</p>
        </div>

        <div class="wider-grid stagger-children">
          <div class="wider-card card">
            <span class="wider-icon" style="color: #ff453a;">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg>
            </span>
            <span class="wider-value">&pound;16.4M</span>
            <h3>Children&rsquo;s Social Care</h3>
            <p>Fostering, residential care, family support, and leaving care services across the Burnley district. The single largest spending category.</p>
          </div>

          <div class="wider-card card">
            <span class="wider-icon" style="color: #ff9f0a;">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 3a3 3 0 0 0-3 3v12a3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3H6a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3V6a3 3 0 0 0-3-3 3 3 0 0 0-3 3 3 3 0 0 0 3 3h12a3 3 0 0 0 3-3 3 3 0 0 0-3-3z"></path></svg>
            </span>
            <span class="wider-value">&pound;1M+</span>
            <h3>Highways &amp; Roads</h3>
            <p>&pound;748K in capital resurfacing (2026/27) plus &pound;254K in day-to-day maintenance (2025). County-wide, LCC has committed &pound;72 million for highways capital in 2026/27.</p>
          </div>

          <div class="wider-card card">
            <span class="wider-icon" style="color: #30d158;">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
            </span>
            <span class="wider-value">&pound;61K</span>
            <h3>Libraries</h3>
            <p>Maintenance and refurbishment across Burnley&rsquo;s libraries, including a &pound;22,008 refurbishment at Burnley Divisional Library on Grimshaw Street.</p>
          </div>

          <div class="wider-card card">
            <span class="wider-icon" style="color: #bf5af2;">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            </span>
            <span class="wider-value">&pound;18K</span>
            <h3>Stocks Massey Fund</h3>
            <p>As Chairman of the Advisory Committee, I oversaw &pound;18,000 in grants to 15 Burnley arts organisations plus two university bursaries in 2025.</p>
          </div>

          <div class="wider-card card">
            <span class="wider-icon" style="color: var(--accent);">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"></path><path d="M5 21V7l8-4v18"></path><path d="M19 21V11l-6-4"></path></svg>
            </span>
            <span class="wider-value">&pound;55M</span>
            <h3>East Lancs Levelling Up</h3>
            <p>Levelling Up Fund programme for Burnley and Pendle. Manchester Road corridor, Colne Road improvements, and Centenary Way Viaduct remediation &mdash; benefiting the whole borough.</p>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 6: LCC Properties -->
  <section class="properties-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">LCC Properties in the Division</h2>
          <p class="section-subtitle">16 county council-owned properties and land holdings in Padiham &amp; Burnley West.</p>
        </div>

        <div class="properties-grid stagger-children">
          <div class="property-card card">
            <span class="property-type">Children&rsquo;s Care</span>
            <h4>Woodside Residential Care Home</h4>
            <p class="property-address">Burnley Road, BB12 8SD</p>
            <div class="property-meta">
              <span>Freehold &middot; 1,895 sqm</span>
              <span>EPC: D &middot; IMD Decile 3</span>
            </div>
          </div>

          <div class="property-card card">
            <span class="property-type">Education</span>
            <h4>Whitegate Nursery School</h4>
            <p class="property-address">Victoria Road, BB12 8TG</p>
            <div class="property-meta">
              <span>Freehold &middot; 919 sqm</span>
              <span>EPC: E &middot; IMD Decile 3</span>
            </div>
          </div>

          <div class="property-card card">
            <span class="property-type">Education</span>
            <h4>Padiham St Leonard&rsquo;s CE Primary</h4>
            <p class="property-address">Moor Lane, BB12 8HT</p>
            <div class="property-meta">
              <span>Freehold &middot; 1,905 sqm</span>
              <span>EPC: D &middot; IMD Decile 3</span>
            </div>
          </div>

          <div class="property-card card">
            <span class="property-type">Education</span>
            <h4>Padiham Primary School</h4>
            <p class="property-address">Burnley Road, BB12 8SJ</p>
            <div class="property-meta">
              <span>Freehold &middot; 1,817 sqm</span>
              <span>EPC: D &middot; IMD Decile 1</span>
            </div>
          </div>

          <div class="property-card card">
            <span class="property-type">Education</span>
            <h4>Padiham Green CE Primary</h4>
            <p class="property-address">St Annes Street, BB12 7AX</p>
            <div class="property-meta">
              <span>Freehold &middot; 1,603 sqm</span>
              <span>EPC: C &middot; IMD Decile 1</span>
            </div>
          </div>

          <div class="property-card card">
            <span class="property-type">Education</span>
            <h4>Hapton CE/Methodist Primary</h4>
            <p class="property-address">Manchester Road, BB11 5RF</p>
            <div class="property-meta">
              <span>Freehold &middot; 718 sqm</span>
              <span>EPC: E &middot; IMD Decile 6</span>
            </div>
          </div>

          <div class="property-card card">
            <span class="property-type">Library</span>
            <h4>Padiham Library</h4>
            <p class="property-address">Town Hall, Burnley Road, BB12 8BN</p>
            <div class="property-meta">
              <span>Leasehold</span>
              <span>IMD Decile 1</span>
            </div>
          </div>

          <div class="property-card card">
            <span class="property-type">Heritage</span>
            <h4>Gawthorpe Hall</h4>
            <p class="property-address">off Burnley Road, BB12 8UA</p>
            <div class="property-meta">
              <span>Grade I Listed</span>
              <span>&pound;34K invested (May&ndash;Dec 2025)</span>
            </div>
          </div>

          <div class="property-card card">
            <span class="property-type">Operations</span>
            <h4>Hapton Fleet Workshop</h4>
            <p class="property-address">Brindley Close, BB11 5TD</p>
            <div class="property-meta">
              <span>Leasehold &middot; 2,429 sqm</span>
              <span>EPC: C &middot; IMD Decile 6</span>
            </div>
          </div>

          <div class="property-card card">
            <span class="property-type">Children&rsquo;s Home</span>
            <h4>Stoney View</h4>
            <p class="property-address">Malvern Avenue, BB12 7DT</p>
            <div class="property-meta">
              <span>Freehold &middot; 218 sqm</span>
              <span>EPC: C &middot; IMD Decile 3</span>
            </div>
          </div>
        </div>

        <div class="properties-note card">
          <p>Plus 6 land holdings including Molly Wood Woodlands, Hameldon Hill county woodlands (2 parcels), Padiham Disused Railway, Canning Street Footbridge, and Towneley Reclamation Scheme land.</p>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 7: CTA -->
  <section class="cta-section">
    <div class="container-narrow">
      <ScrollReveal>
        <div class="cta-card card">
