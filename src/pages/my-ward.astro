---
import Layout from '../layouts/Layout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import Accordion from '../components/Accordion.astro';
---

<Layout
  title="Padiham & Burnley West | Tom Pickup"
  description="What Lancashire County Council is investing in Padiham and Burnley West. Schools, childcare, care homes, heritage, highways — tracked since May 2025."
>
  <!-- Hero -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-inner">
        <span class="hero-badge">LCC Division</span>
        <h1>Padiham &amp; Burnley West</h1>
        <p class="hero-sub">Your division. Your money. Every pound tracked since April 2024.</p>
        <div class="hero-stats">
          <div class="hero-stat hero-stat-featured">
            <span class="hero-stat-value">&pound;1.71M</span>
            <span class="hero-stat-label">Total Investment</span>
            <span class="hero-stat-detail">Revenue + capital Apr 2024&ndash;Dec 2025</span>
          </div>
          <div class="hero-stat">
            <span class="hero-stat-value">7</span>
            <span class="hero-stat-label">Schools Funded</span>
          </div>
          <div class="hero-stat">
            <span class="hero-stat-value">18,599</span>
            <span class="hero-stat-label">Residents Served</span>
          </div>
          <div class="hero-stat">
            <span class="hero-stat-value">1,840</span>
            <span class="hero-stat-label">Transactions</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Reform Achievements -->
  <section class="achievements-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">What Reform Has Delivered</h2>
          <p class="section-subtitle">What Reform UK has achieved since taking control of Lancashire County Council in May 2025.</p>
        </div>
        <div class="achievements-grid stagger-children">
          <div class="achievement-card card">
            <span class="achievement-number" style="color: #30d158;">3.80%</span>
            <h3>Lowest CT Rise in 12 Years</h3>
            <p>Conservatives maxed council tax 7 of 8 years. Reform&rsquo;s first budget: 3.80%, saving Band D households &pound;17.55 vs the old approach.</p>
          </div>
          <div class="achievement-card card">
            <span class="achievement-number" style="color: #ff453a;">&pound;28M&rarr;&pound;6M</span>
            <h3>Overspend Corrected</h3>
            <p>Inherited &pound;28M overspend. Reduced to &pound;6.1M through targeted action, not front-line cuts.</p>
          </div>
          <div class="achievement-card card">
            <span class="achievement-number" style="color: var(--accent);">5</span>
            <h3>Care Homes Saved</h3>
            <p>Secured all five county care homes, including Woodside in Padiham. 1,600+ residents consulted.</p>
          </div>
          <div class="achievement-card card">
            <span class="achievement-number" style="color: #ff9f0a;">&pound;60.3M</span>
            <h3>Waste: First Open Tender</h3>
            <p>First competitive waste tender in a generation. Burnley lot processed locally at Hapton Valley.</p>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Direct Investment — Accordions -->
  <section class="investment-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">&pound;1.41M Direct Padiham Spending</h2>
          <p class="section-subtitle">Every pound tracked to named Padiham &amp; Burnley West facilities, April 2024 &ndash; December 2025.</p>
        </div>

        <div class="accordion-stack">
          <Accordion title="Schools & Education" subtitle="7 schools receiving direct LCC investment" value="&pound;1M" stats="800 txns" accentColor="#30d158" progress={71} progressLabel="71% of direct spend">
            <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
            <div class="detail-grid">
              <div class="detail-row">
                <div class="detail-name">Padiham St Leonard&rsquo;s CE Primary</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 33%; background: #30d158;"></div>
                </div>
                <div class="detail-amount">&pound;326,517</div>
              </div>
              <div class="detail-row">
                <div class="detail-name">Ightenhill Primary School</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 23%; background: #30d158;"></div>
                </div>
                <div class="detail-amount">&pound;229,305</div>
              </div>
              <div class="detail-row">
                <div class="detail-name">Padiham Green CE Primary</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 14%; background: #30d158;"></div>
                </div>
                <div class="detail-amount">&pound;141,784</div>
              </div>
              <div class="detail-row">
                <div class="detail-name">Ightenhill Nursery School</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 13%; background: #30d158;"></div>
                </div>
                <div class="detail-amount">&pound;131,563</div>
              </div>
              <div class="detail-row">
                <div class="detail-name">Padiham Primary School</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 9%; background: #30d158;"></div>
                </div>
                <div class="detail-amount">&pound;93,205</div>
              </div>
              <div class="detail-row">
                <div class="detail-name">Hapton CE/Methodist Primary</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 8%; background: #30d158;"></div>
                </div>
                <div class="detail-amount">&pound;79,451</div>
              </div>
              <div class="detail-row">
                <div class="detail-name">Padiham St John Baptist RC Primary</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 1%; background: #30d158;"></div>
                </div>
                <div class="detail-amount">&pound;1,244</div>
              </div>
            </div>
            <p class="detail-note">Includes &pound;43K SEND educational psychology support, &pound;31K building works, &pound;25K playground equipment, ICT capital (laptops &amp; tablets), sports coaching, and supply teaching.</p>
          </Accordion>

          <Accordion title="Early Years & Childcare" subtitle="Government-funded places for under-5s" value="&pound;243K" stats="40 txns" accentColor="#ff9f0a" progress={17} progressLabel="17% of direct spend">
            <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            <div class="detail-grid">
              <div class="detail-row">
                <div class="detail-name">Little Acorns Padiham</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 89%; background: #ff9f0a;"></div>
                </div>
                <div class="detail-amount">&pound;216,279</div>
              </div>
              <div class="detail-row">
                <div class="detail-name">Whitegate Children&rsquo;s Centre</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 11%; background: #ff9f0a;"></div>
                </div>
                <div class="detail-amount">&pound;25,753</div>
              </div>
            </div>
            <p class="detail-note">Little Acorns: &pound;71K for 3&ndash;4-year-olds, &pound;64K for under-2s, &pound;62K for 2-year-olds, &pound;14K additional SEND inclusion support. Whitegate: building maintenance and lease.</p>
          </Accordion>

          <Accordion title="Care & Social Services" subtitle="Including Woodside Care Home — future secured" value="&pound;54K" stats="100 txns" accentColor="#ff453a" progress={4} progressLabel="4% of direct spend">
            <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            <div class="detail-grid">
              <div class="detail-row">
                <div class="detail-name">Woodside Residential Care Home</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 77%; background: #ff453a;"></div>
                </div>
                <div class="detail-amount">&pound;41,569</div>
              </div>
              <div class="detail-row">
                <div class="detail-name">Short Break East Lancashire</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 18%; background: #ff453a;"></div>
                </div>
                <div class="detail-amount">&pound;9,518</div>
              </div>
              <div class="detail-row">
                <div class="detail-name">Stoney View Children&rsquo;s Home</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 4%; background: #ff453a;"></div>
                </div>
                <div class="detail-amount">&pound;1,998</div>
              </div>
              <div class="detail-row">
                <div class="detail-name">Ightenhill Children&rsquo;s Centre</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 2%; background: #ff453a;"></div>
                </div>
                <div class="detail-amount">&pound;1,059</div>
              </div>
            </div>
            <p class="detail-note">Woodside (Burnley Road): 59 transactions for operations, service contracts, and planned maintenance. Short Break facility: respite care for children with disabilities.</p>
          </Accordion>

          <Accordion title="Heritage & Culture" subtitle="Gawthorpe Hall + Padiham Library" value="&pound;107K" stats="160 txns" accentColor="#bf5af2" progress={8} progressLabel="8% of direct spend">
            <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"></path><path d="M5 21V7l8-4v18"></path><path d="M19 21V11l-6-4"></path></svg>
            <div class="detail-grid">
              <div class="detail-row">
                <div class="detail-name">Gawthorpe Hall (Grade I listed)</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 71%; background: #bf5af2;"></div>
                </div>
                <div class="detail-amount">&pound;76,101</div>
              </div>
              <div class="detail-row">
                <div class="detail-name">Padiham Library</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 29%; background: #bf5af2;"></div>
                </div>
                <div class="detail-amount">&pound;30,961</div>
              </div>
            </div>
            <p class="detail-note">Gawthorpe: premises &pound;30K, conservation &pound;26K, shop stock &pound;12K, general &pound;8K. Library: &pound;25K lease/service charge to Burnley BC, plus electrical and fire safety.</p>
          </Accordion>

          <Accordion title="Community & Operations" subtitle="Local grants, parish support, fleet depot" value="&pound;7K" stats="12 txns" accentColor="var(--accent)" progress={1} progressLabel="<1% of direct spend">
            <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            <div class="detail-grid">
              <div class="detail-row">
                <div class="detail-name">Hapton Parish Council (Treescapes)</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 32%; background: var(--accent);"></div>
                </div>
                <div class="detail-amount">&pound;2,108</div>
              </div>
              <div class="detail-row">
                <div class="detail-name">Hapton Fleet Workshop</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 30%; background: var(--accent);"></div>
                </div>
                <div class="detail-amount">&pound;2,038</div>
              </div>
              <div class="detail-row">
                <div class="detail-name">Hapton Over 50s Luncheon Club</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 13%; background: var(--accent);"></div>
                </div>
                <div class="detail-amount">&pound;900</div>
              </div>
              <div class="detail-row">
                <div class="detail-name">Padiham Football Club</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 10%; background: var(--accent);"></div>
                </div>
                <div class="detail-amount">&pound;700</div>
              </div>
              <div class="detail-row">
                <div class="detail-name">Padiham Road Methodist Church (HSF)</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 7%; background: var(--accent);"></div>
                </div>
                <div class="detail-amount">&pound;500</div>
              </div>
              <div class="detail-row">
                <div class="detail-name">Padiham Parish PCC</div>
                <div class="detail-bar-wrap">
                  <div class="detail-bar" style="width: 6%; background: var(--accent);"></div>
                </div>
                <div class="detail-amount">&pound;400</div>
              </div>
            </div>
            <p class="detail-note">Local Member Grants awarded directly by your county councillor, plus Household Support Fund and Treescapes environmental grants.</p>
          </Accordion>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- LCC Spending Context -->
  <section class="context-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">Your Division in Context</h2>
          <p class="section-subtitle">
            How Padiham &amp; Burnley West&rsquo;s &pound;1.71M fits within Lancashire County Council&rsquo;s &pound;3.56 billion total spending (Apr 2024 &ndash; Dec 2025).
          </p>
        </div>

        <div class="context-bar-card card">
          <div class="context-bar-label">
            <span>LCC Total Spend: <strong>&pound;3.56B</strong></span>
            <span>753,220 transactions</span>
          </div>
          <div class="context-bar-outer">
            <div class="context-bar-inner" style="width: 0.048%;"></div>
            <div class="context-bar-marker">
              <span class="marker-label">PBW &pound;1.71M</span>
            </div>
          </div>
          <p class="context-bar-note">Your division&rsquo;s direct spending represents a fraction of LCC&rsquo;s total &mdash; but every pound is tracked to a named facility.</p>
        </div>

        <div class="lcc-spend-grid stagger-children">
          <div class="lcc-spend-card">
            <span class="lcc-spend-icon" style="color: #ff453a;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            </span>
            <span class="lcc-spend-value">&pound;242M</span>
            <span class="lcc-spend-label">Adult Social Care</span>
            <span class="lcc-spend-detail">Residential placements (largest single item)</span>
          </div>
          <div class="lcc-spend-card">
            <span class="lcc-spend-icon" style="color: #30d158;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
            </span>
            <span class="lcc-spend-value">&pound;181M</span>
            <span class="lcc-spend-label">Schools Funding</span>
            <span class="lcc-spend-detail">Dedicated Schools Grant passthrough</span>
          </div>
          <div class="lcc-spend-card">
            <span class="lcc-spend-icon" style="color: #bf5af2;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </span>
            <span class="lcc-spend-value">&pound;164M</span>
            <span class="lcc-spend-label">NHS / Health</span>
            <span class="lcc-spend-detail">Integrated care &amp; public health commissioning</span>
          </div>
          <div class="lcc-spend-card">
            <span class="lcc-spend-icon" style="color: #ff9f0a;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
            </span>
            <span class="lcc-spend-value">&pound;127M</span>
            <span class="lcc-spend-label">Waste &amp; Recycling</span>
            <span class="lcc-spend-detail">Lancashire Renewables + Suez contracts</span>
          </div>
        </div>

        <div class="lcc-cta-row">
          <a href="https://aidoge.co.uk/lancashirecc/" class="lcc-cta-link" target="_blank" rel="noopener">
            Explore All LCC Spending on AI DOGE
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
          </a>
          <a href="https://aidoge.co.uk/burnleycouncil/" class="lcc-cta-link lcc-cta-secondary" target="_blank" rel="noopener">
            Burnley Borough Spending
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Capital Programme -->
  <section class="capital-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">&pound;509K Highways Capital 2026/27</h2>
          <p class="section-subtitle">
            4 road schemes funded or in reserve for PBW. From the &pound;72M county-wide highways budget.
          </p>
        </div>

        <div class="capital-cards stagger-children">
          <div class="capital-card card">
            <div class="capital-card-header">
              <span class="capital-badge capital-funded">Funded</span>
              <span class="capital-amount tabular-nums">&pound;138K</span>
            </div>
            <h4>Park Road, Padiham</h4>
            <p>Full carriageway resurfacing</p>
          </div>
          <div class="capital-card card">
            <div class="capital-card-header">
              <span class="capital-badge capital-funded">Funded</span>
              <span class="capital-amount tabular-nums">&pound;109K</span>
            </div>
            <h4>A671 Padiham Road</h4>
            <p>Preventative surface dressing</p>
          </div>
          <div class="capital-card card">
            <div class="capital-card-header">
              <span class="capital-badge capital-reserve">Reserve</span>
              <span class="capital-amount tabular-nums">&pound;237K</span>
            </div>
            <h4>A646 Rossendale Road</h4>
            <p>Major route resurfacing</p>
          </div>
          <div class="capital-card card">
            <div class="capital-card-header">
              <span class="capital-badge capital-reserve">Reserve</span>
              <span class="capital-amount tabular-nums">&pound;25K</span>
            </div>
            <h4>A671 Junction Resurfacing</h4>
            <p>Ightenhill Park Lane junction</p>
          </div>
        </div>

        <p class="capital-context-note">Burnley borough total: &pound;748K across 7 funded schemes &mdash; largest allocation in East Lancashire. Plus &pound;262K on the reserve list.</p>
      </ScrollReveal>
    </div>
  </section>

  <!-- Properties -->
  <section class="properties-section">
    <div class="container">
      <ScrollReveal>
        <Accordion title="16 LCC Properties in the Division" subtitle="County council-owned buildings and land holdings in Padiham &amp; Burnley West" stats="16 assets" accentColor="var(--accent)">
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          <div class="properties-grid">
            <div class="prop-item"><span class="prop-type">Care</span><strong>Woodside Residential Care Home</strong><span>Burnley Road &middot; Freehold &middot; 1,895 sqm</span></div>
            <div class="prop-item"><span class="prop-type">Education</span><strong>Whitegate Nursery School</strong><span>Victoria Road &middot; Freehold &middot; 919 sqm</span></div>
            <div class="prop-item"><span class="prop-type">Education</span><strong>Padiham St Leonard&rsquo;s CE Primary</strong><span>Moor Lane &middot; Freehold &middot; 1,905 sqm</span></div>
            <div class="prop-item"><span class="prop-type">Education</span><strong>Padiham Primary School</strong><span>Burnley Road &middot; Freehold &middot; 1,817 sqm</span></div>
            <div class="prop-item"><span class="prop-type">Education</span><strong>Padiham Green CE Primary</strong><span>St Annes Street &middot; Freehold &middot; 1,603 sqm</span></div>
            <div class="prop-item"><span class="prop-type">Education</span><strong>Hapton CE/Methodist Primary</strong><span>Manchester Road &middot; Freehold &middot; 718 sqm</span></div>
            <div class="prop-item"><span class="prop-type">Library</span><strong>Padiham Library</strong><span>Town Hall, Burnley Road &middot; Leasehold</span></div>
            <div class="prop-item"><span class="prop-type">Heritage</span><strong>Gawthorpe Hall</strong><span>off Burnley Road &middot; Grade I Listed</span></div>
            <div class="prop-item"><span class="prop-type">Operations</span><strong>Hapton Fleet Workshop</strong><span>Brindley Close &middot; Leasehold &middot; 2,429 sqm</span></div>
            <div class="prop-item"><span class="prop-type">Children</span><strong>Stoney View Children&rsquo;s Home</strong><span>Malvern Avenue &middot; Freehold &middot; 218 sqm</span></div>
          </div>
          <p class="detail-note" style="margin-top: var(--space-md)">Plus 6 land holdings: Molly Wood Woodlands, Hameldon Hill county woodlands (2 parcels), Padiham Disused Railway, Canning Street Footbridge, and Towneley Reclamation Scheme land.</p>
        </Accordion>
      </ScrollReveal>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container-narrow">
      <ScrollReveal>
        <div class="cta-card card">
          <h2>Have Your Say</h2>
