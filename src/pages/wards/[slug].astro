---
import Layout from '../../layouts/Layout.astro';
import ScrollReveal from '../../components/ScrollReveal.astro';
import Accordion from '../../components/Accordion.astro';
import WardMap3D from '../../components/WardMap3D.astro';
import wardData from '../../data/burnley-wards.json';

export function getStaticPaths() {
  return Object.entries(wardData.wards).map(([slug, ward]: [string, any]) => ({
    params: { slug },
    props: { ward: { ...ward, slug } },
  }));
}

const { ward } = Astro.props;

// Deprivation colour
function depColor(decile: number): string {
  if (decile <= 2) return '#ff453a';
  if (decile <= 4) return '#ff9f0a';
  if (decile <= 6) return '#ffd60a';
  if (decile <= 8) return '#30d158';
  return '#34c759';
}

function depText(decile: number): string {
  const pct = decile * 10;
  if (decile <= 1) return `Top 10% most deprived in England`;
  if (decile <= 2) return `Top 20% most deprived in England`;
  if (decile <= 3) return `Top 30% most deprived in England`;
  return `${pct}th percentile nationally`;
}

const dep = ward.deprivation || {};
const elec = ward.elections || {};
const plan = ward.planning || {};
const crime = wardData.meta?.borough_crime || {};
const councillors = ward.councillors || [];
const depDecile = dep.avg_imd_decile || 5;
const electorate = elec.electorate || 0;
const nextElection = elec.next_election || {};
const currentHolders = elec.current_holders || [];
const history = elec.history || [];
const planTotal = plan.total || 0;
const planRecent = plan.recent || [];
const crimeCategories = crime.categories || [];
const cc = ward.county_council || {};
const mp = wardData.meta?.mp || {};
const pcc = wardData.meta?.pcc || {};
const isTomWard = cc.councillor === 'Tom Pickup';
---

<Layout
  title={`${ward.name} Ward | Tom Pickup`}
  description={`${ward.name} ward in Burnley. Who represents you, deprivation data, election history, planning applications, and more.`}
>
  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">{ward.name}</span>
    </div>
  </nav>

  <!-- Section 1: Header -->
  <section class="ward-header">
    <div class="container">
      <ScrollReveal>
        <div class="ward-header-content">
          <div>
            <h1 class="gradient-text">{ward.name}</h1>
            <p class="ward-subtitle">Burnley Borough Council Ward</p>
          </div>
          <span class="badge" style={`background: color-mix(in srgb, ${ward.party_color} 20%, transparent); color: ${ward.party_color}; border: 1px solid color-mix(in srgb, ${ward.party_color} 35%, transparent);`}>
            {ward.primary_party}
          </span>
        </div>

        <div class="stat-cards stagger-children">
          <div class="stat-card" style={`--accent-stat: ${depColor(depDecile)}`}>
            <span class="stat-value tabular-nums">{depDecile}</span>
            <span class="stat-label">IMD Decile</span>
            <span class="stat-detail" style={`color: ${depColor(depDecile)}`}>{dep.deprivation_level || 'Unknown'}</span>
          </div>
          <div class="stat-card">
            <span class="stat-value tabular-nums">{electorate.toLocaleString()}</span>
            <span class="stat-label">Registered Voters</span>
          </div>
          <div class="stat-card">
            <span class="stat-value tabular-nums">{planTotal}</span>
            <span class="stat-label">Planning Applications</span>
          </div>
          <div class="stat-card">
            <span class="stat-value tabular-nums">{elec.seats || 3}</span>
            <span class="stat-label">Council Seats</span>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 2: Map -->
  <section class="ward-map-section">
    <div class="container">
      <ScrollReveal>
        <WardMap3D activeWard={ward.slug} size="mini" />
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 3: Who Represents You -->
  <section class="representatives-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">Who Represents You</h2>
          <p class="section-subtitle">Your councillors and the tiers of government that serve this ward.</p>
        </div>

        <!-- Tier 1: Borough Council -->
        <div class="tier-block">
          <div class="tier-header">
            <div class="tier-badge" style="background: rgba(255, 159, 10, 0.12); border-color: rgba(255, 159, 10, 0.25);">
              <span class="tier-label" style="color: #ff9f0a;">Burnley Borough Council</span>
              <span class="tier-type">District Council</span>
            </div>
            <p class="tier-explainer">Your borough council handles housing, planning applications, waste collection, parks, leisure centres, and council tax collection.</p>
          </div>
          <div class="councillor-grid stagger-children">
            {councillors.map((c: any) => (
              <div class="councillor-card card">
                <div class="councillor-photo-wrap">
                  <img
                    src={`/images/councillors/${c.id}.jpg`}
                    alt={c.name}
                    class="councillor-photo"
                    loading="lazy"
                    onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                  />
                  <div class="councillor-fallback" style={`display:none; background: color-mix(in srgb, ${c.party_color} 30%, #1c1c1e);`}>
                    {c.name.split(' ').map((n: string) => n[0]).join('')}
                  </div>
                </div>
                <div class="councillor-info">
                  <span class="councillor-name">{c.name}</span>
                  <span class="councillor-party" style={`color: ${c.party_color}`}>{c.party}</span>
                </div>
                <div class="councillor-party-bar" style={`background: ${c.party_color}`}></div>
              </div>
            ))}
          </div>
        </div>

        <!-- Tier 2: County Council -->
        <div class="tier-block">
          <div class="tier-header">
            <div class="tier-badge" style="background: rgba(18, 182, 207, 0.12); border-color: rgba(18, 182, 207, 0.25);">
              <span class="tier-label" style="color: var(--accent);">Lancashire County Council</span>
              <span class="tier-type">County Council</span>
            </div>
            <p class="tier-explainer">Your county council runs schools, children&rsquo;s and adult social care, highways and roads, libraries, and trading standards.</p>
          </div>
          <div class="councillor-grid">
            <div class="councillor-card card">
              <div class="councillor-photo-wrap">
                {isTomWard ? (
                  <img src="/images/headshot.jpg" alt="Tom Pickup" class="councillor-photo" loading="lazy" />
                ) : (
                  <div class="councillor-fallback" style={`display:flex; background: ${cc.party === 'Reform UK' ? 'rgba(18,182,207,0.2)' : 'rgba(128,128,128,0.2)'};`}>
                    {(cc.councillor || '').split(' ').map((n: string) => n[0]).join('')}
                  </div>
                )}
              </div>
              <div class="councillor-info">
                <span class="councillor-name">{cc.councillor || 'Unknown'}</span>
                <span class="councillor-party" style={`color: ${cc.party === 'Reform UK' ? 'var(--accent)' : cc.party === 'Independent' ? '#808080' : '#808080'}`}>{cc.party || 'Unknown'}</span>
                <span class="councillor-role">{cc.ced || 'Unknown'} Division</span>
              </div>
              <div class="councillor-party-bar" style={`background: ${cc.party === 'Reform UK' ? 'var(--accent)' : '#808080'}`}></div>
            </div>
          </div>
        </div>

        <!-- Tier 3: MP -->
        <div class="tier-block">
          <div class="tier-header">
            <div class="tier-badge" style="background: rgba(220, 36, 31, 0.12); border-color: rgba(220, 36, 31, 0.25);">
              <span class="tier-label" style="color: #DC241F;">Member of Parliament</span>
              <span class="tier-type">Burnley Constituency</span>
            </div>
            <p class="tier-explainer">Your MP represents Burnley in the House of Commons, votes on national legislation, and raises local concerns in Parliament.</p>
          </div>
          <div class="mp-card card">
            <div class="mp-info">
              <span class="councillor-name">{mp.name || 'Unknown'}</span>
              <span class="councillor-party" style="color: #DC241F;">{mp.party || 'Unknown'}</span>
            </div>
            <div class="mp-stats">
              <div class="mp-stat">
                <span class="mp-stat-value tabular-nums">{mp.ge2024?.vote_share || 0}%</span>
                <span class="mp-stat-label">Vote Share (2024)</span>
              </div>
              <div class="mp-stat">
                <span class="mp-stat-value tabular-nums">{mp.ge2024?.majority?.toLocaleString() || 0}</span>
                <span class="mp-stat-label">Majority</span>
              </div>
              <div class="mp-stat">
                <span class="mp-stat-value tabular-nums">{mp.voting_attendance || 0}%</span>
                <span class="mp-stat-label">Voting Attendance</span>
              </div>
              <div class="mp-stat">
                <span class="mp-stat-value tabular-nums">&pound;{((mp.expenses_total || 0) / 1000).toFixed(0)}K</span>
                <span class="mp-stat-label">Expenses Claimed</span>
              </div>
            </div>
            <div class="councillor-party-bar" style="background: #DC241F"></div>
          </div>
        </div>

        <!-- Tier 4 & 5: Fire & PCC -->
        <div class="tier-row">
          <div class="tier-block tier-compact">
            <div class="tier-badge" style="background: rgba(255, 69, 58, 0.12); border-color: rgba(255, 69, 58, 0.25);">
              <span class="tier-label" style="color: #ff453a;">Lancashire Fire &amp; Rescue</span>
            </div>
            <p class="tier-explainer">Part of the county council. Fire prevention, emergency response, and community safety across Lancashire.</p>
          </div>

          <div class="tier-block tier-compact">
            <div class="tier-badge" style="background: rgba(191, 90, 242, 0.12); border-color: rgba(191, 90, 242, 0.25);">
              <span class="tier-label" style="color: #bf5af2;">Police &amp; Crime Commissioner</span>
            </div>
            <p class="tier-explainer">Oversees Lancashire Constabulary, sets police priorities, and manages the policing budget for the county.</p>
            <span class="pcc-name">{pcc.name || 'Unknown'} ({pcc.party || 'Unknown'})</span>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 4: Your Area at a Glance -->
  <section class="area-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">Your Area at a Glance</h2>
        </div>

        <div class="area-headline card">
          <div class="dep-badge" style={`background: color-mix(in srgb, ${depColor(depDecile)} 15%, transparent); border: 1px solid color-mix(in srgb, ${depColor(depDecile)} 30%, transparent);`}>
            <span class="dep-decile" style={`color: ${depColor(depDecile)}`}>Decile {depDecile}</span>
          </div>
          <p class="dep-summary">{depText(depDecile)}</p>
          <div class="dep-bar-wrap">
            <div class="dep-bar-track">
              <div class="dep-bar-fill" style={`width: ${(10 - depDecile + 1) * 10}%; background: ${depColor(depDecile)};`}></div>
            </div>
            <div class="dep-bar-labels">
              <span>Most deprived</span>
              <span>Least deprived</span>
            </div>
          </div>
        </div>

        <Accordion title="Full Deprivation Detail">
          <div class="detail-grid">
            <div class="detail-item">
              <span class="detail-label">IMD Score</span>
              <span class="detail-value">{dep.avg_imd_score?.toFixed(1) || 'N/A'}</span>
            </div>
            <div class="detail-item">
              <span class="detail-label">National Percentile</span>
              <span class="detail-value">{dep.national_percentile?.toFixed(1) || 'N/A'}%</span>
            </div>
            <div class="detail-item">
              <span class="detail-label">LSOAs in Ward</span>
              <span class="detail-value">{dep.lsoa_count || 'N/A'}</span>
            </div>
            <div class="detail-item">
              <span class="detail-label">Most Deprived LSOA Rank</span>
              <span class="detail-value">{dep.most_deprived_lsoa_rank?.toLocaleString() || 'N/A'} of 32,844</span>
            </div>
            <div class="detail-item">
              <span class="detail-label">Least Deprived LSOA Rank</span>
              <span class="detail-value">{dep.least_deprived_lsoa_rank?.toLocaleString() || 'N/A'} of 32,844</span>
            </div>
          </div>
        </Accordion>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 5: Elections -->
  <section class="elections-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">Elections</h2>
        </div>

        <div class="election-headline card">
          <div class="election-next">
            <span class="election-date">Next election: <strong>7 May 2026</strong></span>
            {nextElection.defender && (
              <span class="election-defender">
                Defending: <strong>{nextElection.defender.name}</strong> ({nextElection.defender.party})
              </span>
            )}
          </div>
        </div>

        <h3 class="subsection-title">Current Holders</h3>
        <div class="holders-grid">
          {currentHolders.map((h: any) => (
            <div class="holder-card card">
              <span class="holder-name">{h.name}</span>
              <span class="holder-party" style={`color: ${h.party === 'Labour' ? '#DC241F' : h.party === 'Conservative' ? '#0087DC' : h.party === 'Liberal Democrats' ? '#FAA61A' : h.party === 'Green Party' ? '#6AB023' : h.party === 'Reform UK' ? '#12b6cf' : '#808080'}`}>{h.party}</span>
              <span class="holder-year">Elected {h.elected_year || 'N/A'}</span>
            </div>
          ))}
        </div>

        <Accordion title="Full Election History">
          <div class="election-history">
            <table class="history-table">
              <thead>
                <tr>
                  <th>Year</th>
                  <th>Turnout</th>
                  <th>Majority</th>
                  <th>Winner</th>
                </tr>
              </thead>
              <tbody>
                {history.slice(0, 15).map((h: any) => (
                  <tr>
                    <td class="tabular-nums">{h.year}</td>
                    <td class="tabular-nums">{h.turnout_pct ? `${h.turnout_pct}%` : 'N/A'}</td>
                    <td class="tabular-nums">{h.majority || 'N/A'}</td>
                    <td>{h.candidates?.[0]?.name || 'N/A'} ({h.candidates?.[0]?.party || ''})</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </Accordion>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 6: What's Happening Locally -->
  <section class="local-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">What&rsquo;s Happening Locally</h2>
        </div>

        <div class="local-cards">
          <div class="local-stat card">
            <span class="local-stat-value tabular-nums">{planTotal}</span>
            <span class="local-stat-label">Planning applications in the last 3 years</span>
          </div>
          {crimeCategories.length > 0 && (
            <div class="local-stat card">
              <span class="local-stat-value">{crimeCategories[0]?.category || 'N/A'}</span>
              <span class="local-stat-label">Top crime concern in Burnley ({crimeCategories[0]?.count?.toLocaleString() || 0} incidents)</span>
            </div>
          )}
        </div>

        {planRecent.length > 0 && (
          <Accordion title={`Recent Planning Applications (${planRecent.length})`}>
            <div class="planning-list">
              {planRecent.map((app: any) => (
                <div class="planning-item">
                  <div class="planning-header">
                    <span class={`planning-status ${app.state === 'Decided' ? 'status-decided' : 'status-pending'}`}>{app.state || 'Unknown'}</span>
                    <span class="planning-date">{app.start_date || ''}</span>
                  </div>
                  <p class="planning-address">{app.address || 'No address'}</p>
                  <p class="planning-desc">{(app.description || '').slice(0, 150)}{(app.description || '').length > 150 ? '...' : ''}</p>
                </div>
              ))}
            </div>
          </Accordion>
        )}

        {crimeCategories.length > 0 && (
          <Accordion title="Crime Breakdown (Borough-Wide)">
            <div class="crime-list">
              {crimeCategories.slice(0, 10).map((cat: any) => (
                <div class="crime-item">
                  <span class="crime-cat">{cat.category}</span>
                  <span class="crime-count tabular-nums">{cat.count?.toLocaleString()}</span>
                </div>
              ))}
            </div>
          </Accordion>
        )}
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 7: Contact -->
  <section class="deep-dive-section">
    <div class="container">
      <ScrollReveal>
        <div class="deep-dive-card">
          <div class="deep-dive-lines"></div>
          <div class="deep-dive-inner">
            <h2>Got a question about {ward.name}?</h2>
            <p>
              Whether it&rsquo;s planning, housing, bins, or anything else in your area &mdash; get in touch.
            </p>
            <div class="deep-dive-actions">
              <a href="/contact/" class="btn-primary">
                Contact Me
              </a>
              <a href="/report/" class="btn-secondary">Report an Issue</a>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>
</Layout>

<style>
  /* ---- Breadcrumb ---- */
  .breadcrumb {
    padding: calc(56px + var(--space-lg)) 0 0;
    font-size: 0.8125rem;
    color: var(--text-tertiary);
  }

  .breadcrumb a {
    color: var(--text-tertiary);
  }

  .breadcrumb a:hover {
    color: var(--accent);
  }

  .breadcrumb-sep {
    margin: 0 var(--space-sm);
  }

  .breadcrumb-current {
    color: var(--text-secondary);
  }

  /* ---- Ward Header ---- */
  .ward-header {
    padding: var(--space-xl) 0 var(--space-lg);
  }

  .ward-header-content {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .ward-subtitle {
    color: var(--text-secondary);
    font-size: 1rem;
    margin-top: var(--space-xs);
  }

  /* ---- Stat Cards ---- */
  .stat-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }

  .stat-card {
    background: rgba(28, 28, 30, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--text-primary);
  }

  .stat-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-detail {
    font-size: 0.8125rem;
    font-weight: 600;
    margin-top: 2px;
  }

  /* ---- Map Section ---- */
  .ward-map-section {
    padding: 0 0 var(--space-xl);
  }

  /* ---- Representatives ---- */
  .representatives-section {
    padding: var(--space-xl) 0 var(--space-2xl);
  }

  .tier-block {
    margin-bottom: var(--space-xl);
  }

  .tier-header {
    margin-bottom: var(--space-lg);
  }

  .tier-badge {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid;
    margin-bottom: var(--space-sm);
  }

  .tier-label {
    font-size: 0.875rem;
    font-weight: 700;
  }

  .tier-type {
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    font-weight: 500;
  }

  .tier-explainer {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 600px;
  }

  .tier-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  .tier-compact {
    background: rgba(28, 28, 30, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
  }

  .pcc-name {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-top: var(--space-sm);
  }

  /* ---- Councillor Cards ---- */
  .councillor-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .councillor-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xl) var(--space-lg);
    overflow: hidden;
  }

  .councillor-party-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
  }

  .councillor-photo-wrap {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
  }

  .councillor-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s var(--ease-smooth);
  }

  .councillor-card:hover .councillor-photo {
    transform: scale(1.08);
  }

  .councillor-fallback {
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    border-radius: 50%;
  }

  .councillor-info {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .councillor-name {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .councillor-party {
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .councillor-role {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    margin-top: 2px;
  }

  /* ---- MP Card ---- */
  .mp-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    overflow: hidden;
  }

  .mp-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mp-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-sm);
  }

  .mp-stat {
    display: flex;
    flex-direction: column;
