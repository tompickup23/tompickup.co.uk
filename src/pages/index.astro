---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import PriorityCard from '../components/PriorityCard.astro';
import ComparisonBar from '../components/ComparisonBar.astro';
import TrustCertificate from '../components/TrustCertificate.astro';
import NewsCard from '../components/NewsCard.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import EmailSignup from '../components/EmailSignup.astro';
import WardMap3D from '../components/WardMap3D.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Layout title="Tom Pickup | Lancashire County Councillor for Padiham & Burnley West">
  <!-- Section 1: Hero -->
  <Hero />

  <!-- Section 2: What I Stand For -->
  <section class="priorities-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">What I Stand For</h2>
          <p class="section-subtitle">My priorities as your councillor for Padiham and Burnley West</p>
        </div>

        <div class="priorities-grid stagger-children">
          <PriorityCard
            title="Council Tax: 7 Years of Maximum Rises: Ended"
            icon='<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>'
            description="The Conservatives raised council tax to the legal maximum in 7 of their 8 years in control, including the highest rise in Lancashire&rsquo;s history at 5.99%. Reform&rsquo;s first budget delivered 3.80%, the lowest in 12 years."
          />
          <PriorityCard
            title="&pound;28M Inherited Overspend: Nearly Eliminated"
            icon='<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 7a4 4 0 0 0-4-4H9a4 4 0 0 0-1 7.87V16H6m2-5h6"></path><line x1="6" y1="20" x2="18" y2="20"></line></svg>'
            description="When Reform took control, LCC was forecasting a &pound;28 million overspend. Through targeted action, we&rsquo;ve cut it to &pound;6.1 million and falling, without slashing front-line services."
            color="#ff9f0a"
          />
          <PriorityCard
            title="Five County Care Homes: Future Secured"
            icon='<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>'
            description="We inherited a Conservative consultation on the future of five county care homes. After listening to 1,600+ residents, we secured their future with new investment pledged, because elderly care isn&rsquo;t a line to cut."
            color="#30d158"
          />
          <PriorityCard
            title="&pound;350M Bond Losses the Conservatives Concealed: Exposed"
            icon='<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>'
            description="&pound;519 million invested in VeLTIP bonds now worth an estimated &pound;169 million. The previous Conservative administration failed to transparently report the true scale of these paper losses to councillors or the public."
            color="#bf5af2"
          />
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 3: Find Your Ward -->
  <section class="ward-finder-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header" style="text-align: center;">
          <h2 class="section-heading">Your Ward. Your Councillors. Your Services.</h2>
          <p class="section-subtitle" style="max-width: 600px; margin: var(--space-sm) auto 0;">
            Select your ward to see who represents you, how your area compares, and what&rsquo;s happening locally.
          </p>
        </div>

        <WardMap3D size="full" />
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 4: Latest News -->
  <section class="news-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">Latest News &amp; Updates</h2>
        </div>

        {posts.length > 0 ? (
          <div class="news-grid stagger-children">
            {posts.map((post) => (
              <NewsCard
                title={post.data.title}
                date={post.data.date.toISOString()}
                description={post.data.description}
                tags={post.data.tags}
                slug={post.id}
                image={post.data.image}
              />
            ))}
          </div>
        ) : (
          <p class="empty-state text-secondary">No posts yet. Check back soon.</p>
        )}

        <div class="news-more">
          <a href="/news/" class="btn-secondary">
            View all news
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 4: Reform at LCC -->
  <section class="reform-section">
    <div class="container">
      <ScrollReveal>
        <div class="reform-card">
          <div class="reform-content">
            <div class="reform-text">
              <span class="badge badge-teal">Reform UK at Lancashire County Council</span>
              <h2>Changing Lancashire for the Better</h2>
              <p>
                In May 2025, Reform won a historic landslide, 53 of 84 seats. In our first year,
                we&rsquo;ve delivered a balanced &pound;1.33 billion budget with the lowest council tax rise
                in 12 years. We corrected a &pound;28 million inherited overspend, saved all five county
                care homes, and stopped councillors collecting salaries for pension fund directorships.
              </p>
              <p>
                The previous Conservative administration raised council tax to the maximum in 7 of 8 years,
                saw savings delivery collapse from 91% to 48%, and left &pound;350 million in concealed bond losses.
                We&rsquo;re doing things differently.
              </p>
              <a
                href="/news/"
                class="btn-primary reform-cta"
              >
                Read the Full Story
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </div>

            <div class="reform-comparisons">
              <ComparisonBar
                title="Council Tax Rise"
                reformValue="3.80%"
                reformPercent={63}
                conValue="4.99%"
                conPercent={83}
                lowerIsBetter={true}
                annotation="Reform delivered the lowest council tax rise in 12 years"
              />
              <ComparisonBar
                title="Savings Delivery Rate"
                reformValue="90%+"
                reformPercent={90}
                conValue="48%"
                conPercent={48}
                annotation="Conservative savings delivery collapsed over 8 years"
              />
              <ComparisonBar
                title="Overspend"
                reformValue="&pound;6.1M"
                reformPercent={22}
                conValue="&pound;28M"
                conPercent={100}
                lowerIsBetter={true}
                annotation="78% reduction in inherited overspend without front-line cuts"
              />
            </div>

            <div class="reform-stats">
              <div class="reform-stat">
                <span class="reform-stat-value tabular-nums">3.80%</span>
                <span class="reform-stat-label">Lowest CT Rise in 12 Years</span>
              </div>
              <div class="reform-stat">
                <span class="reform-stat-value tabular-nums">&pound;62M</span>
                <span class="reform-stat-label">Savings Programme</span>
              </div>
              <div class="reform-stat">
                <span class="reform-stat-value tabular-nums">&pound;1.33B</span>
                <span class="reform-stat-label">Balanced Budget</span>
              </div>
            </div>

            <div class="reform-trust">
              <TrustCertificate />
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 5: Email Signup -->
  <section class="signup-section">
    <div class="container">
      <ScrollReveal>
        <EmailSignup variant="inline" />
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 6: Contact CTA -->
  <section class="contact-cta-section">
    <div class="container">
      <ScrollReveal>
        <div class="contact-cta-card">
          <div class="contact-cta-lines"></div>
          <div class="contact-cta-inner">
            <h2>Have a Question or Concern?</h2>
            <p>
              I'm here to help. Whether it's a local issue, a question about council decisions, or
              you just want to say hello, get in touch.
            </p>
            <div class="contact-cta-actions">
              <a href="/contact/" class="cta-btn-white">Contact Me</a>
              <a href="/contact/#surgery" class="cta-btn-ghost">View Surgery Dates</a>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>
</Layout>

<style>
  /* ---- Section Spacing ---- */
  .priorities-section,
  .news-section,
  .reform-section,
  .ward-finder-section {
    padding: var(--space-2xl) 0;
  }

  .signup-section {
    padding: 0 0 var(--space-xl);
  }

  .contact-cta-section {
    padding: var(--space-xl) 0 var(--space-2xl);
  }

  /* ---- Section Headers ---- */
  .section-header {
    margin-bottom: var(--space-xl);
  }

  .section-subtitle {
    color: var(--text-secondary);
    font-size: 1.0625rem;
    margin-top: var(--space-sm);
    max-width: 520px;
  }

  /* ---- Priorities Grid ---- */
  .priorities-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  /* ---- News Grid ---- */
  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .news-more {
    text-align: center;
    margin-top: var(--space-xl);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-2xl) var(--space-lg);
  }

  /* ---- Reform Card ---- */
  .reform-card {
    background: rgba(28, 28, 30, 0.6);
    backdrop-filter: blur(20px) saturate(1.2) brightness(1.02);
    -webkit-backdrop-filter: blur(20px) saturate(1.2) brightness(1.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition: box-shadow var(--transition-normal), border-color var(--transition-normal);
  }

  .reform-card:hover {
    box-shadow: var(--shadow-lg), var(--shadow-glow);
    border-color: rgba(255, 255, 255, 0.1);
    border-left-color: var(--accent);
  }

  .reform-content {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .reform-comparisons {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    grid-column: 1 / -1;
  }

  .reform-trust {
    grid-column: 1 / -1;
  }

  .reform-text h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: var(--space-md) 0 var(--space-md);
    background: linear-gradient(135deg, #ffffff 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .reform-text p {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .reform-cta {
    margin-top: var(--space-sm);
  }

  .reform-stats {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .reform-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: var(--space-lg) var(--space-md);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-normal), transform var(--transition-fast);
  }

  .reform-stat:hover {
    border-color: var(--accent-border);
    transform: translateY(-2px);
  }

  .reform-stat-value {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--accent);
    line-height: 1.1;
  }

  .reform-stat-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ---- Contact CTA ---- */
  .contact-cta-card {
    position: relative;
    background:
      radial-gradient(ellipse 80% 60% at 20% 80%, rgba(18, 182, 207, 0.4) 0%, transparent 50%),
      linear-gradient(135deg, #0a2a3a 0%, #12b6cf 100%);
    border-radius: var(--radius-xl);
    overflow: hidden;
    padding: var(--space-2xl) var(--space-xl);
    text-align: center;
  }

  .contact-cta-lines {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        135deg,
        transparent,
        transparent 40px,
        rgba(255, 255, 255, 0.03) 40px,
        rgba(255, 255, 255, 0.03) 41px
      );
    pointer-events: none;
  }

  .contact-cta-inner {
    position: relative;
    z-index: 1;
    max-width: 560px;
    margin: 0 auto;
  }

  .contact-cta-inner h2 {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: #ffffff;
    margin-bottom: var(--space-md);
  }

  .contact-cta-inner p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.0625rem;
    line-height: 1.65;
    margin: 0 auto var(--space-xl);
    max-width: 480px;
  }

  .contact-cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .cta-btn-white {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: 0.7rem 1.75rem;
    background: #ffffff;
    color: #0a2a3a;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    background-image: none;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.2);
    transition: transform var(--transition-fast), box-shadow var(--transition-normal);
  }

  .cta-btn-white:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    background-image: none;
    background-size: 0;
  }

  .cta-btn-white:active {
    transform: scale(0.97) translateY(0);
  }

  .cta-btn-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: 0.7rem 1.75rem;
    background: transparent;
    color: #ffffff;
    font-weight: 500;
    font-size: 0.9375rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.3);
    text-decoration: none;
    background-image: none;
    transition: transform var(--transition-fast), background-color var(--transition-normal), border-color var(--transition-normal);
  }

  .cta-btn-ghost:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.5);
    transform: translateY(-2px);
    background-image: none;
    background-size: 0;
  }

  .cta-btn-ghost:active {
    transform: scale(0.97) translateY(0);
  }

  /* ---- Responsive ---- */
  @media (max-width: 1024px) {
    .reform-content {
      grid-template-columns: 1fr;
    }

    .reform-stats {
      flex-direction: row;
    }

    .reform-stat {
      flex: 1;
    }
  }

  @media (max-width: 768px) {
    .priorities-grid {
      grid-template-columns: 1fr;
    }

    .news-grid {
      grid-template-columns: 1fr;
    }

    .reform-stats {
      flex-direction: column;
    }

    .reform-card {
      padding: var(--space-lg);
    }

    .contact-cta-card {
      padding: var(--space-xl) var(--space-lg);
    }

    .contact-cta-actions {
      flex-direction: column;
    }

    .cta-btn-white,
    .cta-btn-ghost {
      width: 100%;
    }
  }

  @media (max-width: 480px) {
    .priorities-section,
    .news-section,
    .reform-section {
      padding: var(--space-xl) 0;
    }

    .contact-cta-card {
      padding: var(--space-xl) var(--space-md);
      border-radius: var(--radius-lg);
    }

    .reform-card {
      padding: var(--space-md);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reform-stat {
      transition: none;
    }
  }
</style>
