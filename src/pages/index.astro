---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import PriorityCard from '../components/PriorityCard.astro';
import NewsCard from '../components/NewsCard.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Layout title="Tom Pickup — Lancashire County Councillor for Padiham & Burnley West">
  <!-- Section 1: Hero -->
  <Hero />

  <!-- Section 2: What I Stand For -->
  <section class="priorities-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">What I Stand For</h2>
          <p class="section-subtitle">My priorities as your councillor for Padiham and Burnley West</p>
        </div>

        <div class="priorities-grid stagger-children">
          <PriorityCard
            title="Spending Transparency"
            icon='<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>'
            description="Every pound of public money should be accounted for. I built the AI DOGE platform to track over £12 billion in council spending across Lancashire — exposing duplicate payments, contract irregularities, and wasteful spending. Transparency isn't optional; it's the foundation of trust."
          />
          <PriorityCard
            title="Better Local Services"
            icon='<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>'
            description="Potholes, missed bin collections, overgrown verges — the basics matter. I push both Lancashire County Council and Burnley Borough Council to deliver the services residents pay for. If something isn't right in Padiham or Burnley West, I want to know about it."
            color="#30d158"
          />
          <PriorityCard
            title="Value for Money"
            icon='<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>'
            description="Council tax keeps rising while services get cut. I challenge wasteful spending, scrutinise contracts, and ask the uncomfortable questions about where your money goes. Duplicate payments, sole-supplier deals, and inflated costs — I'm on it."
            color="#ff9f0a"
          />
          <PriorityCard
            title="Community First"
            icon='<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>'
            description="I'm here to listen. Whether it's a planning concern, an issue with a local road, or an idea to improve our area — your voice matters. I hold regular surgeries and I'm always available to residents of Padiham and Burnley West. This is your seat, not mine."
            color="#bf5af2"
          />
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 3: Latest News -->
  <section class="news-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">Latest News &amp; Updates</h2>
        </div>

        {posts.length > 0 ? (
          <div class="news-grid stagger-children">
            {posts.map((post) => (
              <NewsCard
                title={post.data.title}
                date={post.data.date.toISOString()}
                description={post.data.description}
                tags={post.data.tags}
                slug={post.id}
              />
            ))}
          </div>
        ) : (
          <p class="empty-state text-secondary">No posts yet. Check back soon.</p>
        )}

        <div class="news-more">
          <a href="/news/" class="btn-secondary">
            View all news
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 4: AI DOGE Highlight -->
  <section class="doge-section">
    <div class="container">
      <ScrollReveal>
        <div class="doge-card">
          <div class="doge-content">
            <div class="doge-text">
              <span class="badge badge-teal">Open Data Platform</span>
              <h2>AI DOGE</h2>
              <p>
                I created AI DOGE to bring radical transparency to council spending across Lancashire.
                Using AI-powered forensic analysis, the platform tracks every transaction, flags duplicate
                payments, monitors supplier concentration, and benchmarks spending across all 15 Lancashire councils.
              </p>
              <p>
                This isn't about politics — it's about making sure your council tax is spent wisely. Every
                dataset is public, every finding is verifiable, and every resident can see exactly where
                the money goes.
              </p>
              <a
                href="https://aidoge.co.uk/lancashire/lancashirecc/"
                class="btn-primary doge-cta"
                target="_blank"
                rel="noopener noreferrer"
              >
                Explore the Data
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </div>

            <div class="doge-stats">
              <div class="doge-stat">
                <span class="doge-stat-value tabular-nums">15</span>
                <span class="doge-stat-label">Councils</span>
              </div>
              <div class="doge-stat">
                <span class="doge-stat-value tabular-nums">2.3M+</span>
                <span class="doge-stat-label">Transactions</span>
              </div>
              <div class="doge-stat">
                <span class="doge-stat-value tabular-nums">&pound;12B+</span>
                <span class="doge-stat-label">Tracked</span>
              </div>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Section 5: Contact CTA -->
  <section class="contact-cta-section">
    <div class="container">
      <ScrollReveal>
        <div class="contact-cta-card">
          <div class="contact-cta-lines"></div>
          <div class="contact-cta-inner">
            <h2>Have a Question or Concern?</h2>
            <p>
              I'm here to help. Whether it's a local issue, a question about council decisions, or
              you just want to say hello — get in touch.
            </p>
            <div class="contact-cta-actions">
              <a href="/contact/" class="cta-btn-white">Contact Me</a>
              <a href="/contact/#surgery" class="cta-btn-ghost">View Surgery Dates</a>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>
</Layout>

<style>
  /* ---- Section Spacing ---- */
  .priorities-section,
  .news-section,
  .doge-section {
    padding: var(--space-2xl) 0;
  }

  .contact-cta-section {
    padding: var(--space-xl) 0 var(--space-2xl);
  }

  /* ---- Section Headers ---- */
  .section-header {
    margin-bottom: var(--space-xl);
  }

  .section-subtitle {
    color: var(--text-secondary);
    font-size: 1.0625rem;
    margin-top: var(--space-sm);
    max-width: 520px;
  }

  /* ---- Priorities Grid ---- */
  .priorities-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  /* ---- News Grid ---- */
  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .news-more {
    text-align: center;
    margin-top: var(--space-xl);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-2xl) var(--space-lg);
  }

  /* ---- AI DOGE Card ---- */
  .doge-card {
    background: rgba(28, 28, 30, 0.6);
    backdrop-filter: blur(20px) saturate(1.2) brightness(1.02);
    -webkit-backdrop-filter: blur(20px) saturate(1.2) brightness(1.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition: box-shadow var(--transition-normal), border-color var(--transition-normal);
  }

  .doge-card:hover {
    box-shadow: var(--shadow-lg), var(--shadow-glow);
    border-color: rgba(255, 255, 255, 0.1);
    border-left-color: var(--accent);
  }

  .doge-content {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .doge-text h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: var(--space-md) 0 var(--space-md);
    background: linear-gradient(135deg, #ffffff 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .doge-text p {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .doge-cta {
    margin-top: var(--space-sm);
  }

  .doge-stats {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .doge-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: var(--space-lg) var(--space-md);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-normal), transform var(--transition-fast);
  }

  .doge-stat:hover {
    border-color: var(--accent-border);
    transform: translateY(-2px);
  }

  .doge-stat-value {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--accent);
    line-height: 1.1;
  }

  .doge-stat-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ---- Contact CTA ---- */
  .contact-cta-card {
    position: relative;
    background:
      radial-gradient(ellipse 80% 60% at 20% 80%, rgba(18, 182, 207, 0.4) 0%, transparent 50%),
      linear-gradient(135deg, #0a2a3a 0%, #12b6cf 100%);
    border-radius: var(--radius-xl);
    overflow: hidden;
    padding: var(--space-2xl) var(--space-xl);
    text-align: center;
  }

  .contact-cta-lines {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        135deg,
        transparent,
        transparent 40px,
        rgba(255, 255, 255, 0.03) 40px,
        rgba(255, 255, 255, 0.03) 41px
      );
    pointer-events: none;
  }

  .contact-cta-inner {
    position: relative;
    z-index: 1;
    max-width: 560px;
    margin: 0 auto;
  }

  .contact-cta-inner h2 {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: #ffffff;
    margin-bottom: var(--space-md);
  }

  .contact-cta-inner p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.0625rem;
    line-height: 1.65;
    margin: 0 auto var(--space-xl);
    max-width: 480px;
  }

  .contact-cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .cta-btn-white {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: 0.7rem 1.75rem;
    background: #ffffff;
    color: #0a2a3a;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    background-image: none;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.2);
    transition: transform var(--transition-fast), box-shadow var(--transition-normal);
  }

  .cta-btn-white:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    background-image: none;
    background-size: 0;
  }

  .cta-btn-white:active {
    transform: scale(0.97) translateY(0);
  }

  .cta-btn-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: 0.7rem 1.75rem;
    background: transparent;
    color: #ffffff;
    font-weight: 500;
    font-size: 0.9375rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.3);
    text-decoration: none;
    background-image: none;
    transition: transform var(--transition-fast), background-color var(--transition-normal), border-color var(--transition-normal);
  }

  .cta-btn-ghost:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.5);
    transform: translateY(-2px);
    background-image: none;
    background-size: 0;
  }

  .cta-btn-ghost:active {
    transform: scale(0.97) translateY(0);
  }

  /* ---- Responsive ---- */
  @media (max-width: 1024px) {
    .doge-content {
      grid-template-columns: 1fr;
    }

    .doge-stats {
      flex-direction: row;
    }

    .doge-stat {
      flex: 1;
    }
  }

  @media (max-width: 768px) {
    .priorities-grid {
      grid-template-columns: 1fr;
    }

    .news-grid {
      grid-template-columns: 1fr;
    }

    .doge-stats {
      flex-direction: column;
    }

    .doge-card {
      padding: var(--space-lg);
    }

    .contact-cta-card {
      padding: var(--space-xl) var(--space-lg);
    }

    .contact-cta-actions {
      flex-direction: column;
    }

    .cta-btn-white,
    .cta-btn-ghost {
      width: 100%;
    }
  }

  @media (max-width: 480px) {
    .priorities-section,
    .news-section,
    .doge-section {
      padding: var(--space-xl) 0;
    }

    .contact-cta-card {
      padding: var(--space-xl) var(--space-md);
      border-radius: var(--radius-lg);
    }

    .doge-card {
      padding: var(--space-md);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .doge-stat {
      transition: none;
    }
  }
</style>
