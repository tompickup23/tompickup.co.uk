---
import Layout from '../../layouts/Layout.astro';
import NewsCard from '../../components/NewsCard.astro';
import ScrollReveal from '../../components/ScrollReveal.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = posts.find((p) => p.data.featured) || posts[0];
const rest = posts.filter((p) => p !== featured);

function formatDate(dateStr: Date): string {
  try {
    return dateStr.toLocaleDateString('en-GB', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    });
  } catch {
    return '';
  }
}
---

<Layout title="News & Updates | Tom Pickup" description="Latest news and updates from Tom Pickup, Lancashire County Councillor for Padiham and Burnley West.">
  <div class="news-page">
    <header class="page-header">
      <h1 class="page-title">News &amp; Updates</h1>
      <p class="page-subtitle">
        What I&rsquo;m working on, what&rsquo;s happening at County Hall, and issues affecting Padiham and Burnley West.
      </p>
    </header>

    {posts.length === 0 ? (
      <div class="empty-state">
        <p>No posts yet. Check back soon.</p>
      </div>
    ) : (
      <>
        {/* Featured Article */}
        {featured && (
          <ScrollReveal>
            <a href={`/news/${featured.id}`} class="featured-card">
              {featured.data.image && (
                <div class="featured-image">
                  <img src={featured.data.image} alt="" loading="eager" decoding="async" />
                </div>
              )}
              <div class="featured-content">
                {featured.data.tags && featured.data.tags.length > 0 && (
                  <div class="featured-tags">
                    {featured.data.tags.map((tag) => (
                      <span class="featured-tag">{tag}</span>
                    ))}
                  </div>
                )}
                <h2 class="featured-title">{featured.data.title}</h2>
                <time class="featured-date" datetime={featured.data.date.toISOString()}>
                  {formatDate(featured.data.date)}
                </time>
                <p class="featured-description">{featured.data.description}</p>
                <span class="featured-read">
                  Read full article
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </span>
              </div>
            </a>
          </ScrollReveal>
        )}

        {/* Rest of the articles */}
        {rest.length > 0 && (
          <div class="posts-grid stagger-children">
            {rest.map((post) => (
              <ScrollReveal>
                <NewsCard
                  title={post.data.title}
                  date={post.data.date.toISOString()}
                  description={post.data.description}
                  tags={post.data.tags}
                  slug={post.id}
                  image={post.data.image}
                />
              </ScrollReveal>
            ))}
          </div>
        )}
      </>
    )}

    <div class="rss-link">
      <a href="/rss.xml" aria-label="Subscribe to RSS feed">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="2" cy="12" r="1.5" fill="currentColor"/>
          <path d="M0.5 7.5C3.81 7.5 6.5 10.19 6.5 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M0.5 2.5C6.58 2.5 11.5 7.42 11.5 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Subscribe via RSS
      </a>
    </div>
  </div>
</Layout>

<style>
  .news-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
    background: linear-gradient(135deg, #ffffff 0%, #12b6cf 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page-subtitle {
    font-size: 1.0625rem;
    color: var(--text-secondary, #8e8e93);
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ---- Featured Card ---- */
  .featured-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    background: rgba(28, 28, 30, 0.7);
    backdrop-filter: blur(20px) saturate(1.2);
    -webkit-backdrop-filter: blur(20px) saturate(1.2);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: #fff;
    margin-bottom: var(--space-xl, 2rem);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    background-image: none;
  }

  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
    border-color: rgba(255, 255, 255, 0.12);
    background-image: none;
  }

  .featured-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 75%;
    display: block;
    transition: transform 0.4s ease;
  }

  .featured-card:hover .featured-image img {
    transform: scale(1.04);
  }

  .featured-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-xl, 2rem);
    gap: 10px;
  }

  .featured-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .featured-tag {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: 9999px;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: rgba(18, 182, 207, 0.12);
    color: #12b6cf;
    border: 1px solid rgba(18, 182, 207, 0.15);
  }

  .featured-title {
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .featured-date {
    font-size: 0.8125rem;
    color: rgba(235, 235, 245, 0.4);
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }

  .featured-description {
    font-size: 0.9375rem;
    color: rgba(235, 235, 245, 0.6);
    line-height: 1.6;
    margin: 0;
  }

  .featured-read {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    color: #12b6cf;
    font-weight: 500;
    margin-top: auto;
    transition: gap 0.2s ease;
  }

  .featured-card:hover .featured-read {
    gap: 10px;
  }

  /* ---- Posts Grid ---- */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* Ensure ScrollReveal wrappers stretch to fill grid cells for uniform card heights */
  .posts-grid > :global(.reveal) {
    height: 100%;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--text-secondary, #8e8e93);
    font-size: 1.0625rem;
  }

  .rss-link {
    text-align: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .rss-link a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary, #8e8e93);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
    background-image: none;
  }

  .rss-link a:hover {
    color: #12b6cf;
    background-image: none;
  }

  @media (max-width: 900px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .featured-card {
      grid-template-columns: 1fr;
    }

    .featured-image {
      aspect-ratio: 16 / 9;
    }

    .featured-content {
      padding: var(--space-lg, 1.5rem);
    }
  }

  @media (max-width: 600px) {
    .news-page {
      padding: 1.5rem 1rem 3rem;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .page-title {
      font-size: 2rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .featured-card,
    .featured-image img,
    .featured-read {
      transition: none;
    }
  }
</style>
