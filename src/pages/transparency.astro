---
import Layout from '../layouts/Layout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
---

<Layout title="Transparency | Tom Pickup" description="Tracking &pound;12B+ in public spending across all 15 Lancashire councils. Forensic analysis, councillor integrity checks, and full transaction data.">
  <div class="transparency-page">

    <!-- Section 1: Page Header -->
    <header class="page-header">
      <h1 class="gradient-text">Transparency</h1>
      <p class="page-subtitle">
        I believe every penny of public money should be accounted for. That&rsquo;s why I track
        every transaction across all 15 Lancashire councils.
      </p>
    </header>

    <!-- Section 2: Key Stats -->
    <ScrollReveal>
      <section class="stats-section">
        <div class="stats-grid stagger-children">
          <div class="impact-card" data-accent="teal">
            <div class="impact-accent"></div>
            <div class="impact-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 21h18"></path>
                <path d="M5 21V7l8-4v18"></path>
                <path d="M19 21V11l-6-4"></path>
                <path d="M9 9v.01"></path>
                <path d="M9 12v.01"></path>
                <path d="M9 15v.01"></path>
                <path d="M9 18v.01"></path>
              </svg>
            </div>
            <span class="impact-value tabular-nums">15</span>
            <span class="impact-label">Lancashire Councils</span>
          </div>

          <div class="impact-card" data-accent="green">
            <div class="impact-accent"></div>
            <div class="impact-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
                <polyline points="10 9 9 9 8 9"></polyline>
              </svg>
            </div>
            <span class="impact-value tabular-nums">2.3M+</span>
            <span class="impact-label">Transactions Analysed</span>
          </div>

          <div class="impact-card" data-accent="blue">
            <div class="impact-accent"></div>
            <div class="impact-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 7c-1-2-3.5-3-6-3-3.3 0-6 2.7-6 6 0 1.5.5 2.8 1.3 3.8"></path><path d="M4 17h12"></path><path d="M4 13h8"></path><path d="M10 7v14"></path>
              </svg>
            </div>
            <span class="impact-value tabular-nums">&pound;12B+</span>
            <span class="impact-label">Public Spending Tracked</span>
          </div>

          <div class="impact-card" data-accent="purple">
            <div class="impact-accent"></div>
            <div class="impact-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
              </svg>
            </div>
            <span class="impact-value tabular-nums">35+</span>
            <span class="impact-label">Forensic Techniques</span>
          </div>
        </div>
      </section>
    </ScrollReveal>

    <!-- Section 3: How I Track Public Spending -->
    <ScrollReveal>
      <section class="about-section">
        <div class="about-card card">
          <h2 class="section-heading">How I Track Public Spending</h2>
          <div class="about-content">
            <p>
              I analyse public spending data from all 15 Lancashire councils &mdash; from small district councils like Ribble Valley to Lancashire County Council itself and the two unitary authorities, Blackpool and Blackburn with Darwen. Every transaction is searchable, every supplier is tracked, and every pattern is flagged.
            </p>
            <p>
              My analysis applies 35+ forensic techniques drawn from professional audit standards (ACFE, INTOSAI, Nigrini). These include duplicate payment detection, split payment evasion analysis, Benford&rsquo;s Law screening of payment distributions, supplier concentration scoring, year-end spike detection, round-number anomaly checks, payment cadence analysis, and weak competition flagging.
            </p>
            <p>
              The data also covers councillor integrity checks &mdash; including Companies House directorships and Electoral Commission donations &mdash; budget breakdowns sourced directly from GOV.UK outturn data, procurement notices, council tax collection rates, and ward-level deprivation data.
            </p>
            <p>
              This work is independent and not affiliated with any council or political party. I built it because residents deserve to see exactly where their money goes, and to hold decision-makers to account with hard data, not just rhetoric.
            </p>
          </div>
        </div>
      </section>
    </ScrollReveal>

    <!-- Section 4: What We've Found in Burnley -->
    <ScrollReveal>
      <section class="findings-section">
        <h2 class="section-heading">What I Found at Burnley Council</h2>
        <p class="findings-intro">These are real findings from forensic analysis of 30,580 Burnley Council transactions totalling &pound;355 million. Every finding is backed by published spending data you can verify yourself.</p>
        <div class="findings-grid stagger-children">

          <div class="finding-card card">
            <div class="finding-accent" data-color="teal"></div>
            <div class="finding-icon" style="color: var(--accent);">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                <line x1="8" y1="21" x2="16" y2="21"></line>
                <line x1="12" y1="17" x2="12" y2="21"></line>
                <path d="M6 8h.01"></path>
                <path d="M10 8h.01"></path>
                <path d="M14 8h.01"></path>
              </svg>
            </div>
            <span class="finding-stat">&pound;510,700</span>
            <h3>Payments Made Twice</h3>
            <p>137 high-confidence duplicate payment groups: identical amounts to the same suppliers on the same dates. That&rsquo;s money that could fund Burnley&rsquo;s library service for a year.</p>
            <span class="finding-source">Source: Published council spending data</span>
          </div>

          <div class="finding-card card">
            <div class="finding-accent" data-color="green"></div>
            <div class="finding-icon" style="color: var(--accent-green);">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 20V10"></path>
                <path d="M12 20V4"></path>
                <path d="M6 20v-6"></path>
              </svg>
            </div>
            <span class="finding-stat">&pound;5.1M</span>
            <h3>Bills Split to Avoid Checks</h3>
            <p>11 suspected split payment instances where invoices appear to have been broken up to stay below approval thresholds, 80% or more of the limit each time.</p>
            <span class="finding-source">Source: Published council spending data</span>
          </div>

          <div class="finding-card card">
            <div class="finding-accent" data-color="purple"></div>
            <div class="finding-icon" style="color: var(--accent-purple);">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                <line x1="12" y1="17" x2="12.01" y2="17"></line>
              </svg>
            </div>
            <span class="finding-stat">23</span>
            <h3>Contracts Without Proper Competition</h3>
            <p>Contracts awarded with limited competition indicators: short tender windows, single bidders, or rapid awards that suggest the outcome was predetermined.</p>
            <span class="finding-source">Source: Published council spending data</span>
          </div>

        </div>

        <div class="findings-note">
          <p>100% of Burnley Council transactions have no description. The worst transparency of any East Lancashire council. 13.2% are missing department data entirely.</p>
        </div>
      </section>
    </ScrollReveal>

    <!-- Section 5: What I Track -->
    <ScrollReveal>
      <section class="cta-section">
        <div class="cta-card card">
          <div class="cta-inner">
            <div class="cta-screenshot">
              <div class="screenshot-placeholder">
                <span class="screenshot-stat">&pound;12B+</span>
                <span>Tracked Across Lancashire</span>
                <small>All 15 Councils</small>
              </div>
            </div>
            <div class="cta-content">
              <h2 class="section-heading">What I Track Across Lancashire</h2>
              <p>
                Every transaction across all 15 Lancashire councils. Forensic analysis of spending patterns. Councillor integrity checks.
                Budget breakdowns from GOV.UK. Procurement notices and supplier concentration. Want to know something specific? Get in touch.
              </p>
              <div class="cta-buttons">
                <a href="/contact/" class="btn-primary">
                  Ask Me About Spending
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </a>
                <a href="/burnley/" class="btn-secondary">
                  Explore Burnley
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>
    </ScrollReveal>

    <!-- Section 6: FOI Guidance -->
    <ScrollReveal>
      <section class="foi-section">
        <div class="foi-card card">
          <div class="foi-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
          </div>
          <h2 class="section-heading">Making a Freedom of Information Request</h2>
          <div class="foi-content">
            <p>
              The Freedom of Information Act 2000 gives you the right to request any recorded information held by a public authority in England, Wales, and Northern Ireland. This includes councils, NHS bodies, police forces, schools, and central government departments.
            </p>
            <p>
              You do not need to give a reason for your request. The authority must respond within 20 working days, and can only refuse on specific legal grounds (such as national security, personal data, or commercial confidentiality). If they refuse, they must explain why and tell you how to appeal.
            </p>
            <p>
              I already track a significant amount of council spending data across Lancashire, often in far more detail than councils publish themselves. Before submitting an FOI request, feel free to get in touch and I can check whether the information you need is already available. If it&rsquo;s not, an FOI request is your legal right and a powerful tool for holding councils to account.
            </p>
            <p>
              To make a request to Lancashire County Council, you can use their online FOI portal or write to their information governance team directly.
            </p>
            <div class="foi-link">
              <a href="https://www.lancashire.gov.uk/council/transparency/freedom-of-information/" class="btn-secondary" target="_blank" rel="noopener noreferrer">
                LCC Freedom of Information
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </section>
    </ScrollReveal>

  </div>
</Layout>

<style>
  /* ---- Page Layout ---- */
  .transparency-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.5rem 5rem;
  }

  /* ---- Page Header ---- */
  .page-header {
    text-align: center;
    margin-bottom: 3.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .page-header h1 {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  .page-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ---- Stats Section ---- */
  .stats-section {
    margin-bottom: 3.5rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  .impact-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8px;
    padding: 1.75rem 1.25rem;
    background: rgba(28, 28, 30, 0.6);
    backdrop-filter: blur(20px) saturate(1.2) brightness(1.02);
    -webkit-backdrop-filter: blur(20px) saturate(1.2) brightness(1.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal), border-color var(--transition-normal);
  }

  .impact-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
  }

  .impact-card[data-accent="teal"] .impact-accent { background: var(--accent); }
  .impact-card[data-accent="green"] .impact-accent { background: var(--accent-green); }
  .impact-card[data-accent="blue"] .impact-accent { background: var(--accent-blue); }
  .impact-card[data-accent="purple"] .impact-accent { background: var(--accent-purple); }

  .impact-card[data-accent="teal"]:hover {
    box-shadow: 0 10px 40px rgba(18, 182, 207, 0.15), 0 0 20px rgba(18, 182, 207, 0.1);
    border-color: rgba(18, 182, 207, 0.2);
  }
  .impact-card[data-accent="green"]:hover {
    box-shadow: 0 10px 40px rgba(48, 209, 88, 0.15), 0 0 20px rgba(48, 209, 88, 0.1);
    border-color: rgba(48, 209, 88, 0.2);
  }
  .impact-card[data-accent="blue"]:hover {
    box-shadow: 0 10px 40px rgba(10, 132, 255, 0.15), 0 0 20px rgba(10, 132, 255, 0.1);
    border-color: rgba(10, 132, 255, 0.2);
  }
  .impact-card[data-accent="purple"]:hover {
    box-shadow: 0 10px 40px rgba(191, 90, 242, 0.15), 0 0 20px rgba(191, 90, 242, 0.1);
    border-color: rgba(191, 90, 242, 0.2);
  }

  .impact-card:hover {
    transform: translateY(-3px);
  }

  .impact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.04);
    margin-bottom: 4px;
    transition: transform var(--transition-normal);
  }

  .impact-card[data-accent="teal"] .impact-icon { color: var(--accent); }
  .impact-card[data-accent="green"] .impact-icon { color: var(--accent-green); }
  .impact-card[data-accent="blue"] .impact-icon { color: var(--accent-blue); }
  .impact-card[data-accent="purple"] .impact-icon { color: var(--accent-purple); }

  .impact-card:hover .impact-icon {
    transform: scale(1.1);
  }

  .impact-value {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #fff;
    line-height: 1.1;
  }

  .impact-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.3;
  }

  /* ---- About Section ---- */
  .about-section {
    margin-bottom: 3.5rem;
  }

  .about-card {
    border-left: 3px solid var(--accent);
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .about-content p {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.75;
    max-width: none;
  }

  /* ---- Findings Section ---- */
  .findings-section {
    margin-bottom: 3.5rem;
  }

  .findings-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .finding-card {
    position: relative;
    overflow: hidden;
  }

  .finding-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
  }

  .finding-accent[data-color="teal"] { background: var(--accent); }
  .finding-accent[data-color="green"] { background: var(--accent-green); }
  .finding-accent[data-color="purple"] { background: var(--accent-purple); }

  .finding-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.04);
    margin-bottom: var(--space-md);
    transition: transform var(--transition-normal);
  }

  .finding-card:hover .finding-icon {
    transform: scale(1.08) rotate(3deg);
  }

  .finding-card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: var(--space-sm);
    color: var(--text-primary);
  }

  .findings-intro {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 700px;
    margin-bottom: var(--space-xl);
  }

  .finding-stat {
    display: block;
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--accent);
    margin-bottom: var(--space-xs);
  }

  .finding-card p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: none;
  }

  .finding-source {
    display: inline-block;
    margin-top: var(--space-sm);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-tertiary);
    font-style: italic;
  }

  .findings-note {
    margin-top: var(--space-xl);
    padding: var(--space-md) var(--space-lg);
    background: rgba(255, 69, 58, 0.06);
    border: 1px solid rgba(255, 69, 58, 0.15);
    border-radius: var(--radius-md);
  }

  .findings-note p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin: 0;
    max-width: none;
  }

  /* ---- CTA Section ---- */
  .cta-section {
    margin-bottom: 3.5rem;
  }

  .cta-card {
    padding: 0;
    overflow: hidden;
  }

  .cta-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .cta-screenshot {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2xl);
  }

  .screenshot-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, rgba(18, 182, 207, 0.12) 0%, rgba(191, 90, 242, 0.08) 50%, rgba(10, 132, 255, 0.1) 100%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: var(--text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .screenshot-stat {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--accent);
    line-height: 1;
  }

  .screenshot-placeholder svg {
    opacity: 0.5;
    color: var(--accent);
  }

  .screenshot-placeholder small {
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }

  .cta-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-2xl);
  }

  .cta-content p {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.7;
    margin-bottom: var(--space-lg);
    max-width: none;
  }

  .cta-buttons {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  /* ---- FOI Section ---- */
  .foi-section {
    margin-bottom: 2rem;
  }

  .foi-card {
    border-left: 3px solid var(--accent);
  }

  .foi-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(18, 182, 207, 0.1);
    color: var(--accent);
    margin-bottom: var(--space-lg);
  }

  .foi-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .foi-content p {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.75;
    max-width: none;
  }

  .foi-link {
    margin-top: var(--space-sm);
  }

  /* ---- Responsive ---- */
  @media (max-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .cta-inner {
      grid-template-columns: 1fr;
    }

    .cta-screenshot {
      padding: var(--space-lg);
    }

    .cta-content {
      padding: var(--space-lg);
    }
  }

  @media (max-width: 768px) {
    .transparency-page {
      padding: 1.5rem 1rem 3rem;
    }

    .page-header {
      margin-bottom: 2.5rem;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }

    .findings-grid {
      grid-template-columns: 1fr;
    }

    .impact-value {
      font-size: 1.75rem;
    }

    .cta-buttons {
      flex-direction: column;
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      gap: var(--space-sm);
    }

    .impact-card {
      padding: 1.25rem 0.75rem;
    }

    .impact-value {
      font-size: 1.5rem;
    }

    .impact-icon {
      width: 40px;
      height: 40px;
    }

    .cta-screenshot {
