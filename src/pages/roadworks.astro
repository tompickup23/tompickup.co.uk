              <!-- Estimated need line (red) -->
              <polyline fill="none" stroke="#ff453a" stroke-width="2"
                points={annualInvestment.map((y: any, i: number) => {
                  const x = invPad.left + (i / annualInvestment.length) * invPlotW + invPlotW / annualInvestment.length * 0.15 + invBarW / 2;
                  const yPos = invPad.top + invPlotH - ((y.estimated_need || 0) / 1e6 / invMaxY) * invPlotH;
                  return `${x},${yPos}`;
                }).join(' ')} />
              {annualInvestment.map((y: any, i: number) => {
                const x = invPad.left + (i / annualInvestment.length) * invPlotW + invPlotW / annualInvestment.length * 0.15 + invBarW / 2;
