                    <div class="clash-card" style={`border-left: 3px solid ${clashColor}`}>
                      <div class="clash-head">
                        <span class="clash-corridor">{cl.corridor}</span>
                        <span class={`severity-badge severity-${cl.severity}`}>{cl.severity}</span>
                      </div>
                      <div class="clash-stats">
                        <span>{cl.concurrent_works} concurrent works</span>
                        <span class="clash-cap">{Math.round(cl.total_capacity_reduction * 100)}% capacity loss</span>
                      </div>
                      {cl.s59_breach && <div class="clash-breach">s59 DUTY TO COORDINATE LIKELY BREACHED</div>}
                      {!cl.s59_breach && cl.s59_coordination_needed && <div class="clash-breach clash-breach-warn">s59 COORDINATION NEEDED</div>}
                      <div class="clash-works">
