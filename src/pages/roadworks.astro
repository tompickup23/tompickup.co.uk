          </div>
          <div class="restriction-card restriction-lane">
            <div class="restriction-icon">&#x26A0;</div>
            <div class="restriction-count">{restrictionSummary.lane_restriction || 0}</div>
            <div class="restriction-label">Lane Restrictions</div>
            <div class="restriction-desc">Reduced capacity — temp lights, lane closures, alternating flow.</div>
          </div>
          <div class="restriction-card restriction-minor">
            <div class="restriction-icon">&#x1F6A7;</div>
