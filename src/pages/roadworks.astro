            <div class="asset-stat-card asset-stat-card--steady">
              <span class="asset-stat-value">&pound;{investmentAnalysis.practical_steady_state ? (investmentAnalysis.practical_steady_state / 1e6).toFixed(0) : '110'}M<small>/yr</small></span>
              <span class="asset-stat-label">Practical Steady-State Need</span>
              <span class="asset-stat-note">Based on 25-year resurfacing cycle + all asset classes</span>
            </div>
            <div class="asset-stat-card">
              <span class="asset-stat-value">&pound;{investmentAnalysis.current_best_annual_capital ? (investmentAnalysis.current_best_annual_capital / 1e6).toFixed(0) : '72'}M</span>
              <span class="asset-stat-label">2026/27 Capital Programme</span>
              <span class="asset-stat-note">Budgeted. {investmentAnalysis.capital_as_pct_practical_steady_state || 65}% of practical steady-state</span>
            </div>
            <div class="asset-stat-card">
              <span class="asset-stat-value">&sim;9yr</span>
              <span class="asset-stat-label">Years to Clear Backlog</span>
              <span class="asset-stat-note">At current spend, assuming zero new deterioration (impossible)</span>
            </div>
          </div>

          <!-- Investment gap key insight -->
          {investmentAnalysis.key_insight && (
          <div class="key-insight-box">{investmentAnalysis.key_insight}</div>
          )}

          {backlogInflation.backlog_today && (
          <p class="chart-subtitle" style="margin-top: 8px; color: #ff9f0a;"><strong>&#9888; Important:</strong> The &pound;{(backlogInflation.backlog_today / 1e6).toFixed(0)}M backlog is in today&rsquo;s prices. At {(backlogInflation.construction_inflation_rate * 100).toFixed(0)}% annual construction inflation, the real cost of clearing it in 10 years is &pound;{(backlogInflation.backlog_in_10yr / 1e6).toFixed(0)}M. Even the &pound;72M budget buys only ~&pound;{buyingPower.budget_2027_in_2015_terms ? (buyingPower.budget_2027_in_2015_terms / 1e6).toFixed(0) : '50'}M of 2015 road work.</p>
