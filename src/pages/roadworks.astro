            </svg>
            <div class="chart-legend">
              <span class="legend-item"><span class="legend-dot" style="background:#30d158"></span> A Roads</span>
              <span class="legend-item"><span class="legend-dot" style="background:#ff9f0a"></span> B&amp;C Roads</span>
              <span class="legend-item"><span class="legend-dot" style="background:#ff453a"></span> Unclassified</span>
            </div>
          </div>
          )}
        </Accordion>

        <Accordion title="True Cost of Getting Roads Right" defaultOpen={true}>
          <!-- Cost stat cards -->
          <div class="asset-stat-grid">
