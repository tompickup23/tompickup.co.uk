        <Accordion title={`${trafficData.congestion_model.options_appraisal.length} Interventions — Scored by Impact, Feasibility & Cost`} defaultOpen={true}>
          <div class="options-grid">
            {trafficData.congestion_model.options_appraisal.sort((a: any, b: any) => (b.overall_score || 0) - (a.overall_score || 0)).map((opt: any, i: number) => {
