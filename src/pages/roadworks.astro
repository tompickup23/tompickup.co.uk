                  <div class="jci-headline-chip" data-district={j.district || ''} style={`border-color: ${jciColor}`}>
                    <span class="jci-headline-name">{j.name}</span>
                    <span class="jci-headline-score" style={`color:${jciColor}`}>{(j.jci || 0).toFixed(0)}</span>
                    <span class={`severity-badge severity-${j.jci_level}`}>{j.jci_level}</span>
                  </div>
                );
              })}
            </div>
          ) : null;
        })()}
        <Accordion title={`All ${trafficData.congestion_model.junctions.length} Junctions — Full Scoring`} defaultOpen={true}>
