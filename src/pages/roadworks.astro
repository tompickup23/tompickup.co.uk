              return (
                <div class="jci-card" data-district={j.district || ''} style={`border-left: 3px solid ${jciColor}`}>
                  <div class="jci-top">
                    <span class="jci-name">{j.name}</span>
                    <span class="jci-score" style={`color:${jciColor}`}>{(j.jci || 0).toFixed(1)}</span>
                  </div>
                  <div class="jci-bar-track">
                    <div class="jci-bar-fill" style={`width:${j.jci || 0}%;background:${jciColor}`}></div>
                  </div>
                  <div class="jci-factors">
                    <span>{j.traffic_volume ? `Vol: ${j.traffic_volume.toLocaleString()}` : 'Vol: no data'}</span>
