            <p class="chart-subtitle">Orange = DfT grant. Blue = LCC contribution. Red line = estimated need.</p>
            <svg viewBox={`0 0 ${invChartW} ${invChartH}`} class="svg-chart">
              <!-- Y axis grid -->
              {[0, 30, 60, 90, 120].map((v) => (
              <line x1={invPad.left} y1={invPad.top + invPlotH - (v / invMaxY) * invPlotH} x2={invChartW - invPad.right} y2={invPad.top + invPlotH - (v / invMaxY) * invPlotH} stroke="rgba(255,255,255,0.08)" stroke-dasharray="4 4" />
