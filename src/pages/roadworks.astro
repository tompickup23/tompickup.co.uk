                    </div>
                  </div>
                  <p class="option-desc">{opt.description}</p>
                  <div class="option-meta">
                    <span class={`severity-badge severity-${opt.priority}`}>{opt.priority}</span>
                    {opt.congestion_reduction_pct > 0 && <span class="option-tag">-{opt.congestion_reduction_pct}% congestion</span>}
