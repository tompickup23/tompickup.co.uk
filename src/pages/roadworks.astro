              {conditionTrend.filter((t: any) => t.a_red !== null).map((t: any, i: number, arr: any[]) => {
                const x = chartPad.left + (i / Math.max(arr.length - 1, 1)) * plotW;
                const y = chartPad.top + plotH - (t.a_red / 32) * plotH;
                return <circle cx={x} cy={y} r="3" fill="#30d158" />;
              })}
              <!-- B&C roads line (orange) -->
              <polyline fill="none" stroke="#ff9f0a" stroke-width="2"
                points={conditionTrend.filter((t: any) => t.bc_red !== null).map((t: any, i: number, arr: any[]) => {
                  const x = chartPad.left + (i / Math.max(arr.length - 1, 1)) * plotW;
                  const y = chartPad.top + plotH - (t.bc_red / 32) * plotH;
                  return `${x},${y}`;
                }).join(' ')} />
              {conditionTrend.filter((t: any) => t.bc_red !== null).map((t: any, i: number, arr: any[]) => {
                const x = chartPad.left + (i / Math.max(arr.length - 1, 1)) * plotW;
                const y = chartPad.top + plotH - (t.bc_red / 32) * plotH;
                return <circle cx={x} cy={y} r="3" fill="#ff9f0a" />;
              })}
              <!-- Unclassified line (red) -->
              {conditionTrend.filter((t: any) => t.uc_red !== null).length > 0 && (
              <polyline fill="none" stroke="#ff453a" stroke-width="2"
                points={conditionTrend.filter((t: any) => t.uc_red !== null).map((t: any, i: number, arr: any[]) => {
                  const x = chartPad.left + (i / Math.max(arr.length - 1, 1)) * plotW;
                  const y = chartPad.top + plotH - (t.uc_red / 32) * plotH;
                  return `${x},${y}`;
                }).join(' ')} />
              )}
              {conditionTrend.filter((t: any) => t.uc_red !== null).map((t: any, i: number, arr: any[]) => {
                const x = chartPad.left + (i / Math.max(arr.length - 1, 1)) * plotW;
                const y = chartPad.top + plotH - (t.uc_red / 32) * plotH;
                return <circle cx={x} cy={y} r="3" fill="#ff453a" />;
