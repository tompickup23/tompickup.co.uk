</style>

<script>
  // Regional toggle + borough-dynamic content logic
  (function() {
    var currentRegion = 'burnley';
    var DISTRICT_LABELS = {
      burnley:'Burnley', hyndburn:'Hyndburn', pendle:'Pendle', rossendale:'Rossendale',
      lancaster:'Lancaster', ribble_valley:'Ribble Valley', chorley:'Chorley',
      south_ribble:'South Ribble', preston:'Preston', west_lancashire:'West Lancashire',
      wyre:'Wyre', fylde:'Fylde', all: 'All Lancashire'
    };

    // Roadworks by-district stats (injected at build time)
    var BY_DISTRICT = {};
    var TOTAL_STATS = { total: 0, started: 0, planned: 0 };

    // Load roadworks data dynamically
    fetch('/data/roadworks.json').then(function(r) { return r.json(); }).then(function(data) {
      BY_DISTRICT = (data.stats && data.stats.by_district) || {};
      TOTAL_STATS = { total: data.stats.total || 0, started: data.stats.works_started || 0, planned: data.stats.planned_works || 0 };
      // Update hero stat 4 with live total
      var heroStat4 = document.getElementById('hero-stat-4');
      if (heroStat4) heroStat4.textContent = TOTAL_STATS.total.toLocaleString();
      // Initial region setup (Burnley default)
      updateBoroughStats('burnley');
    }).catch(function() {});

    function updateBoroughStats(region) {
      var card = document.getElementById('borough-stats-card');
      if (!card) return;
      if (region === 'all') {
        card.style.display = 'none';
        return;
      }
      var stats = BY_DISTRICT[region];
      if (!stats) { card.style.display = 'none'; return; }
      card.style.display = 'block';
      var label = DISTRICT_LABELS[region] || region;
      var title = document.getElementById('borough-stats-title');
      if (title) title.textContent = label + ' District';
      var els = {
        'bs-total': stats.total || 0,
        'bs-active': stats.works_started || 0,
        'bs-planned': stats.planned_works || 0,
        'bs-high': stats.high || 0
      };
      for (var id in els) {
        var el = document.getElementById(id);
        if (el) el.textContent = els[id].toLocaleString();
      }
      // Count JCI junctions for this district
      var jciCount = document.querySelectorAll('.jci-card[data-district="' + region + '"]').length;
      var bsJci = document.getElementById('bs-jci');
      if (bsJci) bsJci.textContent = jciCount;
      // Update note
      var note = document.getElementById('bs-note');
      if (note) note.textContent = stats.total + ' of ' + TOTAL_STATS.total + ' Lancashire works are in ' + label + '. LCC manages all roads in this district.';
    }

    function filterJCI(region) {
      // Filter JCI junction cards by district
      document.querySelectorAll('.jci-card[data-district]').forEach(function(card) {
        if (region === 'all' || card.getAttribute('data-district') === region) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
      // Filter JCI headline chips
      document.querySelectorAll('.jci-headline-chip[data-district]').forEach(function(chip) {
        if (region === 'all' || chip.getAttribute('data-district') === region) {
          chip.style.display = '';
        } else {
          chip.style.display = 'none';
        }
      });
      // Update junction count in heading
      var jciHeading = document.querySelector('.congestion-section .section-sub');
      if (jciHeading) {
        var visibleCount = document.querySelectorAll('.jci-card[data-district]' + (region !== 'all' ? '[data-district="' + region + '"]' : '') ).length;
        var totalCount = document.querySelectorAll('.jci-card[data-district]').length;
        if (region === 'all') {
          jciHeading.textContent = 'Restriction-aware scoring of ' + totalCount + ' key junctions — weighted by actual capacity reduction';
        } else {
          jciHeading.textContent = visibleCount + ' of ' + totalCount + ' junctions in ' + (DISTRICT_LABELS[region] || region) + ' — weighted by actual capacity reduction';
        }
      }
      // Update accordion title with filtered count
      var accTitle = document.querySelector('.congestion-section .accordion-trigger');
      if (accTitle) {
        var count = document.querySelectorAll('.jci-card[data-district]' + (region !== 'all' ? '[data-district="' + region + '"]' : '') ).length;
        accTitle.childNodes[0].textContent = (region === 'all' ? 'All ' + count : count) + ' Junctions — Full Scoring';
      }
    }

    function updateHeroStats(region) {
      if (region === 'all') {
        // All Lancashire stats
        var h1 = document.getElementById('hero-stat-1');
        var h2 = document.getElementById('hero-stat-2');
        var h3 = document.getElementById('hero-stat-3');
        var h4 = document.getElementById('hero-stat-4');
        if (h1) h1.innerHTML = '&pound;650M+';
        if (h2) h2.innerHTML = '&pound;72M';
        if (h3) h3.textContent = '7,142 km';
        if (h4) h4.textContent = TOTAL_STATS.total.toLocaleString();
        var l1 = document.getElementById('hero-label-1');
        var l2 = document.getElementById('hero-label-2');
        var l3 = document.getElementById('hero-label-3');
        var l4 = document.getElementById('hero-label-4');
        if (l1) l1.textContent = 'Highways Backlog';
        if (l2) l2.textContent = '2026/27 Investment';
        if (l3) l3.textContent = 'LCC Road Network';
        if (l4) l4.textContent = 'Active & Planned Works';
      } else {
        var stats = BY_DISTRICT[region] || {};
        var label = DISTRICT_LABELS[region] || region;
        var h1 = document.getElementById('hero-stat-1');
        var h2 = document.getElementById('hero-stat-2');
        var h3 = document.getElementById('hero-stat-3');
        var h4 = document.getElementById('hero-stat-4');
        if (h1) h1.textContent = (stats.total || 0).toLocaleString();
        if (h2) h2.textContent = (stats.works_started || 0).toLocaleString();
        if (h3) h3.textContent = (stats.planned_works || 0).toLocaleString();
        if (h4) h4.textContent = (stats.high || 0).toLocaleString();
        var l1 = document.getElementById('hero-label-1');
        var l2 = document.getElementById('hero-label-2');
        var l3 = document.getElementById('hero-label-3');
        var l4 = document.getElementById('hero-label-4');
        if (l1) l1.textContent = 'Total Works';
        if (l2) l2.textContent = 'Active';
        if (l3) l3.textContent = 'Planned';
        if (l4) l4.textContent = 'High Severity';
      }
    }

    function setRegion(region) {
      currentRegion = region;
      // Update pill states
      document.querySelectorAll('.region-pill').forEach(function(pill) {
        var isActive = pill.getAttribute('data-region') === region;
        pill.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      // Show/hide Burnley-only sections
      document.querySelectorAll('[data-region-only="burnley"]').forEach(function(section) {
        if (region === 'burnley') {
          section.classList.remove('region-hidden');
        } else {
          section.classList.add('region-hidden');
        }
      });
      // Tell the map to switch region
      window.dispatchEvent(new CustomEvent('setregion', { detail: { district: region } }));
      // Update hero subtitle
      var heroSub = document.querySelector('.hero-sub');
      if (heroSub && region !== 'all') {
        var label = DISTRICT_LABELS[region] || region;
        heroSub.innerHTML = 'Roadworks, traffic analysis, and congestion intelligence for <strong>' + label + '</strong>. ' +
          'Lancashire County Council is the highways authority responsible for all roads except the M65 motorway and unitary areas.';
      } else if (heroSub) {
        heroSub.innerHTML = 'Live roadworks across all 12 Lancashire districts, traffic orders, major projects, and ' +
          'congestion analysis. Lancashire County Council is the highways authority responsible for all roads except the M65 motorway and unitary areas.';
      }
      // Borough-dynamic content
      updateHeroStats(region);
      updateBoroughStats(region);
      filterJCI(region);
    }

    // Attach click handlers
    document.querySelectorAll('.region-pill').forEach(function(pill) {
      pill.addEventListener('click', function() {
        var region = this.getAttribute('data-region');
        setRegion(region);
        // Scroll to map
        var mapSection = document.querySelector('.map-section');
        if (mapSection) mapSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    // Sync from map's district filter change
    window.addEventListener('regionchange', function(e) {
      var district = e.detail && e.detail.district;
      if (district && district !== currentRegion) {
        setRegion(district);
      }
    });
  })();
</script>
