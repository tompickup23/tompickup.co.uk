---
import Layout from '../layouts/Layout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import Accordion from '../components/Accordion.astro';
import RoadworksMap from '../components/RoadworksMap.astro';

// Traffic + FixMyStreet data
let trafficData: any = { heatmap: [], key_roads: [], fixtures: [], school_terms: { in_term: false }, count_points: [] };
let fixmystreetData: any = { reports: [], stats: { total: 0, open: 0, by_category: {} } };

try {
  const trafficRaw = await import('../../public/data/traffic.json');
  trafficData = trafficRaw.default || trafficRaw;
} catch {}
try {
  const fmsRaw = await import('../../public/data/fixmystreet.json');
  fixmystreetData = fmsRaw.default || fmsRaw;
} catch {}

const heatmap = trafficData.heatmap || [];
const keyRoads = trafficData.key_roads || [];
const fixtures = (trafficData.fixtures || []).filter((f: any) => f.is_home && f.date >= new Date().toISOString().slice(0, 10));
const inTerm = trafficData.school_terms?.in_term || false;
const currentTerm = trafficData.school_terms?.current_term || 'Unknown';
const fmsOpen = fixmystreetData.stats?.open || 0;
const fmsTotal = fixmystreetData.stats?.total || 0;
const fmsCats = fixmystreetData.stats?.by_category || {};
const fmsReports = fixmystreetData.reports || [];
const topFmsCats = Object.entries(fmsCats).slice(0, 6);

// Operational intelligence
const opsIntel = trafficData.operational_intelligence || {};
const deferrals = opsIntel.deferral_recommendations || [];
const lccDeferrals = opsIntel.lcc_deferrals || [];
const utilityS56 = opsIntel.utility_s56_recommendations || [];
const corridorClashes = opsIntel.corridor_clashes || [];
const timingDirections = opsIntel.timing_directions || [];
const majorProjects = opsIntel.major_projects || [];
const classifiedWorks = opsIntel.classified_works || [];
const restrictionSummary = trafficData.meta?.restriction_summary || {};
const validity = trafficData.meta?.validity || {};
const coverage = trafficData.meta?.coverage || {};

// Filtering funnel — shows the public exactly how we narrow down to actionable deferrals
const totalWorks = coverage.total_works || 0;
const worksStarted = coverage.works_started || 0;
const lufWorks = coverage.luf_programme_works || 0;
const bridgeWorks = coverage.bridge_structural_works || 0;
const nonDeferrable = coverage.non_deferrable_total || 0;
const lccWorksCount = classifiedWorks.filter((w: any) => (w.operator || '').includes('Lancashire')).length;
const utilityWorksCount = totalWorks - lccWorksCount;

const planningWorks = coverage.planning_obligation_works || 0;

// Non-deferrable reasons breakdown for funnel
const nonDeferrableReasons = [
  { label: 'Works already started', count: worksStarted, reason: 'Road physically dug up \u2014 cannot stop mid-construction' },
  { label: 'LUF programme works', count: lufWorks, reason: 'Levelling Up Fund grant \u2014 deferral risks losing \u00A319.9M government funding' },
  { label: 'Bridge/structural safety', count: bridgeWorks, reason: 'S1 Highways Act 1980 duty to maintain \u2014 structural safety obligation' },
  { label: 'Planning obligations', count: planningWorks, reason: 'Tied to s106/s278 planning agreement \u2014 legal obligation to housing developers' },
].filter((r: any) => r.count > 0);

// Heatmap colour
function heatColor(level: string): string {
  switch (level) {
    case 'severe': return '#dc2626';
    case 'high': return '#f97316';
    case 'moderate': return '#eab308';
    case 'low': return '#22c55e';
    default: return '#1e293b';
  }
}

// --- Chart data ---
const weekdayProfile = trafficData.profiles?.weekday || {};
const weekendProfile = trafficData.profiles?.weekend || {};
const schoolOverlay = trafficData.profiles?.school_run_overlay || {};

// SVG chart dimensions
const chartW = 720;
const chartH = 280;
const chartPad = { top: 20, right: 20, bottom: 40, left: 50 };
const plotW = chartW - chartPad.left - chartPad.right;
const plotH = chartH - chartPad.top - chartPad.bottom;

// Build line path from profile
function profilePath(profile: Record<string, number>, maxY: number): string {
  return Object.entries(profile)
    .sort(([a], [b]) => Number(a) - Number(b))
    .map(([h, v], i) => {
      const x = chartPad.left + (Number(h) / 23) * plotW;
      const y = chartPad.top + plotH - (v / maxY) * plotH;
      return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${y.toFixed(1)}`;
    })
    .join(' ');
}

// Build area path (line + close bottom)
function areaPath(profile: Record<string, number>, maxY: number): string {
  const entries = Object.entries(profile).sort(([a], [b]) => Number(a) - Number(b));
  const line = entries.map(([h, v], i) => {
    const x = chartPad.left + (Number(h) / 23) * plotW;
    const y = chartPad.top + plotH - (v / maxY) * plotH;
    return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${y.toFixed(1)}`;
  }).join(' ');
  const lastX = chartPad.left + plotW;
  const firstX = chartPad.left;
  const bottom = chartPad.top + plotH;
  return `${line} L${lastX},${bottom} L${firstX},${bottom} Z`;
}

const maxFlow = Math.max(...Object.values(weekdayProfile).map(Number), ...Object.values(weekendProfile).map(Number), 10);
const yTicks = [0, 2, 4, 6, 8];
if (maxFlow > 8) yTicks.push(10);

// Combined weekday+school profile
const weekdaySchool: Record<string, number> = {};
for (const h of Object.keys(weekdayProfile)) {
  weekdaySchool[h] = (Number(weekdayProfile[h]) || 0) + (Number(schoolOverlay[h]) || 0);
}
const maxFlowAll = Math.max(...Object.values(weekdaySchool).map(Number), maxFlow);

// Bar chart data (top roads)
const barRoads = keyRoads.slice(0, 9);
const maxVehicles = barRoads.length > 0 ? Math.max(...barRoads.map((r: any) => r.daily_vehicles || 0)) : 60000;

// Vehicle composition for busiest road
const busiestRoad = keyRoads[0] || {};
const compData = busiestRoad.daily_vehicles ? [
  { label: 'Cars & Taxis', value: busiestRoad.cars || 0, color: '#12b6cf' },
  { label: 'LGVs', value: busiestRoad.daily_vehicles - (busiestRoad.cars || 0) - (busiestRoad.hgvs || 0) - (busiestRoad.buses || 0) - (busiestRoad.cycles || 0), color: '#8b5cf6' },
  { label: 'HGVs', value: busiestRoad.hgvs || 0, color: '#f97316' },
  { label: 'Buses', value: busiestRoad.buses || 0, color: '#22c55e' },
  { label: 'Cycles', value: busiestRoad.cycles || 0, color: '#eab308' },
] : [];
const compTotal = compData.reduce((s: number, d: any) => s + d.value, 0);

// Donut chart params
const donutR = 80;
const donutInner = 50;
const donutCx = 100;
const donutCy = 100;
function donutArc(startAngle: number, endAngle: number, r: number): string {
  const s = startAngle - Math.PI / 2;
  const e = endAngle - Math.PI / 2;
  const x1 = donutCx + r * Math.cos(s);
  const y1 = donutCy + r * Math.sin(s);
  const x2 = donutCx + r * Math.cos(e);
  const y2 = donutCy + r * Math.sin(e);
  const large = endAngle - startAngle > Math.PI ? 1 : 0;
  return `M${x1.toFixed(2)},${y1.toFixed(2)} A${r},${r} 0 ${large} 1 ${x2.toFixed(2)},${y2.toFixed(2)}`;
}

// School run highlight bands
const schoolBands = [
  { start: 7, end: 9, label: 'Morning school run' },
  { start: 14, end: 16, label: 'Afternoon school run' },
];
---

<Layout
  title="Roads & Roadworks | Tom Pickup"
  description="Burnley's road network: current roadworks, TTROs, major projects, problem areas, and the £650M Lancashire highways backlog. Report potholes and track repairs."
>
  <!-- Hero -->
  <section class="rw-hero">
    <div class="container">
      <ScrollReveal>
        <div class="rw-hero-inner">
          <span class="badge badge-teal">Highways &amp; Transport</span>
          <h1>Roads &amp; Roadworks</h1>
          <p class="hero-sub">
            Current roadworks, active traffic orders, major projects, and everything you need
            to know about Burnley&rsquo;s road network. Lancashire County Council is the highways
            authority responsible for all roads except the M65 motorway.
          </p>
          <div class="hero-stats">
            <div class="hero-stat">
              <span class="hero-stat-value">&pound;650M+</span>
              <span class="hero-stat-label">Highways Backlog</span>
            </div>
            <div class="hero-stat">
              <span class="hero-stat-value">&pound;72M</span>
              <span class="hero-stat-label">2026/27 Investment</span>
            </div>
            <div class="hero-stat">
              <span class="hero-stat-value">7,400 km</span>
              <span class="hero-stat-label">LCC Road Network</span>
            </div>
            <div class="hero-stat">
              <span class="hero-stat-value">&pound;55M</span>
              <span class="hero-stat-label">Levelling Up Programme</span>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Live Roadworks Map -->
  <section class="map-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <span class="badge badge-red">Live Data</span>
          <h2>Live Roadworks Map</h2>
          <p class="section-sub">
            All current and planned roadworks across Burnley Borough, updated twice daily
            from Lancashire County Council&rsquo;s official highways database. Click any marker for details.
          </p>
        </div>
      </ScrollReveal>
      <RoadworksMap />
    </div>
  </section>

  <!-- Traffic Impact Heatmap -->
  {heatmap.length > 0 && (
  <section class="traffic-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <span class="badge badge-orange">Traffic Intelligence</span>
          <h2>Traffic Impact Timeline</h2>
          <p class="section-sub">
            7-day congestion forecast combining roadworks, school runs, Burnley FC home matches,
            and rush hour patterns. Based on DfT traffic count data from {trafficData.count_points?.length || 0} monitoring points.
          </p>
        </div>

        <!-- Context chips -->
        <div class="traffic-context">
          <span class={`traffic-chip ${inTerm ? 'chip-active' : 'chip-inactive'}`}>
            {inTerm ? `🏫 Term Time (${currentTerm})` : '☀️ School Holiday'}
          </span>
          {fixtures.length > 0 && (
            <span class="traffic-chip chip-match">
              ⚽ Next home: {fixtures[0].opponent} ({fixtures[0].date})
            </span>
          )}
          <span class="traffic-chip chip-info">
            📊 {trafficData.meta?.active_roadworks || 0} active roadworks
          </span>
        </div>

        <!-- Heatmap Grid -->
        <div class="heatmap-scroll">
          <div class="heatmap-grid">
            <div class="heatmap-header">
              <div class="heatmap-label"></div>
              {Array.from({length: 24}, (_, i) => (
                <div class="heatmap-hour-label">{i.toString().padStart(2, '0')}</div>
              ))}
            </div>
            {heatmap.map((day: any) => (
              <div class="heatmap-row">
                <div class="heatmap-label">
                  <span class="heatmap-day">{day.day.slice(0, 3)}</span>
                  <span class="heatmap-date">{day.date.slice(5)}</span>
                </div>
                {day.hours.map((h: any) => (
                  <div
                    class={`heatmap-cell ${h.school_run ? 'cell-school' : ''} ${h.match_day ? 'cell-match' : ''}`}
                    style={`background: ${heatColor(h.level)};`}
                    title={`${day.day} ${h.hour}:00 — ${h.flow_pct}% flow (${h.level})${h.school_run ? ' + school run' : ''}${h.match_day ? ' + match day' : ''}`}
                  >
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>
        <div class="heatmap-legend">
          <span class="legend-item"><span class="legend-dot" style="background: #1e293b"></span>Minimal</span>
          <span class="legend-item"><span class="legend-dot" style="background: #22c55e"></span>Low</span>
          <span class="legend-item"><span class="legend-dot" style="background: #eab308"></span>Moderate</span>
          <span class="legend-item"><span class="legend-dot" style="background: #f97316"></span>High</span>
          <span class="legend-item"><span class="legend-dot" style="background: #dc2626"></span>Severe</span>
          <span class="legend-item"><span class="legend-dot legend-school"></span>School Run</span>
          <span class="legend-item"><span class="legend-dot legend-match"></span>Match Day</span>
        </div>
      </ScrollReveal>

      <!-- Key Roads -->
      {keyRoads.length > 0 && (
        <ScrollReveal>
          <Accordion title={`Busiest Roads — DfT Traffic Counts (${keyRoads.length})`}>
            <div class="key-roads-grid">
              {keyRoads.map((road: any) => (
                <div class="key-road-card">
                  <div class="road-name-bar">
                    <span class="road-name">{road.road}</span>
                    <span class="road-category">{road.category}</span>
                  </div>
                  <div class="road-stats">
                    <span class="road-stat"><strong>{road.daily_vehicles?.toLocaleString()}</strong> vehicles/day</span>
                    <span class="road-stat">{road.cars?.toLocaleString()} cars</span>
                    <span class="road-stat">{road.hgvs?.toLocaleString()} HGVs</span>
                    {road.year && <span class="road-stat year">({road.year} data)</span>}
                  </div>
                </div>
              ))}
            </div>
          </Accordion>
        </ScrollReveal>
      )}

      <!-- FixMyStreet Reports -->
      {fmsTotal > 0 && (
        <ScrollReveal>
          <div class="fms-section">
            <div class="section-header">
              <span class="badge badge-purple">Community Reports</span>
              <h3>FixMyStreet — Recent Reports</h3>
              <p class="section-sub">{fmsOpen} open reports in the Burnley area (last 90 days via FixMyStreet Open311 API)</p>
            </div>
            <div class="fms-cats">
              {topFmsCats.map(([cat, count]: [string, any]) => (
                <div class="fms-cat-chip">
                  <span class="fms-cat-name">{cat}</span>
                  <span class="fms-cat-count">{count}</span>
                </div>
              ))}
            </div>
            <Accordion title={`All Reports (${fmsReports.length})`}>
              <div class="fms-list">
                {fmsReports.slice(0, 30).map((r: any) => (
                  <div class="fms-report">
                    <div class="fms-report-head">
                      <span class={`fms-status fms-${r.status}`}>{r.status}</span>
                      <span class="fms-date">{r.reported ? new Date(r.reported).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) : ''}</span>
                    </div>
                    <p class="fms-title">{r.title || r.category}</p>
                    <p class="fms-desc">{(r.description || '').slice(0, 120)}{(r.description || '').length > 120 ? '...' : ''}</p>
                    {r.ward && <span class="fms-ward">{r.ward}</span>}
                  </div>
                ))}
              </div>
            </Accordion>
          </div>
        </ScrollReveal>
      )}

      <!-- Burnley FC Fixtures Impact -->
      {fixtures.length > 0 && (
        <ScrollReveal>
          <Accordion title={`Burnley FC Home Matches — Traffic Impact (${fixtures.length})`}>
            <p class="fixture-note">Home matches at Turf Moor generate significant traffic on Yorkshire Road, Brunshaw Road, and the M65 Junction 10/11 approaches. Plan alternative routes on match days.</p>
            <div class="fixtures-grid">
              {fixtures.slice(0, 10).map((f: any) => (
                <div class="fixture-card">
                  <span class="fixture-date">{new Date(f.date).toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short' })}</span>
                  <span class="fixture-time">{f.time} KO</span>
                  <span class="fixture-opponent">vs {f.opponent}</span>
                </div>
              ))}
            </div>
          </Accordion>
        </ScrollReveal>
      )}
    </div>
  </section>
  )}

  <!-- Traffic Flow Analysis -->
  {(Object.keys(weekdayProfile).length > 0 || barRoads.length > 0) && (
  <section class="charts-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">Traffic Flow Analysis</h2>
          <p class="section-sub">Hourly traffic patterns, road volumes, and vehicle composition from DfT automatic traffic count data</p>
        </div>
      </ScrollReveal>

      {Object.keys(weekdayProfile).length > 0 && (
      <ScrollReveal>
        <div class="chart-card">
          <h3 class="chart-title">Daily Traffic Profile</h3>
          <p class="chart-desc">Relative traffic volume by hour — weekday vs weekend, with school run overlay</p>
          <svg viewBox={`0 0 ${chartW} ${chartH}`} class="svg-chart" role="img" aria-label="Daily traffic profile chart">
            {/* Grid lines */}
            {yTicks.map(t => {
              const y = chartPad.top + plotH - (t / maxFlowAll) * plotH;
              return (
                <g>
                  <line x1={chartPad.left} y1={y} x2={chartPad.left + plotW} y2={y} stroke="rgba(255,255,255,0.06)" stroke-dasharray="4 4" />
                  <text x={chartPad.left - 8} y={y + 4} fill="#71717a" font-size="10" text-anchor="end">{t}%</text>
                </g>
              );
            })}
            {/* Hour labels */}
            {[0, 3, 6, 9, 12, 15, 18, 21].map(h => {
              const x = chartPad.left + (h / 23) * plotW;
              return <text x={x} y={chartH - 8} fill="#71717a" font-size="10" text-anchor="middle">{h.toString().padStart(2, '0')}:00</text>;
            })}
            {/* School run bands */}
            {schoolBands.map(band => {
              const x1 = chartPad.left + (band.start / 23) * plotW;
              const x2 = chartPad.left + (band.end / 23) * plotW;
              return <rect x={x1} y={chartPad.top} width={x2 - x1} height={plotH} fill="rgba(249,115,22,0.06)" rx="4" />;
            })}
            {/* Weekend area */}
            <path d={areaPath(weekendProfile, maxFlowAll)} fill="rgba(139,92,246,0.08)" />
            <path d={profilePath(weekendProfile, maxFlowAll)} fill="none" stroke="#8b5cf6" stroke-width="1.5" opacity="0.5" />
            {/* Weekday + school area */}
            <path d={areaPath(weekdaySchool, maxFlowAll)} fill="rgba(18,182,207,0.1)" />
            <path d={profilePath(weekdaySchool, maxFlowAll)} fill="none" stroke="#12b6cf" stroke-width="2" />
            {/* Axes */}
            <line x1={chartPad.left} y1={chartPad.top} x2={chartPad.left} y2={chartPad.top + plotH} stroke="rgba(255,255,255,0.1)" />
            <line x1={chartPad.left} y1={chartPad.top + plotH} x2={chartPad.left + plotW} y2={chartPad.top + plotH} stroke="rgba(255,255,255,0.1)" />
          </svg>
          <div class="chart-legend">
            <span class="legend-item"><span class="legend-swatch" style="background:#12b6cf"></span> Weekday + school run</span>
            <span class="legend-item"><span class="legend-swatch" style="background:#8b5cf6"></span> Weekend</span>
            <span class="legend-item"><span class="legend-swatch" style="background:rgba(249,115,22,0.3)"></span> School run periods</span>
          </div>
        </div>
      </ScrollReveal>
      )}

      {barRoads.length > 0 && (
      <ScrollReveal>
        <div class="chart-card">
          <h3 class="chart-title">Key Road Volumes</h3>
          <p class="chart-desc">Average annual daily flow (AADF) from DfT automatic traffic counts</p>
          <div class="bar-chart">
            {barRoads.map((r: any) => {
              const pct = ((r.daily_vehicles || 0) / maxVehicles * 100).toFixed(1);
              const hgvPct = r.daily_vehicles > 0 ? ((r.hgvs || 0) / r.daily_vehicles * 100).toFixed(0) : '0';
              return (
                <div class="bar-row">
                  <div class="bar-label">{r.road_name || r.road}</div>
                  <div class="bar-track">
                    <div class="bar-fill" style={`width:${pct}%`}>
                      <span class="bar-value">{(r.daily_vehicles || 0).toLocaleString()}</span>
                    </div>
                  </div>
                  <div class="bar-meta">{hgvPct}% HGV</div>
                </div>
              );
            })}
          </div>
        </div>
      </ScrollReveal>
      )}

      {compData.length > 0 && compTotal > 0 && (
      <ScrollReveal>
        <div class="chart-card chart-card-donut">
          <div class="donut-wrap">
            <div>
              <h3 class="chart-title">Vehicle Composition</h3>
              <p class="chart-desc">{busiestRoad.road_name || busiestRoad.road || 'Busiest road'} — {compTotal.toLocaleString()} vehicles/day</p>
              <div class="donut-legend">
                {compData.map(d => (
                  <div class="donut-legend-item">
                    <span class="legend-swatch" style={`background:${d.color}`}></span>
                    <span class="donut-legend-label">{d.label}</span>
                    <span class="donut-legend-val">{compTotal > 0 ? (d.value / compTotal * 100).toFixed(0) : 0}%</span>
                  </div>
                ))}
              </div>
            </div>
            <svg viewBox="0 0 200 200" class="donut-svg" role="img" aria-label="Vehicle composition donut chart">
              {(() => {
                let angle = 0;
                return compData.map(d => {
                  const slice = (d.value / compTotal) * Math.PI * 2;
                  if (slice < 0.01) { angle += slice; return null; }
                  const outerArc = donutArc(angle, angle + slice, donutR);
                  const innerArc = donutArc(angle + slice, angle, donutInner);
                  const path = `${outerArc} L${donutCx + donutInner * Math.cos(angle + slice - Math.PI / 2)},${donutCy + donutInner * Math.sin(angle + slice - Math.PI / 2)} ${innerArc} Z`;
                  angle += slice;
                  return <path d={path} fill={d.color} opacity="0.85" />;
                });
              })()}
              <circle cx={donutCx} cy={donutCy} r={donutInner - 2} fill="#09090b" />
              <text x={donutCx} y={donutCy - 4} text-anchor="middle" fill="#e4e4e7" font-size="14" font-weight="700">{(compTotal / 1000).toFixed(0)}k</text>
              <text x={donutCx} y={donutCy + 12} text-anchor="middle" fill="#71717a" font-size="9">vehicles/day</text>
            </svg>
          </div>
        </div>
      </ScrollReveal>
      )}
    </div>
  </section>
  )}

  <!-- Junction Congestion Model -->
  {trafficData.congestion_model?.junctions?.length > 0 && (
  <section class="congestion-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">Junction Congestion Index</h2>
          <p class="section-sub">Restriction-aware scoring of 15 key junctions — full road closures, lane restrictions, and minor works weighted by actual capacity reduction, not just flat counts</p>
        </div>
      </ScrollReveal>
      <ScrollReveal>
        <div class="jci-grid">
          {trafficData.congestion_model.junctions.sort((a: any, b: any) => b.jci - a.jci).map((j: any) => {
            const jciColor = j.jci_level === 'critical' ? '#dc2626' : j.jci_level === 'high' ? '#f97316' : j.jci_level === 'moderate' ? '#eab308' : '#22c55e';
            return (
              <div class="jci-card" style={`border-left: 3px solid ${jciColor}`}>
                <div class="jci-top">
                  <span class="jci-name">{j.name}</span>
                  <span class="jci-score" style={`color:${jciColor}`}>{(j.jci || 0).toFixed(1)}</span>
                </div>
                <div class="jci-bar-track">
                  <div class="jci-bar-fill" style={`width:${j.jci || 0}%;background:${jciColor}`}></div>
                </div>
                <div class="jci-factors">
                  <span>Vol: {(j.traffic_volume || 0).toLocaleString()}</span>
                  {j.nearby_closures > 0 && <span class="factor-closure">Closures: {j.nearby_closures}</span>}
                  {j.nearby_lane_restrictions > 0 && <span class="factor-lane">Lane: {j.nearby_lane_restrictions}</span>}
                  {j.nearby_schools > 0 && <span>Schools: {j.nearby_schools}</span>}
