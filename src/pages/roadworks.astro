        </Accordion>
      </ScrollReveal>
      )}
    </div>
  </section>
  )}

  <!-- Operational Intelligence: Deferrals, Clashes, Timing -->
  {(deferrals.length > 0 || corridorClashes.length > 0) && (
  <section class="intel-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">Operational Intelligence</h2>
          <p class="section-sub">
            Restriction-aware analysis of {totalWorks} roadworks — identifying which LCC can defer,
            which need utility timing directions, and where corridor clashes breach coordination duties.
            {validity.in_school_term && <span class="term-badge">School term ({validity.current_term})</span>}
          </p>
          {validity.analysis_valid_until && (
