            <div class="cumulative-card cumulative-card--shortfall">
              <span class="cumulative-value">&pound;{(cumulativeAnalysis.cumulative_shortfall / 1e6).toFixed(0)}M</span>
              <span class="cumulative-label">Cumulative Shortfall</span>
            </div>
            <div class="cumulative-card">
              <span class="cumulative-value">{cumulativeAnalysis.investment_as_pct_of_need}%</span>
              <span class="cumulative-label">Of Need Was Met</span>
            </div>
          </div>
