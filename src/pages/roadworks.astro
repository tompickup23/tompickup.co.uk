              <span class="cumulative-label">Total Invested (14 yrs)</span>
            </div>
            <div class="cumulative-card">
              <span class="cumulative-value">&pound;{(cumulativeAnalysis.total_needed / 1e6).toFixed(0)}M</span>
              <span class="cumulative-label">Estimated Need (14 yrs)</span>
