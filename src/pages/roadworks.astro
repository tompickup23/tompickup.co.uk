            return (
            <div class="option-card">
              <div class="option-rank">#{i + 1}</div>
              <div class="option-body">
                <div class="option-head">
                  <h3 class="option-name">{opt.intervention}</h3>
                  <div class="option-score-ring" style={`--score: ${pct.toFixed(0)}%`}>
                    <span class="option-score-val">{(opt.overall_score || 0).toFixed(0)}</span>
                  </div>
                </div>
                <p class="option-desc">{opt.description}</p>
                <div class="option-meta">
                  <span class={`severity-badge severity-${opt.priority}`}>{opt.priority}</span>
                  {opt.congestion_reduction_pct > 0 && <span class="option-tag">-{opt.congestion_reduction_pct}% congestion</span>}
                  <span class="option-tag">Timeline: {opt.timeline}</span>
                </div>
                <div class="option-details">
                  <span class="option-detail"><strong>Legal basis:</strong> {opt.legal_basis}</span>
                  <span class="option-detail"><strong>Est. cost:</strong> {opt.cost}</span>
                  {opt.status && <span class="option-detail"><strong>Status:</strong> {opt.status}</span>}
                </div>
                {opt.evidence && <p class="option-evidence">{opt.evidence}</p>}
              </div>
            </div>
            );
          })}
        </div>
      </ScrollReveal>
    </div>
  </section>
