---
import Layout from '../layouts/Layout.astro';
import Accordion from '../components/Accordion.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
---

<Layout
  title="Lancashire County Council | Reform UK in Control | Tom Pickup"
  description="What Reform UK is delivering at Lancashire County Council. Budget discipline, protected services, inherited crises exposed, and real transparency across all departments."
>
  <!-- Hero -->
  <section class="lcc-hero">
    <div class="container">
      <ScrollReveal>
        <div class="lcc-hero-inner">
          <span class="badge badge-teal">Reform UK &middot; 53 of 84 Seats</span>
          <h1>Lancashire County Council</h1>
          <p class="lcc-hero-sub">
            Reform won a historic landslide in May 2025. Nine months in, here&rsquo;s what we inherited,
            what we&rsquo;ve fixed, and what we&rsquo;re building &mdash; for 1.2 million Lancashire residents.
          </p>
          <div class="hero-stats">
            <div class="hero-stat hero-stat-accent">
              <span class="hero-stat-value">&pound;1.33B</span>
              <span class="hero-stat-label">Revenue Budget</span>
            </div>
            <div class="hero-stat">
              <span class="hero-stat-value">&pound;292M</span>
              <span class="hero-stat-label">Capital Programme</span>
            </div>
            <div class="hero-stat">
              <span class="hero-stat-value">3.80%</span>
              <span class="hero-stat-label">CT Rise (Lowest 12 Yrs)</span>
            </div>
            <div class="hero-stat">
              <span class="hero-stat-value">53/84</span>
              <span class="hero-stat-label">Reform Seats</span>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Top Reform Achievements -->
  <section class="lcc-achievements">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">What We&rsquo;ve Delivered</h2>
          <p class="section-subtitle">Reform&rsquo;s first 9 months running Lancashire County Council &mdash; measurable results, not promises</p>
        </div>

        <div class="achievement-grid stagger-children">
          <div class="achievement-card">
            <div class="inherited-badge">Inherited: &pound;28M overspend</div>
            <span class="achievement-number" style="color: #30d158;">&pound;28M &rarr; &pound;0</span>
            <h3>Overspend Eliminated</h3>
            <p>Q1: &pound;28M projected overspend. Q2: &pound;10.4M. Q3: &pound;6.1M. January 2026: near zero. Targeted action, not blanket cuts.</p>
          </div>

          <div class="achievement-card">
            <div class="inherited-badge">Inherited: 4.99% max rises</div>
            <span class="achievement-number" style="color: var(--accent);">3.80%</span>
            <h3>Lowest CT Rise in 12 Years</h3>
            <p>Conservatives maxed council tax 7 of 8 years, including a record 5.99% in 2018/19. Reform&rsquo;s first budget: 3.80%.</p>
          </div>

          <div class="achievement-card">
            <div class="inherited-badge">Inherited: closure consultation</div>
            <span class="achievement-number" style="color: #ff453a;">5</span>
            <h3>Care Homes Saved</h3>
            <p>The Conservatives began consultation to close five county care homes. We listened to 1,600+ residents and secured their future with new investment.</p>
          </div>

          <div class="achievement-card">
            <div class="inherited-badge">Inherited: &pound;350M concealed</div>
            <span class="achievement-number" style="color: #ff9f0a;">&pound;350M</span>
            <h3>Bond Losses Exposed</h3>
            <p>&pound;519M invested in VeLTIP bonds now worth ~&pound;169M. The Conservatives failed to transparently report the scale of these paper losses.</p>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Departments — Rich Accordions -->
  <section class="lcc-departments">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">Department by Department</h2>
          <p class="section-subtitle">What each service area inherited, and what Reform is doing about it</p>
        </div>

        <div class="departments-list">
          <!-- Adult Social Care -->
          <Accordion title="Adult Social Care" subtitle="Biggest budget: 42% of total spend" value="&pound;559M" accentColor="#ff453a">
            <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            <div class="dept-content">
              <div class="inherited-block">
                <h4>What We Inherited</h4>
                <ul>
                  <li><strong>CQC rating: &ldquo;Requires Improvement&rdquo;</strong> (2.0/4) &mdash; joint-lowest of any county council in England</li>
                  <li>5 county care homes on the chopping block &mdash; closure consultation already underway</li>
                  <li>&pound;50M savings requirement demanded across 2025&ndash;27</li>
                  <li>&pound;245M annual residential placement costs &mdash; spiralling and unsustainable</li>
                </ul>
              </div>
              <div class="reform-block">
                <h4>What Reform Has Done</h4>
                <ul>
                  <li><strong>All 5 care homes saved</strong> &mdash; 1,600+ residents consulted, new investment pledged</li>
                  <li><strong>&pound;23M savings delivered</strong> (2025/26) via Living Better Lives transformation &mdash; not closures</li>
                  <li>&pound;559M budget secured for 2026/27 including &pound;26M inflation provision for NLW increase</li>
                  <li>Agency staff costs cut by &pound;1.5M vs prior year</li>
                </ul>
              </div>
            </div>
          </Accordion>

          <!-- Children's Social Care -->
          <Accordion title="Children's Social Care & Education" subtitle="SEND crisis inherited, 677 new places created" value="&pound;266M" accentColor="#bf5af2">
            <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            <div class="dept-content">
              <div class="inherited-block">
                <h4>What We Inherited</h4>
                <ul>
                  <li><strong>SEND Improvement Notice</strong> &mdash; formally issued by the Department for Education</li>
                  <li>DSG deficit spiralling: &pound;95M (2024/25) &rarr; projected &pound;420M by 2028/29</li>
                  <li>Chronic &pound;3M+ underfunding in Educational Psychology services</li>
                  <li>Paper-based EHCP application system &mdash; slow, inefficient, failing families</li>
                  <li>School transport costs exploding: &pound;17.7M demand growth in one year alone</li>
                </ul>
              </div>
              <div class="reform-block">
                <h4>What Reform Has Done</h4>
                <ul>
                  <li><strong>677 new SEND places created</strong> &mdash; 277 in 2025, 400 announced February 2026</li>
                  <li>New 200+ pupil special school to be built by 2027</li>
                  <li>&pound;3M+ annual Educational Psychology investment &mdash; directly addressing the gap</li>
                  <li>EHCP online portal built and rolling out September 2025 &mdash; replacing paper system</li>
                  <li>&pound;73M schools capital programme approved</li>
                </ul>
              </div>
            </div>
          </Accordion>

          <!-- Highways & Transport -->
          <Accordion title="Highways & Transport" subtitle="7,400 km road network — 42% defect reduction" value="&pound;123M" accentColor="#ff9f0a">
            <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 3a3 3 0 0 0-3 3v12a3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3H6a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3V6a3 3 0 0 0-3-3 3 3 0 0 0-3 3 3 3 0 0 0 3 3h12a3 3 0 0 0 3-3 3 3 0 0 0-3-3z"></path></svg>
            <div class="dept-content">
              <div class="inherited-block">
                <h4>What We Inherited</h4>
                <ul>
                  <li>Massive pothole and maintenance backlog from years of underfunding</li>
                  <li>Reactive &ldquo;use it or lose it&rdquo; approach &mdash; March year-end spending spike was 14.7&times; the monthly average</li>
                  <li>Deterioration rate exceeding maintenance capacity across the 7,400 km network</li>
                </ul>
              </div>
              <div class="reform-block">
                <h4>What Reform Has Done</h4>
                <ul>
                  <li><strong>42% reduction in road defects</strong> in the first 6 months &mdash; data-driven, proactive approach</li>
                  <li>&pound;28M dedicated pothole/structural repair budget plus &pound;5M emergency cabinet decision</li>
                  <li>&pound;45M 3-year roads investment pledge &mdash; systematic, not reactive</li>
                  <li>AI traffic management pilot: real-time signal optimisation to reduce congestion</li>
                  <li>DfT 4-year settlement secured: &pound;48.5M rising to &pound;70.1M by 2029/30</li>
                </ul>
              </div>
            </div>
          </Accordion>

          <!-- Waste & Environment -->
          <Accordion title="Waste & Environment" subtitle="First competitive tender in a generation" value="&pound;97M" accentColor="#30d158">
            <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
            <div class="dept-content">
              <div class="inherited-block">
                <h4>What We Inherited</h4>
                <ul>
                  <li>Long-term waste disposal contract with limited competition &mdash; no open tender for years</li>
                  <li>Whinney Hill landfill costs: &pound;74.5M alone</li>
                  <li>Recycling underperforming; waste minimisation chronically underfunded (&pound;100K budget)</li>
                </ul>
              </div>
              <div class="reform-block">
                <h4>What Reform Has Done</h4>
                <ul>
                  <li><strong>&pound;60.3M competitive waste tender</strong> &mdash; first proper open competition in a generation</li>
                  <li>Burnley lot processed locally at Hapton Valley, supporting local jobs</li>
                  <li>&pound;97M budget protected for 2026/27</li>
                </ul>
              </div>
            </div>
          </Accordion>

          <!-- Corporate & Finance -->
          <Accordion title="Corporate Services & Finance" subtitle="VeLTIP exposed, pension pay stopped, savings restored" value="&pound;242M" accentColor="#12b6cf">
            <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 7c-1-2-3.5-3-6-3-3.3 0-6 2.7-6 6 0 1.5.5 2.8 1.3 3.8"></path><path d="M4 17h12"></path><path d="M4 13h8"></path><path d="M10 7v14"></path></svg>
            <div class="dept-content">
              <div class="inherited-block">
                <h4>What We Inherited</h4>
                <ul>
                  <li><strong>&pound;350M VeLTIP bond losses concealed</strong> &mdash; &pound;519M invested, now worth ~&pound;169M</li>
                  <li>Savings delivery collapsed: 91.5% (2023/24) &rarr; <strong>48%</strong> (2024/25) &mdash; &pound;35.7M in targets never materialised</li>
                  <li>Councillors collecting additional salaries as pension fund company directors</li>
                  <li>Oracle Fusion system failures: data breaches, payment errors, missed deadlines</li>
                  <li>Council debt: &pound;1.18 billion</li>
                </ul>
              </div>
              <div class="reform-block">
                <h4>What Reform Has Done</h4>
                <ul>
                  <li><strong>VeLTIP losses exposed publicly</strong> &mdash; &pound;58.4M reserve being built to manage bond disposal</li>
                  <li>Savings delivery: targeting 100% (vs. 48% inherited). &pound;62M programme on track</li>
                  <li><strong>Pension fund director salaries: stopped</strong> &mdash; public service, not personal gain</li>
                  <li><strong>Councillor pay freeze</strong>: voted 75-0 (3 abstentions). Saving &pound;115K/year</li>
                  <li>Debt reduction plan: &pound;1.18B &rarr; &pound;1.06B over 5 years</li>
                  <li>Agency staff cut by &pound;1.5M in first year</li>
                </ul>
              </div>
            </div>
          </Accordion>

          <!-- Public Health -->
          <Accordion title="Public Health" subtitle="Ring-fenced grant — health inequalities focus" value="&pound;99M" accentColor="#5e5ce6">
            <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            <div class="dept-content">
              <div class="inherited-block">
                <h4>What We Inherited</h4>
                <ul>
                  <li>Significant health inequalities across Lancashire &mdash; some of the worst in England</li>
                  <li>Ring-fenced grant declining in real terms since 2015</li>
                </ul>
              </div>
              <div class="reform-block">
                <h4>What Reform Has Done</h4>
                <ul>
                  <li>Ring-fenced public health grant protected &mdash; not raided for general budget</li>
                  <li>&pound;99M budget maintained for smoking cessation, substance misuse, sexual health, obesity programmes</li>
                  <li>&pound;17.2M Crisis Resilience Fund launched &mdash; 3-year programme (2026&ndash;2029) replacing Household Support Fund</li>
                </ul>
              </div>
            </div>
          </Accordion>

          <!-- Libraries & Culture -->
          <Accordion title="Libraries & Culture" subtitle="64 libraries protected as community hubs" value="&pound;19M" accentColor="#ffd60a">
            <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
            <div class="dept-content">
              <div class="inherited-block">
                <h4>What We Inherited</h4>
                <ul>
                  <li>Network of 64 libraries under constant budget pressure</li>
                  <li>Chronic underfunding and post-COVID recovery challenges</li>
                </ul>
              </div>
              <div class="reform-block">
                <h4>What Reform Has Done</h4>
                <ul>
                  <li>All 64 libraries protected &mdash; no closures, no cuts</li>
                  <li>Libraries positioned as community resilience hubs under Crisis Resilience Fund</li>
                  <li>Archives and cultural services maintained (&pound;1.1M archives, &pound;0.7M arts)</li>
                </ul>
              </div>
            </div>
          </Accordion>

          <!-- Fire & Rescue -->
          <Accordion title="Fire & Rescue Service" subtitle="39 fire stations across Lancashire" accentColor="#ff6b6b">
            <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            <div class="dept-content">
              <div class="reform-block">
                <h4>Status</h4>
                <ul>
                  <li>39 fire stations maintained across Lancashire</li>
                  <li>Lancashire Fire and Rescue Service operates under the Combined Fire Authority</li>
                  <li>Covers fire response, RTC rescue, flood response, and community fire safety</li>
                  <li>Capital investment maintained within the &pound;292M programme</li>
                </ul>
              </div>
            </div>
          </Accordion>

          <!-- Trading Standards -->
          <Accordion title="Trading Standards" subtitle="Consumer protection — rogue traders, scam prevention" value="&pound;3M" accentColor="#636366">
            <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            <div class="dept-content">
              <div class="reform-block">
                <h4>Status</h4>
                <ul>
                  <li>Service maintained at &pound;3M budget &mdash; protecting consumers and legitimate businesses</li>
                  <li>Investigating rogue traders, doorstep crime, and counterfeit goods</li>
                  <li>Food safety and underage sales enforcement ongoing</li>
                </ul>
              </div>
            </div>
          </Accordion>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Biggest Risks We Inherited -->
  <section class="risks-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">The Crises We Inherited</h2>
          <p class="section-subtitle">Structural problems left by the previous Conservative administration that cannot be fixed overnight</p>
        </div>
        <div class="risks-grid stagger-children">
          <div class="risk-card risk-critical">
            <span class="risk-level">Critical</span>
            <h3>SEND &amp; DSG Deficit</h3>
            <p>&pound;95M deficit growing to &pound;420M by 2028/29. National crisis, but Lancashire&rsquo;s was made worse by years of inaction. Safety Valve negotiations with DfE ongoing.</p>
          </div>
          <div class="risk-card risk-critical">
            <span class="risk-level">Critical</span>
            <h3>VeLTIP Bond Losses</h3>
            <p>&pound;519M invested, now worth ~&pound;169M. Building a &pound;58M reserve to manage disposal. The Conservatives concealed the true scale from councillors and public.</p>
          </div>
          <div class="risk-card risk-high">
            <span class="risk-level">High</span>
            <h3>Council Debt: &pound;1.18B</h3>
            <p>Treasury costs rising from &pound;79M to &pound;99M by 2028/29. 5-year plan to reduce debt by &pound;125M. No quick fix &mdash; this was years in the making.</p>
          </div>
          <div class="risk-card risk-high">
            <span class="risk-level">High</span>
            <h3>Reserves Declining</h3>
            <p>6th consecutive year of draw-down. Only 4.2 months&rsquo; cover remaining &mdash; below the 6-month prudent minimum. We&rsquo;re rebuilding them.</p>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Data Sources -->
  <section class="sources-section">
    <div class="container">
      <div class="sources-card">
        <span class="sources-label">Data Sources</span>
        <p>
          LCC Budget Report 2026/27 (Full Council, 26 February 2026) &bull;
          LCC Proposed Budget &amp; Medium-Term Financial Strategy &bull;
          DfT Highway Maintenance Settlement 2026&ndash;2030 &bull;
          CQC Adult Social Care Assessment &bull;
          LCC Published Spending Data (Transparency Code) &bull;
          LCC Highways Capital Programme (Cabinet, March 2026) &bull;
          LCC Crisis Resilience Fund (Cabinet, March 2026) &bull;
          Reform UK Transformation Report (9 months)
        </p>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="lcc-contact">
    <div class="container">
      <ScrollReveal>
        <div class="contact-cta-card">
          <div class="contact-cta-lines"></div>
          <div class="contact-cta-inner">
            <h2>Questions About the County Council?</h2>
            <p>Whether it&rsquo;s about highways, schools, social care, or council finances &mdash; I&rsquo;m here to help.</p>
            <a href="/contact/" class="cta-btn-white">Get in Touch</a>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>
</Layout>

<style>
  /* ---- Hero ---- */
  .lcc-hero {
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  .lcc-hero-inner {
    max-width: 720px;
  }

  .lcc-hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.08;
    margin: var(--space-md) 0 var(--space-md);
    background: linear-gradient(135deg, #ffffff 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .lcc-hero-sub {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 600px;
    margin-bottom: var(--space-lg);
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-sm);
  }

  .hero-stat {
    padding: var(--space-md);
    background: rgba(28, 28, 30, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .hero-stat-accent {
    border-color: var(--accent-border);
    background: rgba(18, 182, 207, 0.06);
  }

  .hero-stat-value {
    display: block;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
    line-height: 1.2;
  }

  .hero-stat-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 4px;
  }

  /* ---- Achievements ---- */
  .lcc-achievements {
    padding: var(--space-xl) 0 var(--space-2xl);
  }

  .achievement-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }

  .achievement-card {
    padding: var(--space-lg);
    background: rgba(28, 28, 30, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
    text-align: center;
    transition: border-color var(--transition-normal), transform var(--transition-fast);
  }

  .achievement-card:hover {
    border-color: rgba(255, 255, 255, 0.12);
    transform: translateY(-3px);
  }

  .inherited-badge {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #ff453a;
    padding: 3px 10px;
    background: rgba(255, 69, 58, 0.1);
    border: 1px solid rgba(255, 69, 58, 0.2);
    border-radius: 9999px;
    display: inline-block;
    margin-bottom: var(--space-md);
  }

  .achievement-number {
    display: block;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: var(--space-sm);
    font-variant-numeric: tabular-nums;
  }

  .achievement-card h3 {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
  }

  .achievement-card p {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* ---- Departments ---- */
  .lcc-departments {
    padding: 0 0 var(--space-2xl);
  }

  .departments-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .dept-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .inherited-block, .reform-block {
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-md);
  }

  .inherited-block {
    background: rgba(255, 69, 58, 0.04);
    border: 1px solid rgba(255, 69, 58, 0.1);
  }

  .reform-block {
    background: rgba(48, 209, 88, 0.04);
