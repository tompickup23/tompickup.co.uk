---
import Layout from '../layouts/Layout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import WardMap3D from '../components/WardMap3D.astro';
import wardData from '../data/burnley-wards.json';

const wards = Object.values(wardData.wards);
const meta = wardData.meta;

// Aggregate stats
const totalCouncillors = wards.reduce((sum, w: any) => sum + (w.councillors?.length || 0), 0);
const totalPlanningApps = wards.reduce((sum, w: any) => sum + (w.planning?.total || 0), 0);

// Party breakdown
const partySeats = {} as any;
wards.forEach((w: any) => {
  (w.councillors || []).forEach((c: any) => {
    const p = c.party || 'Unknown';
    partySeats[p] = (partySeats[p] || 0) + 1;
  });
});
const sortedParties = Object.entries(partySeats).sort((a: any, b: any) => b[1] - a[1]);

// Deprivation summary
const depLevels = {} as any;
wards.forEach((w: any) => {
  const level = w.deprivation?.deprivation_level || 'Unknown';
  depLevels[level] = (depLevels[level] || 0) + 1;
});
const highDepCount = (depLevels['Very High'] || 0) + (depLevels['High'] || 0);

// Party colour map
const partyColors = {
  'Labour': '#E4003B',
  'Labour & Co-operative Party': '#E4003B',
  'Conservative': '#0087DC',
  'Liberal Democrats': '#FAA61A',
  'Green Party': '#6AB023',
  'Reform UK': '#12b6cf',
  'Independent': '#808080',
} as any;

function getPartyColor(party: string) {
  return partyColors[party] || '#808080';
}
---

<Layout
  title="Burnley Borough Council | Tom Pickup"
  description="Your guide to Burnley Borough Council. 15 wards, 45 councillors, planning applications, deprivation data, and more. Explore your ward."
>
  <!-- Hero -->
  <section class="burnley-hero">
    <div class="container">
      <ScrollReveal>
        <div class="burnley-hero-inner">
          <span class="badge badge-teal">Borough Council</span>
          <h1>Burnley Borough Council</h1>
          <p class="hero-sub">
            Your borough council handles housing, planning applications, waste collection,
            parks, leisure centres, and council tax collection. It has 45 councillors
            representing 15 wards.
          </p>
          <div class="hero-stats">
            <div class="hero-stat">
              <span class="hero-stat-value">{meta.borough_demographics?.summary?.population?.toLocaleString() || '94,649'}</span>
              <span class="hero-stat-label">Population</span>
            </div>
            <div class="hero-stat">
              <span class="hero-stat-value">15</span>
              <span class="hero-stat-label">Wards</span>
            </div>
            <div class="hero-stat">
              <span class="hero-stat-value">{totalCouncillors}</span>
              <span class="hero-stat-label">Councillors</span>
            </div>
            <div class="hero-stat">
              <span class="hero-stat-value">{totalPlanningApps.toLocaleString()}</span>
              <span class="hero-stat-label">Planning Apps</span>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Ward Map -->
  <section class="map-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header" style="text-align: center;">
          <h2 class="section-heading">Find Your Ward</h2>
          <p class="section-subtitle" style="max-width: 540px; margin: var(--space-sm) auto 0;">
            Click your ward to see who represents you, local deprivation data, planning applications, and election history.
          </p>
        </div>
        <WardMap3D size="full" />
      </ScrollReveal>
    </div>
  </section>

  <!-- Political Control -->
  <section class="control-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">Political Control</h2>
          <p class="section-subtitle">How the 45 borough council seats are distributed</p>
        </div>
        <div class="control-grid">
          <div class="control-bar-container">
            <div class="control-bar">
              {sortedParties.map(([party, seats]) => (
                <div
                  class="control-segment"
                  style={`flex: ${seats}; background: ${getPartyColor(party)};`}
                  title={`${party}: ${seats} seats`}
                >
                  <span class="segment-count">{seats}</span>
                </div>
              ))}
            </div>
            <div class="control-legend">
              {sortedParties.map(([party, seats]) => (
                <div class="legend-item">
                  <span class="legend-dot" style={`background: ${getPartyColor(party)};`}></span>
                  <span class="legend-label">{party}</span>
                  <span class="legend-count">{seats}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="control-context">
            <div class="context-card">
              <h3>No Overall Control</h3>
              <p>
                No single party holds a majority (23 seats needed). The largest groups are
                Labour and Independent with {sortedParties[0][1]} and {sortedParties[1][1]} seats respectively.
              </p>
              <p class="context-note">
                Next elections: <strong>7 May 2026</strong> &mdash; one third of seats up for election.
              </p>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Deprivation Overview -->
  <section class="deprivation-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">Deprivation Across Burnley</h2>
          <p class="section-subtitle">
            {highDepCount} of 15 wards have high or very high deprivation levels.
            Burnley is one of the most deprived boroughs in England.
          </p>
        </div>
        <div class="ward-list stagger-children">
          {wards.sort((a: any, b: any) => {
            const order = { 'Very High': 0, 'High': 1, 'Medium-High': 2, 'Medium': 3, 'Low': 4, 'Unknown': 5 } as any;
            return (order[a.deprivation?.deprivation_level] ?? 5) - (order[b.deprivation?.deprivation_level] ?? 5);
          }).map((ward: any) => {
            const depLevel = ward.deprivation?.deprivation_level || 'Unknown';
            const depColor = depLevel === 'Very High' ? '#ff453a' : depLevel === 'High' ? '#ff9f0a' : depLevel === 'Medium-High' ? '#ffd60a' : depLevel === 'Medium' ? '#30d158' : depLevel === 'Low' ? '#12b6cf' : '#636366';
            return (
              <a href={`/wards/${ward.slug}/`} class="ward-row">
                <div class="ward-row-left">
                  <span class="ward-name">{ward.name}</span>
                  <span class="ward-party" style={`color: ${getPartyColor(ward.primary_party)}`}>{ward.primary_party}</span>
                </div>
                <div class="ward-row-right">
                  <span class="dep-badge" style={`background: ${depColor}20; color: ${depColor}; border-color: ${depColor}40;`}>
                    {depLevel}
                  </span>
                  <span class="ward-planning">{ward.planning?.total || 0} apps</span>
                  <svg class="ward-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                </div>
              </a>
            );
          })}
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- What Does the Borough Council Do? -->
  <section class="services-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">What Does the Borough Council Do?</h2>
          <p class="section-subtitle">Services delivered by Burnley Borough Council (not the county council)</p>
        </div>
        <div class="services-grid stagger-children">
          <div class="service-card">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
            <h3>Housing</h3>
            <p>Council housing, homelessness, housing standards, HMO licensing, empty homes.</p>
          </div>
          <div class="service-card">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
            <h3>Planning</h3>
            <p>Planning applications, building control, conservation, listed buildings.</p>
          </div>
          <div class="service-card">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
            <h3>Waste Collection</h3>
            <p>Bin collections, recycling, street cleansing, fly-tipping enforcement.</p>
          </div>
          <div class="service-card">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M8 14s1.5 2 4 2 4-2 4-2"></path><line x1="9" y1="9" x2="9.01" y2="9"></line><line x1="15" y1="9" x2="15.01" y2="9"></line></svg>
            <h3>Leisure &amp; Parks</h3>
            <p>Parks, playgrounds, leisure centres, cemeteries, allotments.</p>
          </div>
          <div class="service-card">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            <h3>Environmental Health</h3>
            <p>Food hygiene, noise complaints, pest control, air quality, licensing.</p>
          </div>
          <div class="service-card">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect><line x1="1" y1="10" x2="23" y2="10"></line></svg>
            <h3>Council Tax</h3>
            <p>Collecting council tax and business rates for all tiers of local government.</p>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- LCC Capital Investment in Burnley -->
  <section class="capital-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <h2 class="section-heading">County Council Investment in Burnley</h2>
          <p class="section-subtitle">
            What Lancashire County Council is spending in and around the Burnley borough. Part of a &pound;292 million county-wide capital programme and &pound;1.33 billion revenue budget for 2026/27.
          </p>
        </div>

        <div class="capital-grid stagger-children">
          <div class="capital-card">
            <div class="capital-icon" style="color: #ff9f0a;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 3a3 3 0 0 0-3 3v12a3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3H6a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3V6a3 3 0 0 0-3-3 3 3 0 0 0-3 3 3 3 0 0 0 3 3h12a3 3 0 0 0 3-3 3 3 0 0 0-3-3z"></path></svg>
            </div>
            <span class="capital-value tabular-nums">&pound;748K</span>
            <h3>Highways Capital 2026/27</h3>
            <p>7 funded road resurfacing and surface dressing schemes across Burnley borough, from the &pound;72 million county-wide highways capital programme. The largest allocation among East Lancashire districts.</p>
          </div>

          <div class="capital-card">
            <div class="capital-icon" style="color: #30d158;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"></path><path d="M5 21V7l8-4v18"></path><path d="M19 21V11l-6-4"></path></svg>
            </div>
            <span class="capital-value tabular-nums">&pound;55M</span>
            <h3>East Lancashire LUF</h3>
            <p>Levelling Up Fund regeneration programme for Burnley and Pendle. Includes Manchester Road corridor improvements, Colne Road enhancements, and Centenary Way Viaduct remediation.</p>
          </div>

          <div class="capital-card">
            <div class="capital-icon" style="color: #bf5af2;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
            </div>
            <span class="capital-value tabular-nums">SEND</span>
            <h3>Special Schools Capital</h3>
            <p>Capital funding for new special school provision in East Lancashire, including a new secondary SEND unit in Burnley. Part of Lancashire&rsquo;s SEND Sufficiency Strategy to create local places and reduce costly out-of-area placements.</p>
          </div>

          <div class="capital-card">
            <div class="capital-icon" style="color: #ff453a;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            </div>
            <span class="capital-value tabular-nums">&pound;16.4M</span>
            <h3>Children&rsquo;s Social Care</h3>
            <p>Annual county council spending on fostering, residential care, family support, and leaving care services across the Burnley district. The single largest service category.</p>
          </div>

          <div class="capital-card">
            <div class="capital-icon" style="color: #5e5ce6;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
            </div>
            <span class="capital-value tabular-nums">&pound;20.7M</span>
            <h3>Disabled Facilities Grants</h3>
            <p>Capital grant passported to district councils for home adaptations &mdash; stairlifts, wet rooms, and accessibility works for disabled and elderly residents across Lancashire.</p>
          </div>

          <div class="capital-card">
            <div class="capital-icon" style="color: #ff6b6b;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            </div>
            <span class="capital-value tabular-nums">&pound;17.2M</span>
            <h3>Crisis Resilience Fund</h3>
            <p>New 3-year programme from April 2026 replacing the Household Support Fund. Crisis payments, affordable warmth, resilience hubs, and employment support &mdash; distributed through district councils.</p>
          </div>
        </div>

        <div class="capital-note">
          <p>
            Source: LCC Budget Report 2026/27 (Full Council, February 2026) &bull; LCC Highways Capital Programme 2026/27 (Cabinet, March 2026) &bull; LCC Crisis Resilience Fund (Cabinet, March 2026) &bull; LCC Published Spending Data (Transparency Code) &bull; East Lancashire LUF programme
          </p>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- How Councils Fit Together -->
  <section class="tiers-section">
    <div class="container">
      <ScrollReveal>
        <div class="section-header" style="text-align: center;">
          <h2 class="section-heading">How Councils Fit Together</h2>
          <p class="section-subtitle" style="max-width: 560px; margin: var(--space-sm) auto 0;">
            In Lancashire, you have three tiers of local government. Each does different things.
          </p>
        </div>
        <div class="tiers-grid stagger-children">
          <a href="/burnley/" class="tier-card tier-active">
            <span class="tier-level">Borough</span>
            <h3>Burnley Borough Council</h3>
            <p>Housing, planning, bins, parks, leisure, council tax collection</p>
            <span class="tier-detail">45 councillors &middot; 15 wards</span>
          </a>
          <a href="/lancashire/" class="tier-card">
            <span class="tier-level">County</span>
            <h3>Lancashire County Council</h3>
            <p>Schools, roads, social care, libraries, fire service, trading standards</p>
            <span class="tier-detail">84 councillors &middot; Reform UK majority</span>
          </a>
          <a href="/clowbridge/" class="tier-card">
            <span class="tier-level">Parish</span>
            <h3>Clowbridge with Dunnockshaw</h3>
            <p>Local environment, footpaths, community events, planning consultation</p>
            <span class="tier-detail">Smallest tier &middot; hyper-local</span>
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="contact-section">
    <div class="container">
      <ScrollReveal>
        <div class="contact-cta-card">
          <div class="contact-cta-lines"></div>
          <div class="contact-cta-inner">
            <h2>Got a question about Burnley?</h2>
            <p>Whether it&rsquo;s planning, housing, bins, or anything else &mdash; get in touch.</p>
            <a href="/contact/" class="cta-btn-white">Contact Me</a>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>
</Layout>

<style>
  /* ---- Hero ---- */
  .burnley-hero {
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  .burnley-hero-inner {
    max-width: 680px;
  }

  .burnley-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.08;
    margin: var(--space-md) 0 var(--space-md);
    background: linear-gradient(135deg, #ffffff 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: var(--space-lg);
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-sm);
  }

  .hero-stat {
    padding: var(--space-md);
    background: rgba(28, 28, 30, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .hero-stat-value {
    display: block;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
    line-height: 1.2;
  }

  .hero-stat-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 4px;
  }

  /* ---- Map Section ---- */
  .map-section {
    padding: 0 0 var(--space-2xl);
  }

  /* ---- Political Control ---- */
  .control-section {
    padding: 0 0 var(--space-2xl);
  }

  .control-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .control-bar-container {
    padding: var(--space-lg);
    background: rgba(28, 28, 30, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
  }

  .control-bar {
    display: flex;
    border-radius: 8px;
    overflow: hidden;
    height: 36px;
    gap: 2px;
  }

  .control-segment {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity var(--transition-fast);
  }

  .control-segment:hover {
    opacity: 0.8;
  }

  .segment-count {
    font-size: 0.75rem;
    font-weight: 700;
    color: #fff;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
  }

  .control-legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm) var(--space-md);
    margin-top: var(--space-md);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8125rem;
  }

  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .legend-label {
    color: var(--text-secondary);
  }

  .legend-count {
    font-weight: 700;
    color: var(--text-primary);
    font-variant-numeric: tabular-nums;
  }

  .control-context {
    /* nothing extra needed */
  }

  .context-card {
    padding: var(--space-lg);
    background: rgba(28, 28, 30, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
  }

  .context-card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
  }

  .context-card p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: var(--space-sm);
  }

  .context-note {
    font-size: 0.875rem;
    color: var(--accent);
  }

  /* ---- Ward List ---- */
  .deprivation-section {
    padding: 0 0 var(--space-2xl);
  }

  .ward-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    background: rgba(28, 28, 30, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .ward-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    text-decoration: none;
    background-image: none;
    color: var(--text-primary);
    transition: background-color var(--transition-fast);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .ward-row:last-child {
    border-bottom: none;
  }

  .ward-row:hover {
    background: rgba(255, 255, 255, 0.04);
    background-image: none;
    background-size: 0;
  }

  .ward-row-left {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .ward-name {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .ward-party {
    font-size: 0.75rem;
    font-weight: 600;
  }

  .ward-row-right {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .dep-badge {
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 9999px;
    border: 1px solid;
    text-transform: uppercase;
